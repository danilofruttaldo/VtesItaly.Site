---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'grand-prix')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title="Grand Prix" description="Il Grand Prix italiano di Vampire: The Eternal Struggle, il torneo più atteso della stagione.">
  <PageHero title="Grand Prix" image="/images/headers/header-grand-prix.webp" />
  <section class="section"><div class="container container--narrow">
    <p class="lead">Il <strong>Grand Prix italiano</strong> di Vampire: The Eternal Struggle è il <strong>torneo più atteso</strong> della stagione italiana. Appuntamento fisso del circuito europeo, aperto a tutti i Matusalemme pronti a mettersi alla prova tra <strong>intrighi</strong>, <strong>fragili alleanze</strong> e <strong>colpi di scena</strong>.</p>
    <p>Porta il tuo mazzo, affila le strategie… e preparati a conquistare il potere nella <strong>lotta eterna per il dominio</strong>.</p>

    <hr class="divider" />

    <h2 class="section-title">Edizioni del Grand Prix</h2>
    <div class="editions-list">
      {posts.map(post => (
        <a href={`/grand-prix/${post.slug}/`} class="edition-card">
          <span class="edition-year">{new Date(post.data.date).getFullYear()}</span>
          <span class="edition-label">{post.data.title}</span>
        </a>
      ))}
    </div>
  </div></section>
</Base>

<style>
  .section { padding: 40px clamp(20px, 5vw, 80px) 48px; }
  .section-title { font-size: clamp(1.2rem, 3.5vw, 1.5rem); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 0.5px; }
  .lead { font-size: clamp(0.95rem, 3vw, 1.05rem); line-height: 1.7; }
  .divider { border: none; border-top: 1px solid var(--color-accent-light); margin: 32px 0; }
  .editions-list { display: flex; flex-direction: column; gap: 12px; }
  .edition-card {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 20px; border-radius: var(--radius);
    border: 1px solid var(--color-border);
    text-decoration: none; color: var(--color-contrast);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }
  .edition-card:hover { background-color: rgba(255,255,255,0.04); transform: translateX(2px); color: var(--color-contrast); }
  .edition-year { font-size: 1.5rem; font-weight: 700; color: var(--color-gold); min-width: 60px; }
  .edition-label { font-size: 1rem; font-weight: 600; }
</style>
