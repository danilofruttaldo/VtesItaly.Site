---
import Base from '../layouts/Base.astro';
import { getLocaleFromUrl } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const isEn = locale === 'en';
---
<Base title="404">
  <section class="not-found">
    <div class="container">
      <h1>404</h1>
      <p class="subtitle">{isEn ? 'Page not found.' : 'Pagina non trovata.'}</p>
      <p class="hint">{isEn ? 'The vampire you were looking for has hidden in the shadows...' : 'Il vampiro che cercavi si è nascosto nell\'ombra...'}</p>
      <nav class="not-found__links">
        <a href={isEn ? '/en/' : '/'} class="btn">Home</a>
        <a href={isEn ? '/en/community/' : '/comunita/'} class="btn btn--outline">{isEn ? 'Community' : 'Comunità'}</a>
        <a href={isEn ? '/en/domains/' : '/principati/'} class="btn btn--outline">{isEn ? 'Domains' : 'Principati'}</a>
      </nav>
    </div>
  </section>
</Base>
<style>
  .not-found { text-align: center; padding: 100px 20px; }
  .not-found h1 { font-size: 5rem; color: var(--color-accent-1); margin-bottom: 8px; line-height: 1; }
  .subtitle { color: var(--color-muted); margin-bottom: 8px; font-size: 1.1rem; }
  .hint { color: var(--color-gold); font-style: italic; margin-bottom: 32px; font-size: 0.9rem; }
  .not-found__links { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn--outline {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent-1);
  }
  .btn--outline:hover {
    background-color: var(--color-accent);
    color: #fff;
  }
</style>
