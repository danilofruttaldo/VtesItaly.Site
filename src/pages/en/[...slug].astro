---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import TourEdition from '../../components/TourEdition.astro';
import GpEdition from '../../components/GpEdition.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';
import { categoryLabels, categoryUrls } from '../../data/categories';
import { cities } from '../../data/cities';
import { filterByLocale, useTranslations, formatLocalDate } from '../../utils/i18n';

const t = useTranslations('en');

export async function getStaticPaths() {
  const posts = filterByLocale(await getCollection('blog'), 'en');
  return posts.map(post => {
    const cleanSlug = post.slug.replace(/-en$/, '');
    return {
      params: { slug: `${post.data.category}/${cleanSlug}` },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();

// Build gallery: explicit list or auto-glob from folder
let galleryImages: string[] = post.data.gallery || [];
if (post.data.galleryFolder && galleryImages.length === 0) {
  const folder = post.data.galleryFolder.replace(/^\//, '').replace(/\/$/, '');
  const allImages = import.meta.glob('/public/images/gallery/**/*.{webp,jpg,jpeg,png}');
  galleryImages = Object.keys(allImages)
    .filter(p => p.includes(`/${folder}/`))
    .map(p => p.replace('/public', ''))
    .sort();
}


const label = categoryLabels[post.data.category]?.en || post.data.category;
const backUrl = categoryUrls[post.data.category]?.en || t.routes.comunita;
const backLabel = categoryLabels[post.data.category]?.en || t.not_found.community;

// Map city slugs to their domain page
const cityMap = new Map(cities.map(c => [c.slug.it, { name: c.name.en, url: `/en/domains/${c.slug.en}/` }]));

const isTourWithStages = post.data.category === 'tour' && post.data.stages && post.data.stages.length > 0;
const tourToday = new Date(); tourToday.setHours(0, 0, 0, 0);
const tourComputedStatuses = isTourWithStages ? post.data.stages!.map(s => {
  if (s.status === 'cancelled') return 'cancelled';
  const d = new Date(s.date); d.setHours(0, 0, 0, 0);
  return d < tourToday ? 'completed' : 'future';
}) : [];
const tourAllCompleted = tourComputedStatuses.filter(s => s !== 'cancelled').every(s => s === 'completed');
const tourAllFuture = tourComputedStatuses.filter(s => s !== 'cancelled').every(s => s === 'future');
const tourStatus = isTourWithStages ? (tourAllCompleted ? 'past' : tourAllFuture ? 'upcoming' : 'live') : null;
const isGp = post.data.category === 'grand-prix';
const gpEventDate = isGp ? new Date(post.data.date) : null;
const gpToday = isGp ? new Date() : null;
const gpIsToday = gpEventDate && gpToday && gpEventDate.toDateString() === gpToday.toDateString();
const gpStatus = isGp ? (gpIsToday ? 'live' : (gpEventDate! > gpToday! ? 'upcoming' : 'past')) : null;
const usePageHero = isTourWithStages || isGp;
const pageMeta = usePageHero ? mainPages.find(p => p.category === post.data.category) : null;

---
<Base title={post.data.title} description={post.data.excerpt || post.data.title} ogImage={post.data.featuredImage}>
  <JsonLd slot="head" data={{
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    datePublished: post.data.date.toISOString(),
    description: post.data.excerpt || post.data.title,
    ...(post.data.featuredImage ? { image: new URL(post.data.featuredImage, Astro.site).href } : {}),
    publisher: { '@type': 'Organization', name: 'VTES Italy', logo: { '@type': 'ImageObject', url: new URL('/images/logo.webp', Astro.site).href } }
  }} />

  {/* PageHero for tour and GP, classic hero for the rest */}
  {usePageHero && pageMeta ? (
    <PageHero title="" image={pageMeta.headerImage} />
  ) : post.data.featuredImage && (
    <div class="post__hero-wrap">
      <img src={post.data.featuredImage} alt={post.data.title} class="post__hero" loading="eager" decoding="async" />
      <div class="post__hero-overlay"></div>
    </div>
  )}

  <article class="post">

    <div class="container container--narrow">
      {/* Back link */}
      <a href={backUrl} class="post__back">&larr; {backLabel}</a>

      {/* Title & description */}
      <header class="post__header">
        <div class="post__title-row">
          <h1 class="post__title">{post.data.title}</h1>
          {isTourWithStages && tourStatus && (
            <span class:list={['post__status', tourStatus === 'past' ? 'post__status--finished' : 'post__status--active']}>
              {tourStatus === 'past' ? t.status.past : tourStatus === 'live' ? t.status.live : t.status.upcoming}
            </span>
          )}
          {isGp && gpStatus && (
            <span class:list={['post__status', gpStatus === 'past' ? 'post__status--finished' : 'post__status--active']}>
              {gpStatus === 'live' ? t.status.live : gpStatus === 'upcoming' ? t.status.upcoming : t.status.past}
            </span>
          )}
        </div>
        {!usePageHero && post.data.excerpt && (
          <p class="post__excerpt">{post.data.excerpt}</p>
        )}
      </header>

      {/* Metadata: category + date, then tags */}
      <div class="post__meta-row">
        <span class="post__category">{label}</span>
        <time class="post__date" datetime={post.data.date.toISOString()}>
          {formatLocalDate(post.data.date, 'en')}
        </time>
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post__tags-row">
          <div class="post__tags">
            {post.data.tags.map(tag => {
              const city = cityMap.get(tag);
              return city ? (
                <a href={city.url} class="post__tag post__tag--city">{city.name}</a>
              ) : (
                <span class="post__tag">{tag}</span>
              );
            })}
          </div>
        </div>
      )}
      <hr class="post__divider" />

      {/* Layout per categoria */}
      {isTourWithStages ? (
        <TourEdition post={post} locale="en" />
      ) : isGp ? (
        <GpEdition post={post} locale="en" />
      ) : (
        <>
          <div class="post__content prose">
            <Content />
          </div>
          {galleryImages.length > 0 && (
            <section class="post__gallery">
              <h2 class="post__gallery-title">{t.post.gallery}</h2>
              <div class="post__gallery-grid">
                {galleryImages.map((img, i) => (
                  <a href={img} class="post__gallery-item" data-gallery target="_blank" rel="noopener noreferrer">
                    <img src={img} alt={`${post.data.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
                  </a>
                ))}
              </div>
            </section>
          )}
        </>
      )}

      <ShareButtons />

      {/* Footer: back button */}
      <div class="post__footer">
        <a href={backUrl} class="btn">&larr; {backLabel}</a>
      </div>
    </div>
  </article>
</Base>

<style>
  /* Hero */
  .post__hero-wrap {
    position: relative;
    width: 100%;
    max-height: 420px;
    overflow: hidden;
  }
  .post__hero {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }
  .post__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(18,20,22,0.4) 0%, rgba(18,20,22,0.3) 50%, var(--color-base) 100%);
  }
  .post__hero-wrap--poster {
    max-height: none;
    display: flex;
    justify-content: center;
    padding: 32px 16px;
    background: radial-gradient(ellipse at center, rgba(40,20,20,0.5) 0%, var(--color-base) 70%);
  }
  .post__hero-poster {
    max-width: 400px;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  }

  /* Layout */
  .post { padding-bottom: 48px; }

  /* Back link */
  .post__back {
    display: inline-block;
    margin-top: 24px;
    margin-bottom: 16px;
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
  }
  .post__back:hover { color: var(--color-accent-1); }

  /* Header: title + excerpt */
  .post__header { margin-bottom: 16px; }
  .post__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .post__title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .post__title-row .post__title {
    margin-bottom: 0;
  }
  .post__status {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 2px 8px;
    border-radius: var(--radius);
  }
  .post__status--active {
    color: var(--color-gold);
    background: rgba(201,168,76,0.12);
  }
  .post__status--finished {
    color: var(--color-muted);
    background: rgba(155,155,155,0.1);
  }
  .post__excerpt {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Meta: category + date row, tags row */
  .post__meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 6px;
  }
  .post__tags-row {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 8px;
  }
  .post__category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-gold);
    background: rgba(201,168,76,0.1);
    padding: 2px 8px;
    border-radius: var(--radius);
  }
  .post__date { font-size: 0.8rem; color: var(--color-muted); }
  .post__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-left: auto;
  }
  .post__tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: var(--radius);
    background: var(--color-accent-light);
    color: var(--color-accent-1);
  }
  .post__tag--city {
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  .post__tag--city:hover {
    background: rgba(139,26,43,0.25);
    color: var(--color-accent-2);
  }

  /* Divider */
  .post__divider {
    border: none;
    border-top: 1px solid rgba(139,26,43,0.15);
    margin: 24px 0;
  }

  /* Prose styles for markdown content */
  .prose :global(h1) { font-size: clamp(1.4rem, 4vw, 2rem); margin: 32px 0 16px; }
  .prose :global(h2) { font-size: clamp(1.2rem, 3.5vw, 1.5rem); margin: 28px 0 12px; }
  .prose :global(h3) { font-size: clamp(1rem, 3vw, 1.2rem); margin: 24px 0 8px; }
  .prose :global(p) { line-height: 1.7; margin-bottom: 16px; text-align: justify; }
  .prose :global(ul), .prose :global(ol) { padding-left: 20px; margin-bottom: 16px; }
  .prose :global(li) { margin-bottom: 6px; line-height: 1.6; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-gold); padding-left: 16px;
    color: var(--color-muted); font-style: italic; margin: 16px 0;
  }
  .prose :global(hr) { border: none; border-top: 1px solid rgba(139,26,43,0.15); margin: 24px 0; }
  .prose :global(img) { max-width: 100%; border-radius: var(--radius); margin: 16px 0; }
  .prose :global(a) { color: var(--color-accent-1); }
  .prose :global(a:hover) { color: var(--color-accent-2); }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 16px 0; }
  .prose :global(th), .prose :global(td) {
    padding: 8px 12px; border: 1px solid var(--color-border); text-align: left;
  }
  .prose :global(th) { font-weight: 600; background-color: var(--color-surface); }

  /* Gallery */
  .post__gallery { margin-top: 32px; }
  .post__gallery-title {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }
  .post__gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 8px;
  }
  .post__gallery-item {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .post__gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .post__gallery-item:hover img {
    transform: scale(1.05);
  }

  /* Footer */
  .post__footer { text-align: center; margin: 40px 0; }

  @media (max-width: 544px) {
    .post__hero { height: 260px; }
    .post__hero-wrap { max-height: 260px; }
    .post__tags { margin-left: 0; width: 100%; }
    .post__gallery-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  }
</style>
