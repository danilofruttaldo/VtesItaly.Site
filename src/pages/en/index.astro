---
import Base from '../../layouts/Base.astro';
import Calendar from '../../components/Calendar.astro';
import PostCard from '../../components/PostCard.astro';
import { cities } from '../../data/cities';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';
import { filterByLocale, useTranslations } from '../../utils/i18n';
import { getEnPostUrl } from '../../utils/url';

const page = mainPages.find(p => p.slug.it === '')!;
const t = useTranslations('en');
const latestPosts = filterByLocale(await getCollection('blog'), 'en')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);
---

<Base title={page.title.en} description={page.description.en}>
  <img src={page.headerImage} alt="VTES Italy" class="hero-banner" decoding="async" fetchpriority="high" />

  <section class="hero-text">
    <div class="container container--narrow">
      <h1>{t.home.hero_title}</h1>
      <p class="hero-text__subtitle">{t.home.hero_subtitle}</p>
    </div>
  </section>

  <hr class="divider" />

  <section class="section" id="eventi">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.events_title}</h2>
      <p class="section-subtitle">{t.home.events_subtitle}</p>
      <Calendar />
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.latest_title}</h2>
      <p class="section-subtitle">{t.home.latest_subtitle}</p>
      <div class="post-list">
        {latestPosts.map(post => {
          const usesPoster = (post.data.category === 'grand-prix' || post.data.category === 'nazionale') && !!post.data.poster;
          const cardImage = usesPoster ? post.data.poster : (post.data.featuredImage || post.data.poster);
          return (
          <PostCard
            href={getEnPostUrl(post)}
            title={post.data.title}
            image={cardImage}
            isPoster={usesPoster || (!post.data.featuredImage && !!post.data.poster)}
            date={post.data.date}
            category={post.data.category}
            tags={post.data.tags}
            excerpt={post.data.excerpt}
            locale="en"
          />
          );
        })}
      </div>
      <div class="section-cta">
        <a href="/en/community/" class="btn">{t.home.all_articles} &rarr;</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.domains_title}</h2>
      <p class="section-subtitle">{t.home.domains_subtitle}</p>
      <div class="cities-quicklinks">
        {cities.map(city => (
          <a href={`/en/domains/${city.slug.en}/`}>{city.name.en}</a>
        ))}
      </div>
      <div class="section-cta">
        <a href="/en/domains/" class="btn">{t.home.all_domains} &rarr;</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-banner { width: 100%; display: block; object-fit: cover; max-height: 340px; }
  .hero-text { padding: 48px 0 40px; text-align: center; }
  .hero-text h1 { font-size: clamp(1.5rem, 5vw, 2.25rem); margin-bottom: 16px; }
  .hero-text__subtitle {
    color: var(--color-muted); font-size: clamp(0.9rem, 3vw, 1.05rem);
    line-height: 1.6; margin-bottom: 24px;
  }

  .cities-quicklinks {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .cities-quicklinks a {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-accent-1);
    text-decoration: none;
    transition: all 0.2s ease;
    text-align: center;
  }
  .cities-quicklinks a:hover {
    background-color: var(--color-accent-1);
    color: #fff;
    border-color: var(--color-accent-1);
  }

  @media (max-width: 599px) {
    .hero-text { padding-inline: 0; }
  }
</style>
