---
import { getLocaleFromUrl, useTranslations } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<div class="vtesitaly-search-overlay" id="search-overlay">
  <button type="button" class="vtesitaly-search-close" aria-label={t.search.close_label}>&times;</button>
  <div class="vtesitaly-search-container">
    <input
      type="search"
      id="pagefind-input"
      class="vtesitaly-search-field"
      placeholder={t.search.placeholder}
      aria-label={t.search.aria_label}
      autocomplete="off"
    />
    <div id="pagefind-results" class="vtesitaly-search-results" data-no-results={t.search.no_results}></div>
  </div>
</div>

<script is:inline>
  (function () {
    var overlay = document.getElementById('search-overlay');
    if (!overlay) return;

    var closeBtn = overlay.querySelector('.vtesitaly-search-close');
    var input = document.getElementById('pagefind-input');
    var resultsContainer = document.getElementById('pagefind-results');
    var pagefind = null;
    var debounceTimer = null;

    async function initPagefind() {
      if (pagefind) return;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.init();
      } catch {
        /* Pagefind not available in dev mode */
      }
    }

    async function doSearch(query) {
      if (!pagefind || !query || query.length < 2) {
        resultsContainer.innerHTML = '';
        return;
      }

      var search = await pagefind.search(query, {
        filters: {},
      });

      var results = await Promise.all(
        search.results.slice(0, 8).map(function (r) {
          return r.data();
        }),
      );

      if (results.length === 0) {
        resultsContainer.textContent = '';
        var noRes = document.createElement('p');
        noRes.className = 'search-no-results';
        noRes.textContent = resultsContainer.getAttribute('data-no-results') || '';
        resultsContainer.appendChild(noRes);
        return;
      }

      resultsContainer.textContent = '';
      results.forEach(function (r) {
        var a = document.createElement('a');
        a.href = r.url;
        a.className = 'search-result';

        var title = document.createElement('span');
        title.className = 'search-result__title';
        title.textContent = r.meta.title;
        a.appendChild(title);

        var excerpt = document.createElement('span');
        excerpt.className = 'search-result__excerpt';
        excerpt.innerHTML = r.excerpt;
        a.appendChild(excerpt);

        resultsContainer.appendChild(a);
      });
    }

    function openOverlay() {
      overlay.classList.add('open');
      initPagefind();
      if (input) {
        input.value = '';
        resultsContainer.innerHTML = '';
        input.focus();
      }
    }

    function closeOverlay() {
      overlay.classList.remove('open');
    }

    document.addEventListener('open-search', openOverlay);

    if (closeBtn) closeBtn.addEventListener('click', closeOverlay);
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closeOverlay();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeOverlay();
    });

    if (input) {
      input.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        var query = input.value.trim();
        debounceTimer = setTimeout(function () {
          doSearch(query);
        }, 200);
      });
    }
  })();
</script>

<style>
  .vtesitaly-search-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
    background-color: rgba(18, 20, 22, 0.95);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease;
    overflow-y: auto;
  }

  .vtesitaly-search-overlay:global(.open) {
    opacity: 1;
    visibility: visible;
  }

  .vtesitaly-search-close {
    position: absolute;
    top: 20px;
    right: 24px;
    font-size: 2rem;
    color: var(--color-muted);
    background: none;
    border: none;
    cursor: pointer;
    line-height: var(--leading-none);
  }

  .vtesitaly-search-close:hover {
    color: var(--color-contrast);
  }

  .vtesitaly-search-container {
    width: 100%;
    max-width: 600px;
    padding-inline: clamp(12px, 4vw, var(--spacing-md));
  }

  .vtesitaly-search-field {
    width: 100%;
    padding: 14px 20px;
    font-size: var(--font-size-md);
    font-family: var(--font-family);
    color: var(--color-contrast);
    background-color: var(--color-surface);
    border: 1px solid var(--color-accent-light);
    border-radius: var(--radius);
    outline: 2px solid transparent;
    outline-offset: 2px;
    transition:
      border-color 0.2s ease,
      outline-color 0.2s ease;
  }

  .vtesitaly-search-field:focus {
    border-color: var(--color-gold);
    outline-color: var(--color-gold);
  }

  .vtesitaly-search-field::placeholder {
    color: var(--color-muted);
  }

  .vtesitaly-search-results {
    margin-top: var(--spacing-md);
  }

  .vtesitaly-search-results :global(.search-result) {
    display: block;
    padding: 14px 16px;
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-contrast);
    transition: background-color 0.15s ease;
  }

  .vtesitaly-search-results :global(.search-result:hover) {
    background-color: rgba(255, 255, 255, 0.06);
  }

  .vtesitaly-search-results :global(.search-result + .search-result) {
    border-top: 1px solid var(--color-border);
  }

  .vtesitaly-search-results :global(.search-result__title) {
    display: block;
    font-weight: 600;
    font-size: var(--font-size-small);
    color: var(--color-accent-1);
    margin-bottom: 4px;
  }

  .vtesitaly-search-results :global(.search-result__excerpt) {
    display: block;
    font-size: var(--font-size-small);
    color: var(--color-muted);
    line-height: var(--leading-normal);
  }

  .vtesitaly-search-results :global(.search-result__excerpt mark) {
    background-color: transparent;
    color: var(--color-gold);
    font-weight: 600;
  }

  .vtesitaly-search-results :global(.search-no-results) {
    text-align: center;
    color: var(--color-muted);
    font-size: var(--font-size-small);
    padding: var(--spacing-md);
  }
</style>
