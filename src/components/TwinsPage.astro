---
import Base from '../layouts/Base.astro';
import PageHero from './PageHero.astro';
import ShareButtons from './ShareButtons.astro';
import { mainPages } from '../data/pages';
import { twins as twinsData } from '../data/twins';
import { useTranslations } from '../utils/i18n';
import type { Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const page = mainPages.find((p) => p.slug.it === 'gemelli')!;
const t = useTranslations(locale);
const twins = twinsData.map((tw) => ({
  card: tw.card,
  person: tw.person[locale],
  image: tw.image,
  description: tw.description[locale],
}));
---

<Base title={page.title[locale]} description={page.description[locale]} ogImage={page.headerImage}>
  <PageHero title={page.title[locale]} image={page.headerImage} />
  <section class="section">
    <div class="container container--narrow">
      <p class="lead">{t.twins.lead}</p>
      <p class="tagline">{t.twins.tagline}</p>

      <hr class="divider" />

      {
        twins.map((twin) => (
          <div class="twin-entry">
            <div class="twin-image">
              <img src={twin.image} alt={twin.person} loading="lazy" decoding="async" />
            </div>
            <div class="twin-info">
              <h3 class="twin-card">{twin.card}</h3>
              <p class="twin-vs">vs</p>
              <h4 class="twin-person">{twin.person}</h4>
              <p class="twin-desc">{twin.description}</p>
            </div>
          </div>
        ))
      }
      <ShareButtons />
    </div>
  </section>
</Base>

<style>
  .section {
    padding: 40px 0 48px;
  }
  .lead {
    font-size: clamp(0.95rem, 3vw, 1.05rem);
    line-height: 1.7;
  }
  .tagline {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 16px;
  }
  .divider {
    border: none;
    border-top: 1px solid var(--color-accent-light);
    margin: 32px 0;
  }
  .twin-entry {
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .twin-entry:last-child {
    border-bottom: none;
  }
  .twin-image {
    text-align: center;
  }
  .twin-image img {
    border-radius: var(--radius);
    width: 100%;
    max-width: 480px;
    margin-inline: auto;
  }
  .twin-info {
    margin-top: 12px;
    text-align: center;
    max-width: 480px;
    margin-inline: auto;
  }
  .twin-card {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-gold);
    margin-bottom: 0;
    display: inline;
  }
  .twin-vs {
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0;
    display: inline;
    margin-inline: 8px;
  }
  .twin-person {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
    display: inline;
  }
  .twin-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-top: 6px;
  }
</style>
