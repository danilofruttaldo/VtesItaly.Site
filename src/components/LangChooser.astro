---
/**
 * Language chooser popup — shown on first visit when no preference is saved.
 * Redirect logic lives in Base.astro <head> for instant redirect without flash.
 */
import { getLocaleFromUrl, getAlternateUrl, useTranslations } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const altUrl = getAlternateUrl(Astro.url, locale === 'it' ? 'en' : 'it');
---

<div class="lang-chooser-overlay" id="lang-chooser" aria-hidden="true">
  <div class="lang-chooser" role="dialog" aria-label={t.nav.choose_language} tabindex="-1">
    <div class="lang-chooser__options">
      <button
        class="lang-chooser__btn"
        type="button"
        data-lang="it"
        data-href={locale === 'it' ? '' : altUrl}
        aria-label="Italiano"
      >
        <svg class="flag-icon" viewBox="0 0 640 480"
          ><path fill="#009246" d="M0 0h213.3v480H0z"></path><path fill="#fff" d="M213.3 0h213.4v480H213.3z"
          ></path><path fill="#ce2b37" d="M426.7 0H640v480H426.7z"></path></svg
        >
        IT
      </button>
      <button
        class="lang-chooser__btn"
        type="button"
        data-lang="en"
        data-href={locale === 'en' ? '' : altUrl}
        aria-label="English"
      >
        <svg class="flag-icon" viewBox="0 0 640 480"
          ><path fill="#012169" d="M0 0h640v480H0z"></path><path
            fill="#FFF"
            d="m75 0 244 181L562 0h78v62L400 241l240 178v61h-80L320 301 81 480H0v-60l239-178L0 64V0h75z"></path><path
            fill="#C8102E"
            d="m424 281 216 159v40L369 281h55zm-184 20 6 35L54 480H0l240-179zM640 0v3L391 191l2-44L590 0h50zM0 0l239 176h-60L0 42V0z"
          ></path><path fill="#FFF" d="M241 0v480h160V0H241zM0 160v160h640V160H0z"></path><path
            fill="#C8102E"
            d="M0 193v96h640v-96H0zM273 0v480h96V0h-96z"></path></svg
        >
        EN
      </button>
    </div>
  </div>
</div>

<style is:global>
  .lang-chooser-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
  }

  .lang-chooser-overlay.is-open {
    display: flex;
  }

  .lang-chooser {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 32px 40px;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    max-width: 360px;
    width: 90vw;
    animation: lang-chooser-in 0.2s ease;
  }

  @keyframes lang-chooser-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .lang-chooser__options {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  .lang-chooser__btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-contrast);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .lang-chooser__btn:hover,
  .lang-chooser__btn:focus-visible {
    background-color: var(--color-accent-light);
    border-color: var(--color-accent-1);
  }

  .lang-chooser__btn:focus-visible {
    outline: 2px solid var(--color-accent-1);
    outline-offset: 2px;
  }

  .lang-chooser__btn .flag-icon {
    width: 22px;
    height: 16px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .lang-chooser {
      animation: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'vtesitaly-lang';
    var saved = null;
    try {
      saved = localStorage.getItem(STORAGE_KEY);
    } catch (_) {
      /* storage unavailable */
    }

    // If preference already saved, do nothing (redirect handled in <head>)
    if (saved) return;

    var overlay = document.getElementById('lang-chooser');
    if (!overlay) return;

    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    // Focus dialog (not a specific button, so nothing looks pre-selected)
    var dialog = overlay.querySelector('.lang-chooser');
    if (dialog) dialog.focus();
    var buttons = overlay.querySelectorAll('.lang-chooser__btn');

    // Focus trap between the two buttons
    overlay.addEventListener('keydown', function (e) {
      if (e.key === 'Tab') {
        e.preventDefault();
        var focused = document.activeElement;
        if (focused === buttons[0]) buttons[1].focus();
        else buttons[0].focus();
      }
    });

    function choose(btn) {
      var lang = btn.dataset.lang;
      try {
        localStorage.setItem(STORAGE_KEY, lang);
      } catch (_) {
        /* storage unavailable */
      }
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (btn.dataset.href) {
        location.replace(btn.dataset.href);
      }
    }

    for (var i = 0; i < buttons.length; i++) {
      buttons[i].addEventListener('click', function () {
        choose(this);
      });
    }
  })();
</script>
