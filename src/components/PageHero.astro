---
interface Props {
  title: string;
  image?: string;
  breadcrumb?: { label: string; href: string };
}

const { title, image, breadcrumb } = Astro.props;
---

<section class="page-hero">
  {image && <img src={image} alt={title} class="page-hero__img" loading="eager" decoding="async" />}
  <div class="page-hero__overlay"></div>
  <div class="page-hero__content">
    {title && <h1>{title}</h1>}
  </div>
</section>

{breadcrumb && (
  <div class="container breadcrumb">
    <a href={breadcrumb.href}>&larr; {breadcrumb.label}</a>
  </div>
)}

<style>
  .page-hero {
    position: relative;
    height: 420px;
    max-height: 420px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface);
  }

  .page-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;

  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(18,20,22,0.4) 0%, rgba(18,20,22,0.3) 50%, var(--color-base) 100%);
  }

  .page-hero__content {
    position: relative;
    text-align: center;
    padding: 40px clamp(16px, 4vw, 60px);
  }

  .page-hero__content h1 {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-contrast);
  }

  .breadcrumb {
    padding-top: 12px;
    font-size: 0.8rem;
  }

  .breadcrumb a {
    color: var(--color-muted);
  }

  @media (max-width: 544px) {
    .page-hero {
      height: 260px;
      max-height: 260px;
    }
  }
</style>
