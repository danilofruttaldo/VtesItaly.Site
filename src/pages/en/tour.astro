---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import TournamentPage from '../../components/TournamentPage.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';

const page = mainPages.find(p => p.slug === 'tour')!;
const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'tour')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title={page.titleEn} description={page.descriptionEn}>
  <PageHero title={page.titleEn} image={page.headerImage} />
  <TournamentPage
    posts={posts}
    leadHtml={`<p class="page-lead">The <strong>VTES Italian Tour</strong> is an exciting <strong>series of tournaments</strong> held throughout the year across <strong>Italy's main Domains</strong>. Each <strong>stop</strong> offers the chance to <strong>earn valuable points</strong> for the <strong>annual ranking</strong>, with the <strong>best players</strong> competing for <strong>the whole country</strong>.</p><p>Get ready for a <strong>thrilling and strategic competition</strong>, where <strong>every game can make the difference</strong> on the <strong>road to the final victory</strong>.</p>`}
    editionsTitle="Tour Editions"
    baseUrl="/en/tour/"
  />
</Base>
