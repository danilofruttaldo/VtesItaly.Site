---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import JsonLd from '../components/JsonLd.astro';
import LangChooser from '../components/LangChooser.astro';
import { getLocaleFromUrl, getAlternateUrl, useTranslations, getOtherLocales } from '../utils/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const {
  title,
  description = t.default_description,
  ogImage = '/images/headers/header-home.webp',
  noindex = false,
} = Astro.props;
const otherLocales = getOtherLocales(locale);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const altUrlForRedirect = getAlternateUrl(Astro.url, otherLocales[0]);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | VTES Italy</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl.href} />
    {
      otherLocales.map((alt) => (
        <link rel="alternate" hreflang={alt} href={new URL(getAlternateUrl(Astro.url, alt), Astro.site).href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={canonicalUrl.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | VTES Italy`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={t.og_locale} />
    <meta property="og:site_name" content="VTES Italy" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | VTES Italy`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#121416" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Font preload (eliminates discovery delay) -->
    <link rel="preload" href="/fonts/manrope-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/logo-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <JsonLd
      data={{
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'VTES Italy',
        url: Astro.site?.href,
        logo: new URL('/images/logo.webp', Astro.site).href,
        description: t.default_description,
        sameAs: [
          'https://www.facebook.com/groups/115874240013',
          'https://www.instagram.com/vtes.italy',
          'https://www.youtube.com/@VtesItaly',
          'https://t.me/+i_YymbZgFS84YzRk',
        ],
      }}
    />
    <slot name="head" />
    <!-- Early lang redirect (before body renders to avoid flash) -->
    <script is:inline define:vars={{ currentLocale: locale, altUrl: altUrlForRedirect }}>
      (function () {
        try {
          var saved = localStorage.getItem('vtesitaly-lang');
          if (saved && (saved === 'it' || saved === 'en') && saved !== currentLocale) {
            location.replace(altUrl);
          }
        } catch {
          /* storage unavailable */
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only">{t.skip_to_content}</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <SearchOverlay />
    <LangChooser />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </body>
</html>
