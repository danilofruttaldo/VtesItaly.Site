{
  "name": "vtesitaly-site",
  "type": "module",
  "version": "0.1.0",
  "description": "Official multilingual website for the Italian VTES community (Astro, deployed via SSH tar-pipe).",
  "license": "MIT",
  "author": "VTES Italy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danilofruttaldo/VtesItaly.Site.git"
  },
  "homepage": "https://vtesitaly.com",
  "private": true,
  "scripts": {
    "dev": "astro dev --port 4322",
    "build": "astro build && node scripts/stamp-sw.mjs && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "node scripts/warm-content.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:coverage": "node scripts/warm-content.mjs",
    "test:coverage": "vitest run --coverage",
    "test:build": "npm run build && vitest run --config vitest.integration.config.ts",
    "clean": "rimraf dist .astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "astro": "^6.2.2",
    "sharp": "^0.34.5"
  },
  "//overrides": "h3: pinned to fix npm audit vuln in unstorage transitive (commit a6006ca). yaml: pinned ^2.8.3 to avoid yaml-language-server DoS (GHSA-48c2-rrv3-qjmp) pulled by @astrojs/check.",
  "overrides": {
    "h3": "^1.15.10",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.5",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
