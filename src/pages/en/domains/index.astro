---
import Base from '../../../layouts/Base.astro';
import PageHero from '../../../components/PageHero.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import CityCard from '../../../components/CityCard.astro';
import { cities } from '../../../data/cities';
import { mainPages } from '../../../data/pages';

const page = mainPages.find(p => p.slug === 'principati')!;
---

<Base title={page.titleEn} description={page.descriptionEn}>
  <PageHero title={page.titleEn} image={page.headerImage} />

  <section class="section">
    <div class="container">
      <p class="section-subtitle">From north to south, the Italian Methuselah network is alive and thriving!</p>
      <p class="section-intro">This page shows the active Domains: the cities where the VTES community gathers, plays, organizes tournaments and nurtures the passion for the game.</p>
      <p class="section-intro">Whether you are an awakened ancient or a curious neonate, here you can find your domain... or invade one!</p>
      <div class="coordinator">
        <img src="/images/principi/Principi-Miro-Albertazzi.webp" alt="Miro Albertazzi" class="coordinator-avatar" decoding="async" />
        <p>National Coordinator<br /><strong>Miro Albertazzi</strong></p>
      </div>
      <div class="principati-grid">
        {cities.map(city => (
          <CityCard
            name={city.nameEn}
            href={`/en/domains/${city.slugEn}/`}
            princeName={city.prince.name}
            princeAlias={city.prince.alias}
            princeImage={city.prince.image}
          />
        ))}
      </div>
      <ShareButtons label="Share" />
    </div>
  </section>
</Base>

<style>
  .section { padding: 40px clamp(16px, 4vw, 60px) 48px; }
  .section-subtitle { text-align: center; color: var(--color-muted); font-size: clamp(0.875rem, 3vw, 1rem); line-height: 1.6; margin-bottom: 8px; }
  .section-intro { text-align: center; color: var(--color-muted); font-size: 0.9rem; line-height: 1.6; max-width: 640px; margin-inline: auto; margin-bottom: 8px; }
  .coordinator { text-align: center; color: var(--color-gold); font-size: 0.9rem; margin-bottom: 32px; }
  .coordinator-avatar { display: block; width: 120px; height: 120px; border-radius: 16px; object-fit: cover; margin-inline: auto; margin-bottom: 8px; }
  .principati-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  @media (max-width: 599px) { .section { padding-inline: 8px; } }
  @media (min-width: 600px) { .principati-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; } }
  @media (min-width: 1024px) { .principati-grid { grid-template-columns: repeat(4, 1fr); } }
</style>
