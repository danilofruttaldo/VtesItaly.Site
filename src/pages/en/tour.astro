---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import TourEdition from '../../components/TourEdition.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';
import { filterByLocale, useTranslations, formatLocalDate } from '../../utils/i18n';
import { computeTourStatus } from '../../utils/status';
import '../../styles/edition-page.css';

const t = useTranslations('en');

const page = mainPages.find((p) => p.slug.it === 'tour')!;
const posts = filterByLocale(await getCollection('blog'), 'en')
  .filter((p) => p.data.category === page.category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const current = posts[0];
const pastEditions = posts.filter((p) => p !== current);

const tourStatus = computeTourStatus(current?.data.stages || []);
const tourStagesJson = JSON.stringify(
  (current?.data.stages || []).map((s) => ({
    date: s.date instanceof Date ? s.date.toISOString().slice(0, 10) : s.date,
    cancelled: s.status === 'cancelled',
  })),
);
---

<Base title={page.title.en} description={page.description.en}>
  <PageHero title={page.title.en} image={page.headerImage} />

  <section class="page-section">
    <div class="container container--narrow">
      <div class="intro-lead">
        <Fragment set:html={page.leadHtml?.en ?? ''} />
      </div>
    </div>
  </section>

  {
    current && (
      <section class="page-section">
        <div class="container">
          <div class="edition-header">
            <h2 class="edition-title">{current.data.title}</h2>
            {tourStatus && (
              <span
                class="edition-label-tag"
                data-tour-stages={tourStagesJson}
                data-label-live={t.status.live}
                data-label-upcoming={t.status.upcoming}
                data-label-past={t.status.past}
              >
                {tourStatus === 'past' ? t.status.past : tourStatus === 'live' ? t.status.live : t.status.upcoming}
              </span>
            )}
          </div>
          <TourEdition post={current} locale="en" />
        </div>
      </section>
    )
  }

  {
    pastEditions.length > 0 && (
      <section class="page-section">
        <div class="container container--narrow">
          <h2 class="page-section-title">{t.tour.archive}</h2>
          <div class="editions-list">
            {pastEditions.map((post) => (
              <a href={`/en/tour/${post.id.replace(/-en$/, '')}/`} class="edition-card">
                <span class="edition-year">
                  {post.id.match(/\d{4}/)?.[0] ?? new Date(post.data.date).getFullYear()}
                </span>
                {post.data.stages &&
                  post.data.stages.length > 0 &&
                  (() => {
                    const stg = post.data.stages!;
                    const citiesCount = new Set(stg.flatMap((s) => s.cities)).size;
                    const first = formatLocalDate(stg[0].date, 'en', { day: 'numeric', month: 'short' });
                    const last = formatLocalDate(stg[stg.length - 1].date, 'en', { day: 'numeric', month: 'short' });
                    return (
                      <span class="edition-info">
                        {stg.length} {t.tour.stages_unit} &middot; {citiesCount} {t.tour.cities_unit} &middot; {first} —{' '}
                        {last}
                      </span>
                    );
                  })()}
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
  <section class="page-section"><div class="container container--narrow"><ShareButtons /></div></section>
</Base>
