---
/**
 * Redirect from old vtesitaly.com/gp/gp-2026 URLs.
 * Uses fragment to distinguish language:
 *   #h.wdc6u5g2ifxu → EN
 *   anything else   → IT (default)
 */
---
<html>
<head>
  <meta charset="utf-8" />
  <script is:inline>
    if (window.location.hash === '#h.wdc6u5g2ifxu') {
      window.location.replace('/en/grand-prix/grand-prix-2026/');
    } else {
      window.location.replace('/grand-prix/grand-prix-2026/');
    }
  </script>
  <meta http-equiv="refresh" content="0;url=/grand-prix/grand-prix-2026/" />
</head>
</html>
