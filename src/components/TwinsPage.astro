---
import Base from '../layouts/Base.astro';
import PageHero from './PageHero.astro';
import ShareButtons from './ShareButtons.astro';
import { mainPages } from '../data/pages';
import { twins as twinsData } from '../data/twins';
import { useTranslations } from '../utils/i18n';
import type { Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const page = mainPages.find((p) => p.slug.it === 'gemelli')!;
const t = useTranslations(locale);
const twins = twinsData.map((tw) => ({
  card: tw.card,
  person: tw.person[locale],
  image: tw.image,
  description: tw.description[locale],
}));
---

<Base title={page.title[locale]} description={page.description[locale]} ogImage={page.headerImage}>
  <PageHero title={page.title[locale]} image={page.headerImage} />
  <section class="section">
    <div class="container container--narrow">
      <p class="lead">{t.twins.lead}</p>
      <p class="tagline">{t.twins.tagline}</p>
    </div>

    <hr class="divider" />

    <div class="container">
      <div class="twins-grid">
        {
          twins.map((twin) => (
            <div class="twin-entry">
              <div class="twin-image" role="button" tabindex="0">
                <img src={twin.image} alt={twin.person} loading="lazy" decoding="async" />
              </div>
              <div class="twin-info">
                <h3 class="twin-card">{twin.card}</h3>
                <p class="twin-vs">vs</p>
                <h4 class="twin-person">{twin.person}</h4>
                <p class="twin-desc">{twin.description}</p>
              </div>
            </div>
          ))
        }
      </div>
      <ShareButtons />
    </div>
  </section>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>
</Base>

<style>
  .section {
    padding: 40px 0 48px;
  }
  .lead {
    font-size: clamp(0.95rem, 3vw, 1.05rem);
    line-height: var(--leading-relaxed);
  }
  .tagline {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 16px;
  }
  .divider {
    border: none;
    border-top: 1px solid var(--color-accent-light);
    margin: 32px auto;
    max-width: var(--content-width);
  }
  .twins-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 24px 32px;
  }
  .twin-entry {
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .twin-image {
    text-align: center;
    cursor: zoom-in;
  }
  .twin-image img {
    border-radius: var(--radius);
    width: 100%;
    max-width: 480px;
    aspect-ratio: 700 / 490;
    object-fit: cover;
    margin-inline: auto;
    transition: opacity 0.2s ease;
  }
  .twin-image:hover img {
    opacity: 0.85;
  }
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      visibility 0.25s ease;
  }
  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }
  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: var(--radius);
    object-fit: contain;
  }
  .twin-info {
    margin-top: 12px;
    text-align: center;
  }
  @media (max-width: 768px) {
    .twins-grid {
      grid-template-columns: 1fr;
    }
    .twin-image {
      cursor: default;
    }
    .twin-image:hover img {
      opacity: 1;
    }
  }
  .twin-card {
    font-size: var(--font-size-md);
    font-weight: 700;
    color: var(--color-gold);
    margin-bottom: 0;
    display: inline;
  }
  .twin-vs {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: 0;
    display: inline;
    margin-inline: 8px;
  }
  .twin-person {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
    display: inline;
  }
  .twin-desc {
    font-size: var(--font-size-small);
    color: var(--color-muted);
    line-height: var(--leading-normal);
    margin-top: 6px;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    if (!lightbox || !lightboxImg) return;

    document.querySelectorAll('.twin-image').forEach((el) => {
      const img = el.querySelector('img');
      if (!img) return;
      function isMobile() {
        return window.innerWidth <= 768;
      }
      function open() {
        if (isMobile()) return;
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.classList.add('is-open');
        lightbox.setAttribute('aria-hidden', 'false');
      }
      el.addEventListener('click', open);
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          open();
        }
      });
    });

    lightbox.addEventListener('click', () => {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        lightbox.classList.remove('is-open');
        lightbox.setAttribute('aria-hidden', 'true');
      }
    });
  });
</script>
