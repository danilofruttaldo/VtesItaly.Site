---
import '../styles/prose.css';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../utils/i18n';
import { useTranslations, formatLocalDate } from '../utils/i18n';
import { resolvePlatformLabel } from '../utils/status';
import { anonymizeName } from '../utils/anonymize';

interface Props {
  post: CollectionEntry<'blog'>;
  locale?: Locale;
}

const { post, locale = 'it' } = Astro.props;
const t = useTranslations(locale);
const stagesLabel = post.data.stagesLabel || t.tour.stages_label;
const stageItemLabel = post.data.stageItemLabel || t.tour.stage_item;
const { Content } = await render(post);
const stages = post.data.stages || [];

const today = new Date();
today.setHours(0, 0, 0, 0);
const computedStages = stages.map((s) => {
  if (s.status === 'cancelled') return s;
  const stageDate = new Date(s.date);
  stageDate.setHours(0, 0, 0, 0);
  const status = stageDate.getTime() === today.getTime() ? 'upcoming' : stageDate < today ? 'completed' : 'future';
  return { ...s, status };
});
// Mark first future as upcoming
const firstFuture = computedStages.findIndex((s) => s.status === 'future');
if (firstFuture !== -1) computedStages[firstFuture].status = 'upcoming';

const statusLabels: Record<string, string> = {
  completed: t.tour.status_completed,
  upcoming: t.tour.status_upcoming,
  future: t.tour.status_future,
  cancelled: t.tour.status_cancelled,
};

function formatDate(date: Date): string {
  if (date.getDate() === 1) {
    return formatLocalDate(date, locale, { month: 'long', year: 'numeric' });
  }
  return formatLocalDate(date, locale);
}

// Load tour standings
interface TourStanding {
  rank: number;
  name: string;
  city: string;
  total: number;
  [key: string]: number | string | null;
}
let tourStandings: TourStanding[] = [];
let stageCount = 0;
if (post.data.standingsUrl) {
  const allData = import.meta.glob('/src/data/standings/**/*.json', { eager: true }) as Record<
    string,
    { default: unknown }
  >;
  const key = Object.keys(allData).find((k) => k.includes(post.data.standingsUrl!.replace(/^.*\//, '')));
  if (key && Array.isArray(allData[key].default)) {
    tourStandings = allData[key].default as TourStanding[];
    stageCount = stages.length;
  }
}
const hasGw = tourStandings.some((s) => (s as any).gw != null);
const tourFinished = computedStages.length > 0 && computedStages.every((s) => s.status === 'completed');

function formatStage(val: unknown, isAway: boolean): string {
  if (val == null) return '-';
  const suffix = isAway ? '*' : '';
  if (typeof val === 'object' && val !== null && 'gw' in val && 'vp' in val) {
    return `${(val as any).gw}GW ${(val as any).vp}${suffix}`;
  }
  return `${val}${suffix}`;
}
---

<div class="tour-edition">
  {
    tourStandings.length > 0 && (
      <nav class="te-quicknav">
        <a href="#classifica" class="te-quicknav-link">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9" />
          </svg>
          {t.post.jump_standings}
        </a>
      </nav>
    )
  }

  <div class="te-content prose">
    <Content />
  </div>

  {
    post.data.rulesUrl && (
      <div class="te-rules">
        <a href={post.data.rulesUrl} target="_blank" rel="noopener noreferrer" class="te-rules-link">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
            <>
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </>
          </svg>
          {t.tour.rules} (PDF)
        </a>
      </div>
    )
  }

  {
    computedStages.length > 0 && (
      <div class="te-stages">
        <h3 class="te-stages-title">{stagesLabel}</h3>
        <div class="te-stages-list">
          {computedStages.map((stage, i) => (
            <div
              class:list={[
                'te-card',
                {
                  'te-card--upcoming': stage.status === 'upcoming',
                  'te-card--completed': stage.status === 'completed',
                  'te-card--cancelled': stage.status === 'cancelled',
                  'te-card--clickable': !!stage.archonUrl,
                },
              ]}
              data-href={stage.archonUrl || undefined}
              data-stage-date={stage.date instanceof Date ? stage.date.toISOString().slice(0, 10) : stage.date}
              data-stage-cancelled={stage.status === 'cancelled' ? 'true' : undefined}
            >
              {stage.image && (
                <div class="te-card-image">
                  <img src={stage.image} alt={stage.name} loading="lazy" decoding="async" />
                </div>
              )}
              <div class="te-card-body">
                <div class="te-card-top">
                  <div class="te-card-heading">
                    <span class="te-number">
                      {stageItemLabel} {i + 1}
                    </span>
                    <h3 class="te-name">{stage.name}</h3>
                  </div>
                  <span
                    class:list={['te-badge', `te-badge--${stage.status}`]}
                    data-label-completed={statusLabels.completed}
                    data-label-upcoming={statusLabels.upcoming}
                    data-label-future={statusLabels.future}
                    data-label-cancelled={statusLabels.cancelled}
                  >
                    {statusLabels[stage.status]}
                  </span>
                </div>
                {stage.description && <p class="te-desc">{stage.description}</p>}
                <div class="te-card-bottom">
                  <div class="te-meta">
                    <div class="te-date">
                      <svg
                        viewBox="0 0 24 24"
                        width="14"
                        height="14"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <path d="M16 2v4M8 2v4M3 10h18" />
                      </svg>
                      <time>{formatDate(stage.date)}</time>
                    </div>
                    {stage.time && (
                      <div class="te-time">
                        <svg
                          viewBox="0 0 24 24"
                          width="14"
                          height="14"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <circle cx="12" cy="12" r="10" />
                          <polyline points="12 6 12 12 16 14" />
                        </svg>
                        {stage.time}
                      </div>
                    )}
                    {(stage.venue || stage.location) && (
                      <div class="te-venue-block">
                        <div class="te-venue-name">
                          <svg
                            viewBox="0 0 24 24"
                            width="14"
                            height="14"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                            <circle cx="12" cy="10" r="3" />
                          </svg>
                          {stage.venue || stage.location}
                        </div>
                        {stage.venue && stage.location && <div class="te-venue-address">{stage.location}</div>}
                      </div>
                    )}
                  </div>
                  {stage.archonUrl ? (
                    <a
                      href={stage.archonUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class:list={['te-cta', `te-cta--${stage.status}`]}
                    >
                      {resolvePlatformLabel(stage.archonUrl)} &rarr;
                    </a>
                  ) : (
                    <span class="te-cta te-cta--soon">{t.tour.coming_soon}</span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )
  }

  {
    tourStandings.length > 0 && (
      <div id="classifica" class="te-standings">
        <h3 class="te-standings-title">{t.tour.standings}</h3>
        <div class="te-standings-wrap">
          <table class="te-standings-table">
            <caption class="sr-only">{t.tour.standings}</caption>
            <thead>
              <tr>
                <th class="tc">#</th>
                <th>{t.tour.standings_player}</th>
                <th>{t.tour.standings_city}</th>
                {Array.from({ length: stageCount }, (_, i) => (
                  <th class="tc">{`${stageItemLabel[0]}${i + 1}`}</th>
                ))}
                <th class="tc">TOT</th>
              </tr>
            </thead>
            <tbody>
              {tourStandings.map((s) => (
                <tr
                  class:list={[
                    tourFinished && s.rank <= 1 && 'te-standings-winner',
                    tourFinished && s.rank >= 2 && s.rank <= 3 && 'te-standings-top',
                  ]}
                >
                  <td class="tc">{s.rank}</td>
                  <td>{anonymizeName(s.name)}</td>
                  <td class="te-standings-city">{s.city}</td>
                  {Array.from({ length: stageCount }, (_, i) => (
                    <td class:list={['tc', s[`s${i + 1}`] == null && 'te-standings-empty']}>
                      {formatStage(s[`s${i + 1}`], (s as any).away?.includes(i + 1))}
                    </td>
                  ))}
                  <td class="tc te-standings-total">{hasGw ? `${(s as any).gw}GW ${s.total}` : s.total}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {tourStandings.some((s) => (s as any).away?.length > 0) && (
          <p class="te-standings-note">{t.tour.standings_away_note}</p>
        )}
      </div>
    )
  }
</div>

<script>
  document.querySelectorAll('.te-card--clickable').forEach((card) => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) return;
      const href = (card as HTMLElement).dataset.href;
      if (href) window.open(href, '_blank', 'noopener,noreferrer');
    });
  });

  // Recompute stage statuses client-side
  (function () {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const cards = document.querySelectorAll<HTMLElement>('.te-card[data-stage-date]');
    const statuses: string[] = [];

    // First pass: compute raw status per card
    cards.forEach((card) => {
      if (card.dataset.stageCancelled === 'true') {
        statuses.push('cancelled');
        return;
      }
      const d = new Date(card.dataset.stageDate + 'T00:00:00');
      d.setHours(0, 0, 0, 0);
      statuses.push(d < today ? 'completed' : 'future');
    });

    // Mark first future as upcoming
    const firstFuture = statuses.indexOf('future');
    if (firstFuture !== -1) statuses[firstFuture] = 'upcoming';

    // Second pass: apply
    cards.forEach((card, i) => {
      const status = statuses[i];
      if (status === 'cancelled') return; // keep build-time state
      card.classList.remove('te-card--upcoming', 'te-card--completed');
      if (status === 'upcoming') card.classList.add('te-card--upcoming');
      else if (status === 'completed') card.classList.add('te-card--completed');

      const badge = card.querySelector<HTMLElement>('.te-badge');
      if (badge) {
        badge.className = 'te-badge te-badge--' + status;
        badge.textContent = badge.dataset['label' + status.charAt(0).toUpperCase() + status.slice(1)] || status;
      }
    });
  })();
</script>

<style>
  /* Quick nav */
  .te-quicknav {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .te-quicknav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    padding: 6px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all 0.2s ease;
  }
  .te-quicknav-link:hover {
    color: var(--color-gold);
    border-color: rgba(201, 168, 76, 0.3);
    background: rgba(201, 168, 76, 0.08);
  }
  .te-quicknav-link svg {
    flex-shrink: 0;
  }

  /* Content */
  .te-content {
    margin-bottom: 32px;
  }

  /* Rules */
  .te-rules {
    margin-bottom: 28px;
  }
  .te-rules-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    padding: 8px 18px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: var(--radius);
    background: rgba(201, 168, 76, 0.08);
    transition: all 0.2s ease;
  }
  .te-rules-link:hover {
    background: rgba(201, 168, 76, 0.18);
    border-color: rgba(201, 168, 76, 0.5);
  }
  .te-rules-link svg {
    flex-shrink: 0;
  }

  /* Stages */
  .te-stages {
    border-top: 1px solid var(--color-border);
    padding-top: 28px;
  }
  .te-stages-title {
    font-size: var(--font-size-md);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-muted);
    margin-bottom: 20px;
    text-align: center;
  }
  .te-stages-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Card */
  .te-card {
    display: flex;
    flex-direction: row;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: var(--color-surface);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .te-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    border-color: rgba(255, 255, 255, 0.12);
  }
  .te-card--clickable {
    cursor: pointer;
  }
  .te-card--upcoming {
    border-color: rgba(201, 168, 76, 0.4);
  }
  .te-card--upcoming:hover {
    border-color: var(--color-gold);
    box-shadow: 0 8px 24px rgba(201, 168, 76, 0.15);
  }
  .te-card--completed {
    opacity: 0.7;
  }
  .te-card--completed:hover {
    opacity: 1;
  }
  .te-card--cancelled {
    opacity: 0.35;
  }

  /* Image */
  .te-card-image {
    width: 220px;
    min-height: 220px;
    flex-shrink: 0;
    overflow: hidden;
    background: #0a0a0a;
  }
  .te-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .te-card:hover .te-card-image img {
    transform: scale(1.04);
  }

  /* Body */
  .te-card-body {
    padding: 20px 24px;
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .te-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 4px;
  }
  .te-card-heading {
    display: flex;
    flex-direction: column;
  }
  .te-number {
    font-size: var(--font-size-3xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-muted);
    margin-bottom: 2px;
  }
  .te-name {
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    line-height: var(--leading-tight);
    margin: 0;
  }
  .te-card--upcoming .te-name {
    color: var(--color-gold);
  }
  .te-card--cancelled .te-name {
    text-decoration: line-through;
  }

  .te-badge {
    display: inline-block;
    margin-left: auto;
    font-size: var(--font-size-3xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    padding: 2px 8px;
    border-radius: var(--radius);
  }
  .te-badge--completed {
    color: var(--color-muted);
    background: rgba(155, 155, 155, 0.08);
  }
  .te-badge--upcoming {
    color: var(--color-gold);
    background: rgba(201, 168, 76, 0.15);
  }
  .te-badge--future {
    color: var(--color-muted);
    background: rgba(155, 155, 155, 0.08);
  }
  .te-badge--cancelled {
    color: var(--color-accent-1);
    background: rgba(139, 26, 43, 0.12);
  }

  .te-desc {
    font-size: var(--font-size-sm);
    line-height: var(--leading-normal);
    color: var(--color-muted);
    margin: 0;
    flex: 1;
  }

  /* Bottom */
  .te-card-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-top: 12px;
  }
  .te-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .te-date {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-muted);
  }
  .te-date svg {
    flex-shrink: 0;
    opacity: 0.5;
  }
  .te-time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-muted);
  }
  .te-time svg {
    flex-shrink: 0;
    opacity: 0.5;
  }
  .te-venue-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .te-venue-name {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-muted);
  }
  .te-venue-name svg {
    flex-shrink: 0;
    opacity: 0.5;
  }
  .te-venue-address {
    font-size: var(--font-size-2xs);
    color: var(--color-muted);
    opacity: 0.6;
    padding-left: 20px;
  }
  /* CTA */
  .te-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-end;
    font-size: var(--font-size-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    text-decoration: none;
    padding: 7px 18px;
    border-radius: var(--radius);
    transition: all 0.2s ease;
  }
  .te-cta--upcoming,
  .te-cta--future {
    color: var(--color-gold);
    background: rgba(201, 168, 76, 0.12);
    border: 1px solid rgba(201, 168, 76, 0.25);
  }
  .te-cta--upcoming:hover,
  .te-cta--future:hover {
    background: rgba(201, 168, 76, 0.22);
    border-color: rgba(201, 168, 76, 0.4);
  }
  .te-cta--completed {
    color: var(--color-success);
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.18);
  }
  .te-cta--completed:hover {
    background: rgba(74, 222, 128, 0.18);
    border-color: rgba(74, 222, 128, 0.3);
  }
  .te-cta--soon {
    color: var(--color-muted);
    background: rgba(155, 155, 155, 0.06);
    border: 1px solid rgba(155, 155, 155, 0.12);
    cursor: default;
    opacity: 0.6;
  }

  /* Standings */
  .te-standings {
    margin-top: 36px;
    border-top: 1px solid var(--color-border);
    padding-top: 28px;
    scroll-margin-top: 80px;
  }
  .te-standings-title {
    font-size: var(--font-size-md);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    text-align: center;
    color: var(--color-muted);
    margin-bottom: 16px;
  }
  .te-standings-wrap {
    overflow: auto;
    max-height: 600px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    scrollbar-width: none;
  }
  .te-standings-wrap::-webkit-scrollbar {
    display: none;
  }
  .te-standings-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-2xs);
  }
  .te-standings-table th {
    font-size: var(--font-size-3xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-gold);
    padding: 6px 4px;
    border-bottom: 2px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-base);
    white-space: nowrap;
  }
  .te-standings-table td {
    padding: 4px 4px;
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }
  .te-standings-table tr:hover td {
    background: rgba(201, 168, 76, 0.05);
  }
  .te-standings-table th,
  .te-standings-table td {
    text-align: center;
  }
  .te-standings-table th:nth-child(2),
  .te-standings-table td:nth-child(2) {
    text-align: left;
  }
  .te-standings-table th:nth-child(3),
  .te-standings-table td:nth-child(3) {
    text-align: left;
  }
  .te-standings-winner td {
    color: var(--color-gold);
    font-weight: 700;
  }
  .te-standings-top td {
    font-weight: 600;
  }
  .te-standings-total {
    font-weight: 700;
  }
  .te-standings-empty {
    opacity: 0.3;
  }
  .te-standings-city {
    font-size: var(--font-size-2xs);
    color: var(--color-muted);
  }
  .te-standings-note {
    font-size: var(--font-size-2xs);
    color: var(--color-muted);
    margin-top: 8px;
    text-align: right;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .te-card {
      flex-direction: column;
    }
    .te-card-image {
      width: 100%;
    }
    .te-card-image img {
      width: 100%;
      height: auto;
      object-fit: contain;
    }
    .te-card-body {
      padding: 12px 14px 14px;
      gap: 4px;
    }
    .te-card-top {
      margin-bottom: 2px;
    }
    .te-name {
      font-size: var(--font-size-lg);
      letter-spacing: var(--tracking-widest);
    }
    .te-card-bottom {
      flex-direction: column;
      align-items: flex-start;
