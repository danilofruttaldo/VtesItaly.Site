---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'tour')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title="Italian Tour" description="Il circuito di tornei VTES in Italia. Partecipa alle tappe e scala la classifica annuale.">
  <PageHero title="Italian Tour" image="/images/headers/header-tour.webp" />
  <section class="section"><div class="container container--narrow">
    <p class="lead">Il <strong>VTES Italian Tour</strong> è un'entusiasmante <strong>serie di tornei</strong> che si svolgono durante tutto l'anno nei <strong>principali Principati italiani</strong>. Ogni <strong>tappa</strong> offre l'opportunità di <strong>guadagnare punti preziosi</strong> per la <strong>classifica annuale</strong>, con i <strong>migliori giocatori</strong> pronti a contendersi <strong>tutto il territorio</strong>.</p>
    <p>Preparati a vivere una <strong>competizione avvincente e strategica</strong>, dove <strong>ogni partita può fare la differenza</strong> nel <strong>cammino verso la vittoria finale</strong>.</p>

    <hr class="divider" />

    <h2 class="section-title">Edizioni del Tour</h2>
    <div class="editions-list">
      {posts.map(post => (
        <a href={`/tour/${post.slug}/`} class="edition-card">
          <span class="edition-year">{new Date(post.data.date).getFullYear()}</span>
          <span class="edition-label">{post.data.title}</span>
        </a>
      ))}
    </div>
  </div></section>
</Base>

<style>
  .section { padding: 40px clamp(20px, 5vw, 80px) 48px; }
  .section-title { font-size: clamp(1.2rem, 3.5vw, 1.5rem); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 0.5px; }
  .lead { font-size: clamp(0.95rem, 3vw, 1.05rem); line-height: 1.7; }
  .divider { border: none; border-top: 1px solid var(--color-accent-light); margin: 32px 0; }
  .editions-list { display: flex; flex-direction: column; gap: 12px; }
  .edition-card {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 20px; border-radius: var(--radius);
    border: 1px solid var(--color-border);
    text-decoration: none; color: var(--color-contrast);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }
  .edition-card:hover { background-color: rgba(255,255,255,0.04); transform: translateX(2px); color: var(--color-contrast); }
  .edition-year { font-size: 1.5rem; font-weight: 700; color: var(--color-gold); min-width: 60px; }
  .edition-label { font-size: 1rem; font-weight: 600; }
</style>
