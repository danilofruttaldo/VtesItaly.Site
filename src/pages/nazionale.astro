---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'nazionale')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title="Nazionale" description="Il Campionato Nazionale italiano di VTES, l'evento annuale più atteso dalla community.">
  <PageHero title="Nazionale" image="/images/headers/header-nazionale.webp" />
  <section class="section"><div class="container container--narrow">
    <p class="lead">Il <strong>Campionato Nazionale italiano di VTES</strong> è l'evento annuale più atteso dalla community: un raduno che unisce <strong>competizione di alto livello</strong> e <strong>spirito conviviale</strong>, un vero rituale per i Cainiti italiani dove <strong>strategia</strong>, <strong>passione</strong> e <strong>prestigio</strong> si intrecciano.</p>
    <p>Il torneo prevede <strong>3 gironi + finale</strong>, con iscrizione e decklist obbligatorie su BCN. Il vincitore viene incoronato <strong>Campione d'Italia</strong>.</p>

    <hr class="divider" />

    <h2 class="section-title">Edizioni del Campionato</h2>
    <div class="editions-list">
      {posts.map(post => (
        <a href={`/nazionale/${post.slug}/`} class="edition-card">
          <span class="edition-year">{new Date(post.data.date).getFullYear()}</span>
          <span class="edition-label">{post.data.title}</span>
        </a>
      ))}
    </div>
  </div></section>
</Base>

<style>
  .section { padding: 40px clamp(20px, 5vw, 80px) 48px; }
  .section-title { font-size: clamp(1.2rem, 3.5vw, 1.5rem); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 0.5px; }
  .lead { font-size: clamp(0.95rem, 3vw, 1.05rem); line-height: 1.7; }
  .divider { border: none; border-top: 1px solid var(--color-accent-light); margin: 32px 0; }
  .editions-list { display: flex; flex-direction: column; gap: 12px; }
  .edition-card {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 20px; border-radius: var(--radius);
    border: 1px solid var(--color-border);
    text-decoration: none; color: var(--color-contrast);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }
  .edition-card:hover { background-color: rgba(255,255,255,0.04); transform: translateX(2px); color: var(--color-contrast); }
  .edition-year { font-size: 1.5rem; font-weight: 700; color: var(--color-gold); min-width: 60px; }
  .edition-label { font-size: 1rem; font-weight: 600; }
</style>
