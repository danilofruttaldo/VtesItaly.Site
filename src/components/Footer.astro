  <div class="container footer-bottom">
    <p>&copy; 2025–{new Date().getFullYear()} VTES Italy</p>
    <p class="legal">Vampire: The Eternal Struggle&trade; {t.footer.legal}</p>
    <p class="legal">{t.footer.disclaimer}</p>
    <p class="legal contact">{t.footer.contact} <a href="mailto:info@vtesitaly.com">info@vtesitaly.com</a></p>
    <p class="legal">{t.footer.credits}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--spacing-xl);
    padding-block: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: var(--font-size-small);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-lg);
  }

  .footer-about {
    max-width: 420px;
  }

  .footer-about h4 {
    font-size: var(--font-size-small);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: var(--spacing-xs);
    color: var(--color-contrast);
  }

  .social-icons {
    display: flex;
    gap: 10px;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: #fff;
    text-decoration: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .social-icon:hover {
    transform: scale(1.1);
    opacity: 0.9;
  }

  .social-icon--facebook { background-color: #1877F2; }
  .social-icon--instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
  .social-icon--youtube { background-color: #FF0000; }
  .social-icon--whatsapp { background-color: #25D366; }
  .social-icon--telegram { background-color: #26A5E4; }
  .social-icon--email { background-color: var(--color-gold); color: #1a1a1a; }

  .footer-bottom {
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .legal {
    font-size: 0.7rem;
    color: var(--color-muted);
    opacity: 0.7;
    margin-top: 4px;
  }

  .contact a {
    color: var(--color-muted);
    font-weight: 600;
    text-decoration: none;
  }
  .contact a:hover {
    color: var(--color-contrast);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .social-icons { justify-content: center; }
  }
</style>
