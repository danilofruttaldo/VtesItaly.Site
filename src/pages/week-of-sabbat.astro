---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { mainPages } from '../data/pages';
import { useTranslations } from '../utils/i18n';

const page = mainPages.find(p => p.slug.it === 'week-of-sabbat')!;
const t = useTranslations('it');
---
<Base title={page.title.it} description={page.description.it}>
  <PageHero title={page.title.it} image={page.headerImage} />
  <section class="section"><div class="container container--narrow">
    <p class="date-badge">{t.wos.date_badge}</p>
    <p class="lead"><Fragment set:html={t.wos.lead} /></p>
    <blockquote class="pullquote">"{t.wos.quote}"</blockquote>

    <hr class="divider" />

    <h2 class="section-title">{t.wos.what_title}</h2>
    <p><Fragment set:html={t.wos.what_text} /></p>

    <h2 class="section-title">{t.wos.how_title}</h2>
    <ul class="rules-list">
      {t.wos.how_items.map(item => (
        <li><Fragment set:html={item} /></li>
      ))}
    </ul>

    <h2 class="section-title">{t.wos.scores_title}</h2>
    <ul class="rules-list">
      {t.wos.scores_items.map(item => (
        <li><Fragment set:html={item} /></li>
      ))}
    </ul>

    <h2 class="section-title">{t.wos.deck_title}</h2>
    <p>{t.wos.deck_text}</p>

    <h2 class="section-title">{t.wos.standings_title}</h2>
    <p>{t.wos.standings_text}</p>

    <div class="standings-frame">
      <iframe src="https://docs.google.com/spreadsheets/d/1haGlL72KGpcU9bqPkPVNP4djl5mEdI7U8OJc0jGiimg/pubhtml?widget=true&headers=false" title={t.wos.standings_title} loading="lazy"></iframe>
    </div>

    <hr class="divider" />

    <h2 class="section-title">{t.wos.download}</h2>
    <div class="downloads">
      <a href="https://drive.google.com/uc?export=download&id=1YMFmpUSYcWwY6foPrW44jTz-MfL087xO" class="btn btn--outline" download>{t.wos.infokit}</a>
      <a href="https://drive.google.com/uc?export=download&id=1u1FgSWPC9LPQzRNPh8Hxx7gzw578IOiw" class="btn btn--outline" download>{t.wos.report_template}</a>
    </div>
    <ShareButtons />
  </div></section>
</Base>

<style>
  .section { padding: 40px clamp(20px, 5vw, 80px) 48px; }
  .section-title { font-size: clamp(1.1rem, 3vw, 1.3rem); text-transform: uppercase; margin-top: 32px; margin-bottom: 12px; letter-spacing: 0.5px; }
  .lead { font-size: clamp(0.95rem, 3vw, 1.05rem); line-height: 1.7; }
  .date-badge {
    display: inline-block;
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
    color: var(--color-gold); background: rgba(201,168,76,0.1);
    padding: 4px 12px; border-radius: var(--radius); margin-bottom: 16px;
  }
  .pullquote {
    font-size: 1.1rem; font-style: italic; color: var(--color-gold);
    border-left: 3px solid var(--color-gold); padding-left: 16px; margin: 24px 0;
  }
  .divider { border: none; border-top: 1px solid var(--color-accent-light); margin: 32px 0; }
  .rules-list { padding-left: 20px; margin-bottom: 16px; }
  .rules-list li { margin-bottom: 8px; line-height: 1.6; }
  .standings-frame {
    margin-top: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .standings-frame iframe {
    width: 100%;
    min-height: 500px;
    border: none;
    background: var(--color-surface);
  }
  .downloads {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
