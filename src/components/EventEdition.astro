---
import '../styles/prose.css';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../utils/i18n';
import { useTranslations, formatLocalDate } from '../utils/i18n';
import { resolvePlatformLabel } from '../utils/status';
import { anonymizeName } from '../utils/anonymize';
import { composeFormat } from '../utils/calendar';

interface Props {
  post: CollectionEntry<'blog'>;
  locale?: Locale;
  showExcerpt?: boolean;
}

const { post, locale = 'it', showExcerpt = false } = Astro.props;
if (post.data.category !== 'grand-prix' && post.data.category !== 'nazionale' && post.data.category !== 'comunita') {
  throw new Error(`EventEdition: unsupported category "${post.data.category}"`);
}
const t = useTranslations(locale);

const { Content } = await render(post);
const links = (post.data.links ?? [])
  .filter((l) => !l.locale || l.locale === locale)
  .map((l) => ({
    ...l,
    label: l.url.includes('bcncrisis') || l.url.includes('archon') ? resolvePlatformLabel(l.url) : l.label,
  }));

// Build gallery (exclude poster)
let galleryImages: string[] = post.data.gallery || [];
if (post.data.galleryFolder && galleryImages.length === 0) {
  const folder = post.data.galleryFolder.replace(/^\//, '').replace(/\/$/, '');
  const allImages = import.meta.glob('/public/{gp,nc,tour,ev}/**/*.{webp,jpg,jpeg,png}');
  galleryImages = Object.keys(allImages)
    .filter((p) => p.includes(`/${folder}/`))
    .map((p) => p.replace('/public', ''))
    .sort();
}
if (post.data.poster) {
  galleryImages = galleryImages.filter((img) => img !== post.data.poster);
}

// Load standings if available
interface Standing {
  rank: number;
  name: string;
  gw: number;
  vp: number;
  fvp: number | null;
  tp: number;
}
let standings: Standing[] = [];
if (post.data.standingsUrl) {
  const allData = import.meta.glob('/src/data/standings/**/*.json', { eager: true }) as Record<
    string,
    { default: unknown }
  >;
  const key = Object.keys(allData).find((k) => k.includes(post.data.standingsUrl!.replace(/^.*\//, '')));
  if (key && Array.isArray(allData[key].default)) standings = allData[key].default as Standing[];
}
const hasFvp = standings.some((s) => s.fvp != null);
const postEvents = post.data.events;
---

{/* Poster / locandina */}
{
  post.data.poster && (
    <figure class="gp-poster">
      <img src={post.data.poster} alt={post.data.title} loading="eager" decoding="async" />
      {post.data.posterCaption && <figcaption class="gp-poster-caption">{post.data.posterCaption}</figcaption>}
    </figure>
  )
}

{/* Descrizione breve */}
{showExcerpt && post.data.excerpt && <p class="gp-excerpt">{post.data.excerpt}</p>}

{/* Quick nav */}
{
  standings.length > 0 && (
    <nav class="gp-quicknav">
      <a href="#classifica" class="gp-quicknav-link">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9" />
        </svg>
        {t.post.jump_standings}
      </a>
    </nav>
  )
}

{/* Info di servizio */}
<div class="gp-info">
  {
    post.data.venue && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.venue_label}</span>
        <span class="gp-value">
          <>
            <strong>
              {post.data.venue.siteUrl ? (
                <a href={post.data.venue.siteUrl} target="_blank" rel="noopener noreferrer">
                  {post.data.venue.name}
                </a>
              ) : (
                post.data.venue.name
              )}
            </strong>
            <br />
          </>
          {post.data.venue.mapUrl ? (
            <a href={post.data.venue.mapUrl} target="_blank" rel="noopener noreferrer">
              {post.data.venue.address}
            </a>
          ) : (
            post.data.venue.address
          )}
        </span>
      </div>
    )
  }
  {
    post.data.events.length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.program_label}</span>
        <div class="gp-value">
          {post.data.events.map((ev) => (
            <div class="gp-event">
              <strong>{ev.name}</strong>
              <br />
              {formatLocalDate(new Date(ev.date), locale, { weekday: 'long', day: 'numeric', month: 'long' })} —{' '}
              {t.gp.time_prefix} {ev.time}
              <br />
              <span class="gp-muted">{composeFormat(ev.format, ev.proxies, ev.rounds, locale)}</span>
            </div>
          ))}
        </div>
      </div>
    )
  }
  {
    post.data.schedule.length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.schedule_label}</span>
        <div class="gp-value">
          {post.data.schedule.map((s) => (
            <div class="gp-schedule-item">
              <span class="gp-muted">{s.time}</span> — {s.label}
            </div>
          ))}
        </div>
      </div>
    )
  }
  {
    post.data.pricing.length > 0 && post.data.pricing.some((p) => p.regular || p.early) && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.pricing_label}</span>
        <div class="gp-value">
          <table class="gp-table">
            {post.data.earlyDeadline && (
              <thead>
                <tr>
                  <th />
                  <th>
                    {t.gp.early_col} {post.data.earlyDeadline}
                  </th>
                  <th>
                    {t.gp.regular_col} {post.data.earlyDeadline}
                  </th>
                </tr>
              </thead>
            )}
            <tbody>
              {post.data.pricing.map((p) => (
                <tr>
                  <td>{p.label}</td>
                  {p.early && <td>{p.early}</td>}
                  <td>{p.regular}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )
  }
  {
    post.data.payment && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.payment_label}</span>
        <span class="gp-value">{post.data.payment}</span>
      </div>
    )
  }
  {
    post.data.hotel.length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.hotel_label}</span>
        <div class="gp-value">
          {post.data.hotel.map((h) => (
            <div>
              {h.room}: <strong>{h.price}</strong>
            </div>
          ))}
          {post.data.hotelNote && <div class="gp-muted gp-hotel-note">{post.data.hotelNote}</div>}
        </div>
      </div>
    )
  }
  {
    post.data.prizes && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.prizes_label}</span>
        <div class="gp-value">
          {Array.isArray(post.data.prizes) ? (
            <ul class="gp-prizes-list">
              {post.data.prizes.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          ) : (
            post.data.prizes
          )}
        </div>
      </div>
    )
  }
  {
    (post.data.registration || post.data.events.some((ev) => ev.archonUrl)) && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.registration_label}</span>
        <div class="gp-value">
          {post.data.registration}
          {post.data.events.some((ev) => ev.archonUrl) && (
            <div class="gp-archon-links">
              {post.data.events
                .filter((ev) => ev.archonUrl)
                .map((ev) => {
                  const platform = resolvePlatformLabel(ev.archonUrl!);
                  const hasMultiple = postEvents.filter((e) => e.archonUrl).length > 1;
                  return (
                    <a href={ev.archonUrl} target="_blank" rel="noopener noreferrer" class="gp-link-btn">
                      <svg
                        viewBox="0 0 24 24"
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                      {hasMultiple ? `${ev.name} — ${platform}` : platform}
                    </a>
                  );
                })}
            </div>
          )}
        </div>
      </div>
    )
  }
  {
    post.data.contact && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.contact_label}</span>
        <span class="gp-value">
          {post.data.contact?.includes('@') ? (
            <a href={`mailto:${post.data.contact}`}>{post.data.contact}</a>
          ) : (
            post.data.contact
          )}
        </span>
      </div>
    )
  }
  {
    post.data.notes
      .filter((n) => /^[A-Za-zÀ-ú\s]{2,25}:/.test(n))
      .map((n) => {
        const idx = n.indexOf(':');
        return (
          <div class="gp-row">
            <span class="gp-label">{n.slice(0, idx).trim()}</span>
            <span class="gp-value">{n.slice(idx + 1).trim()}</span>
          </div>
        );
      })
  }
  {
    post.data.notes.filter((n) => !/^[A-Za-zÀ-ú\s]{2,25}:/.test(n)).length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.notes_label}</span>
        <div class="gp-value">
          {post.data.notes
            .filter((n) => !/^[A-Za-zÀ-ú\s]{2,25}:/.test(n))
            .map((n) => (
              <div class="gp-muted">{n}</div>
            ))}
        </div>
      </div>
    )
  }
</div>

{/* Link utili */}
{
  links.length > 0 && (
    <div class="gp-links">
      {links.map((link) => (
        <a href={link.url} target="_blank" rel="noopener noreferrer" class="gp-link-btn">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="16" y1="13" x2="8" y2="13" />
            <line x1="16" y1="17" x2="8" y2="17" />
            <polyline points="10 9 9 9 8 9" />
          </svg>
          {link.label}
        </a>
      ))}
    </div>
  )
}

{/* Contenuto */}
<div class="gp-content prose">
  <Content />
</div>

{/* Streaming finale */}
{
  post.data.streamingUrl && (
    <div class="gp-links">
      <a
        href={post.data.streamingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="gp-link-btn gp-link-btn--streaming"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0C.488 3.45.029 5.804 0 12c.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0C23.512 20.55 23.971 18.196 24 12c-.029-6.185-.484-8.549-4.385-8.816zM9 16V8l8 4-8 4z" />
        </svg>
        {t.gp.streaming_label}
      </a>
    </div>
  )
}

{/* Galleria a sezioni */}
{
  post.data.gallerySections.length > 0 && (
    <section class="gp-gallery">
      <h2 class="gp-gallery-title">{t.post.gallery}</h2>
      {post.data.gallerySections.map((section) => (
        <div class="gp-gallery-section">
          <h3 class="gp-gallery-section-title">{section.title}</h3>
          <div class="gp-collage">
            {section.images.map((img, i) => (
              <a
                href={img}
                class={`gp-collage-item${(section.wideImages || []).includes(img) ? ' wide' : ''}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img src={img} alt={`${section.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  )
}

{/* Galleria griglia (fallback se no sezioni) */}
{
  post.data.gallerySections.length === 0 && galleryImages.length > 0 && (
    <section class="gp-gallery">
      <h2 class="gp-gallery-title">{t.post.gallery}</h2>
      <div class="gp-gallery-grid">
        {galleryImages.map((img, i) => (
          <a href={img} class="gp-gallery-item" target="_blank" rel="noopener noreferrer">
            <img src={img} alt={`${post.data.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </section>
  )
}

{/* Classifica */}
{
  standings.length > 0 && (
    <section id="classifica" class="gp-standings">
      <h2 class="gp-standings-title">{t.gp.standings_label}</h2>
      <div class="gp-standings-wrap">
        <table class="gp-standings-table">
          <caption class="sr-only">{t.gp.standings_label}</caption>
          <thead>
            <tr>
              <th class="tc">#</th>
              <th>{t.gp.standings_player}</th>
              <th class="tc">GW</th>
              <th class="tc">VP</th>
              {hasFvp && <th class="tc">FVP</th>}
              <th class="tc">TP</th>
            </tr>
          </thead>
          <tbody>
            {standings.map((s) => (
              <tr
                class:list={[
                  s.rank <= 1 && 'gp-standings-winner',
                  s.rank >= 2 && s.rank <= 5 && 'gp-standings-finalist',
                ]}
              >
                <td class="tc">{s.rank}</td>
                <td>{anonymizeName(s.name)}</td>
                <td class="tc">{s.gw}</td>
                <td class="tc">{s.vp}</td>
                {hasFvp && <td class="tc">{s.fvp ?? ''}</td>}
                <td class="tc">{s.tp}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )
}

<style>
  /* Poster */
  .gp-poster {
    margin: 0 0 28px;
    text-align: center;
  }
  .gp-poster-caption {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    font-style: italic;
    margin-top: 8px;
  }
  .gp-poster img {
    max-width: 360px;
    width: 100%;
    margin: 0 auto;
    display: block;
    border-radius: var(--radius);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  /* Prose */
  .gp-excerpt {
    font-size: var(--font-size-small);
    line-height: var(--leading-relaxed);
    color: var(--color-contrast);
    margin-bottom: 24px;
    text-align: left;
  }
  .gp-content {
    margin-bottom: 28px;
  }

  /* Info block */
  .gp-info {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    overflow: hidden;
    margin-bottom: 28px;
  }
  .gp-row {
    display: flex;
    gap: 16px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border);
    align-items: baseline;
  }
  .gp-row:last-child {
    border-bottom: none;
  }
  .gp-label {
    flex-shrink: 0;
    width: 100px;
    font-size: var(--font-size-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-gold);
    padding-top: 2px;
  }
  .gp-value {
    font-size: var(--font-size-small);
    line-height: var(--leading-normal);
    color: var(--color-contrast);
  }
  .gp-value a {
    color: var(--color-accent-1);
    text-decoration: none;
  }
  .gp-value a:hover {
    color: var(--color-accent-2);
    text-decoration: underline;
  }
  .gp-event {
    margin-bottom: 10px;
  }
  .gp-event:last-child {
    margin-bottom: 0;
  }
  .gp-link-btn--inline {
    margin-top: 6px;
    font-size: var(--font-size-xs);
    padding: 4px 12px;
  }
  .gp-muted {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }
  .gp-hotel-note {
    margin-top: 6px;
  }
  .gp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }
  .gp-table th,
  .gp-table td {
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .gp-table th {
    font-size: var(--font-size-2xs);
    font-weight: 600;
    color: var(--color-muted);
    background: transparent;
  }

  /* Prizes list */
  .gp-prizes-list {
    list-style: disc;
    padding-left: 18px;
    margin: 0;
  }
  .gp-prizes-list li {
    padding: 2px 0;
  }

  /* Archon links in registration */
  .gp-archon-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }

  /* Links */
  .gp-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }
  .gp-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    padding: 8px 18px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: var(--radius);
    background: rgba(201, 168, 76, 0.08);
    transition: all 0.2s ease;
  }
  .gp-link-btn:hover {
    background: rgba(201, 168, 76, 0.18);
    border-color: rgba(201, 168, 76, 0.5);
  }
  .gp-link-btn--streaming {
    color: var(--color-streaming);
    border-color: rgba(255, 0, 0, 0.3);
    background: rgba(255, 0, 0, 0.08);
  }
  .gp-link-btn--streaming:hover {
    background: rgba(255, 0, 0, 0.18);
    border-color: rgba(255, 0, 0, 0.5);
  }
  .gp-link-btn svg {
    flex-shrink: 0;
  }

  /* Quick nav */
  .gp-quicknav {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .gp-quicknav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    padding: 6px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all 0.2s ease;
  }
  .gp-quicknav-link:hover {
    color: var(--color-gold);
    border-color: rgba(201, 168, 76, 0.3);
    background: rgba(201, 168, 76, 0.08);
  }
  .gp-quicknav-link svg {
    flex-shrink: 0;
  }

  /* Standings */
  .gp-standings {
    margin-bottom: 32px;
    scroll-margin-top: 80px;
  }
  .gp-standings-title {
    font-size: var(--font-size-lg);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    text-align: center;
    margin-bottom: 16px;
  }
  .gp-standings-wrap {
    overflow: auto;
    max-height: 480px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    scrollbar-width: none;
  }
  .gp-standings-wrap::-webkit-scrollbar {
    display: none;
  }
  .gp-standings-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }
  .gp-standings-table th {
    font-size: var(--font-size-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-gold);
    padding: 8px 10px;
    border-bottom: 2px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-base);
  }
  .gp-standings-table td {
    padding: 6px 10px;
    border-bottom: 1px solid var(--color-border);
  }
  .gp-standings-table tr:hover td {
    background: rgba(201, 168, 76, 0.05);
  }
  .gp-standings-winner td {
    color: var(--color-gold);
    font-weight: 700;
  }
  .gp-standings-finalist td {
    font-weight: 600;
  }

  .gp-standings-table th,
  .gp-standings-table td {
    text-align: center;
  }
  .gp-standings-table th:nth-child(2),
  .gp-standings-table td:nth-child(2) {
    text-align: left;
  }

  /* Gallery */
  .gp-gallery {
    margin-top: 32px;
  }
  .gp-gallery-title {
    font-size: var(--font-size-lg);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    text-align: center;
    margin-bottom: 24px;
  }

  /* Gallery sections with collage */
  .gp-gallery-section {
    margin-bottom: 28px;
  }
  .gp-gallery-section-title {
    font-size: var(--font-size-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-gold);
    margin-bottom: 12px;
    text-align: center;
  }
  .gp-collage {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
  }
  .gp-collage-item {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .gp-collage-item.wide {
    grid-column: 1 / -1;
  }
  .gp-collage-item:only-child {
    grid-column: 1 / -1;
    max-width: 500px;
    margin: 0 auto;
  }
  .gp-collage-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .gp-collage-item:hover img {
    transform: scale(1.05);
  }

  /* Gallery grid (fallback) */
  .gp-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 8px;
  }
  .gp-gallery-item {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .gp-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
