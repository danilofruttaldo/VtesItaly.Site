---
import '../../../styles/community-page.css';
import type { GetStaticPaths } from 'astro';
import Base from '../../../layouts/Base.astro';
import Hero from '../../../components/Hero.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../../../data/pages';
import { filterByLocale, useTranslations } from '../../../utils/i18n';
import { getEnPostUrl } from '../../../utils/url';
import { todayLocalMidnight } from '../../../utils/today';

const t = useTranslations('en');

export const getStaticPaths = (async ({ paginate }) => {
  const posts = filterByLocale(await getCollection('blog'), 'en')
    .filter((p) => p.data.category === 'comunita')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  const today = todayLocalMidnight();
  const pastStartGlobal = posts.findIndex((p) => new Date(p.data.date) < today);
  return paginate(posts, { pageSize: 8 }).map((path) => ({
    ...path,
    props: { ...path.props, pastStartGlobal },
  }));
}) satisfies GetStaticPaths;

const pageMeta = mainPages.find((p) => p.slug.it === 'comunita')!;
const { page, pastStartGlobal } = Astro.props as typeof Astro.props & { pastStartGlobal: number };

const pageStart = (page.currentPage - 1) * page.size;
const dividerAtPageIndex =
  pastStartGlobal === -1 || pastStartGlobal < pageStart || pastStartGlobal >= pageStart + page.data.length
    ? -1
    : pastStartGlobal - pageStart;
---

<Base
  title={pageMeta.title.en}
  description={pageMeta.description.en}
  ogImage={pageMeta.ogImage}
  noindex={page.currentPage > 1}
>
  <Hero src={pageMeta.headerImage} alt={pageMeta.title.en} />
  <section class="hero-text">
    <div class="container container--narrow">
      <h1>{pageMeta.title.en}</h1>
      <p class="hero-text__subtitle">{t.community.subtitle}</p>
    </div>
  </section>
  <section class="section">
    <div class="container container--narrow">
      <div class="post-list" data-temporal-divider>
        {
          page.data.map((post, i) => (
            <>
              {i === dividerAtPageIndex && (
                <div class="post-list__divider" role="separator" aria-label={t.community.past_label}>
                  <span>{t.community.past_label}</span>
                </div>
              )}
              <PostCard
                href={getEnPostUrl(post)}
                title={post.data.title}
                image={post.data.featuredImage || post.data.poster}
                imageAnchor={
                  post.data.imageAnchor ||
                  (post.data.events && post.data.events.length > 0 && post.data.events.every((e) => e.type === 'altro')
                    ? 'left center'
                    : undefined)
                }
                date={post.data.date}
                tags={post.data.tags}
                excerpt={post.data.excerpt}
                locale="en"
                eager={i === 0}
              />
            </>
          ))
        }
        {
          /* Fallback divider for the runtime script to move when build-time saw
            no past on this page but today has since advanced. */
        }
        {
          dividerAtPageIndex === -1 && (
            <div class="post-list__divider" role="separator" aria-label={t.community.past_label} hidden>
              <span>{t.community.past_label}</span>
            </div>
          )
        }
      </div>

      {
        page.lastPage > 1 && (
          <nav class="pagination" aria-label={t.community.pagination}>
            {page.url.prev ? (
              <a href={page.url.prev} class="pagination__link">
                &larr; {t.community.previous}
              </a>
            ) : (
              <span class="pagination__link pagination__link--disabled">&larr; {t.community.previous}</span>
            )}
            <span class="pagination__info">
              {t.community.page_info
                .replace('%current%', String(page.currentPage))
                .replace('%last%', String(page.lastPage))}
            </span>
            {page.url.next ? (
              <a href={page.url.next} class="pagination__link">
                {t.community.next} &rarr;
              </a>
            ) : (
              <span class="pagination__link pagination__link--disabled">{t.community.next} &rarr;</span>
            )}
          </nav>
        )
      }
      <ShareButtons />
    </div>
  </section>
</Base>
