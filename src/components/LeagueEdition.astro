---
import '../styles/prose.css';
import '../styles/league-edition.css';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../utils/i18n';
import { useTranslations } from '../utils/i18n';
import { resolveLinkLabel, resolvePlatformLabel } from '../utils/status';
import { anonymizeName } from '../utils/anonymize';
import { composeFormat } from '../utils/calendar';
import { formatLocalDate } from '../utils/i18n';

interface Props {
  post: CollectionEntry<'blog'>;
  locale?: Locale;
}

const { post, locale = 'it' } = Astro.props;
if (post.data.category !== 'comunita') {
  throw new Error(`LeagueEdition: unsupported category "${post.data.category}"`);
}
const t = useTranslations(locale);
const { Content } = await render(post);

// Links (same pattern as EventEdition)
const links = (post.data.links ?? [])
  .filter((l) => !l.locale || l.locale === locale)
  .map((l) => ({ ...l, label: resolveLinkLabel(l) }));

// Gallery (same pattern as EventEdition)
let galleryImages: string[] = post.data.gallery || [];
if (post.data.galleryFolder && galleryImages.length === 0) {
  const folder = post.data.galleryFolder.replace(/^\//, '').replace(/\/$/, '');
  const allImages = import.meta.glob('/public/{gp,nc,tour,ev}/**/*.{webp,jpg,jpeg,png}');
  galleryImages = Object.keys(allImages)
    .filter((p) => p.includes(`/${folder}/`))
    .map((p) => p.replace('/public', ''))
    .sort();
}
if (post.data.poster) {
  galleryImages = galleryImages.filter((img) => img !== post.data.poster);
}

// League standings — supports two dialects:
//   - league shape (full season): { fp?, lp, gw, vp, pp, bp, games }
//   - tournament shape (single giornata): { gw, vp, fvp?, tp }
// We discriminate by the presence of `tp` on the first row.
interface LeagueStanding {
  rank: number;
  name: string;
  fp?: number | null;
  lp?: number;
  gw: number;
  vp: number;
  pp?: number;
  bp?: number;
  games?: number;
  fvp?: number | null;
  tp?: number;
}
let standings: LeagueStanding[] = [];
if (post.data.standingsUrl) {
  const allData = import.meta.glob('/src/data/standings/**/*.json', { eager: true }) as Record<
    string,
    { default: unknown }
  >;
  const key = Object.keys(allData).find((k) => k.includes(post.data.standingsUrl!.replace(/^.*\//, '')));
  if (key && Array.isArray(allData[key].default)) standings = allData[key].default as LeagueStanding[];
}
const isTournamentShape = standings.length > 0 && 'tp' in standings[0];
const hasFp = standings.some((s) => s.fp != null);
const hasPp = standings.some((s) => (s.pp ?? 0) !== 0);
const hasFvp = standings.some((s) => s.fvp != null);
function fmt(n: number): string {
  return n % 1 === 0 ? String(n) : n.toFixed(2).replace(/0+$/, '').replace(/\.$/, '');
}
---

{/* Poster */}
{
  post.data.poster && (
    <div class="le-poster">
      <img src={post.data.poster} alt={post.data.title} loading="eager" decoding="async" />
    </div>
  )
}

{/* Quick nav */}
{
  standings.length > 0 && (
    <nav class="le-quicknav">
      <a href="#classifica" class="le-quicknav-link">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9" />
        </svg>
        {t.post.jump_standings}
      </a>
    </nav>
  )
}

{/* Content */}
<div class="le-content prose">
  <Content />
</div>

{/* Stats bar */}
{
  post.data.leagueStats && (
    <div class="le-stats">
      <div class="le-stat">
        <span class="le-stat-value">{post.data.leagueStats.players}</span>
        <span class="le-stat-label">{t.league.players}</span>
      </div>
      <div class="le-stat">
        <span class="le-stat-value">{post.data.leagueStats.games}</span>
        <span class="le-stat-label">{t.league.games}</span>
      </div>
      <div class="le-stat">
        <span class="le-stat-value">{post.data.leagueStats.tables}</span>
        <span class="le-stat-label">{t.league.tables}</span>
      </div>
    </div>
  )
}

{/* Top Lists */}
{
  post.data.leagueTopLists && post.data.leagueTopLists.length > 0 && (
    <section class="le-tops">
      <h2 class="le-section-title">{t.league.top_lists_title}</h2>
      <div class="le-tops-grid">
        {post.data.leagueTopLists.map((list) => (
          <div class="le-top-col">
            <h3 class="le-top-label">{list.label}</h3>
            <ul class="le-top-list">
              {list.items.map((item) => (
                <li>
                  {item.name} <span class="le-top-count">({item.count})</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )
}

{/* Info block */}
<div class="le-info">
  {
    post.data.venue && (
      <div class="le-row">
        <span class="le-label">{t.gp.venue_label}</span>
        <span class="le-value">
          <>
            <strong>
              {post.data.venue.siteUrl ? (
                <a href={post.data.venue.siteUrl} target="_blank" rel="noopener noreferrer">
                  {post.data.venue.name}
                </a>
              ) : (
                post.data.venue.name
              )}
            </strong>
            <br />
          </>
          {post.data.venue.mapUrl ? (
            <a href={post.data.venue.mapUrl} target="_blank" rel="noopener noreferrer">
              {post.data.venue.address}
            </a>
          ) : (
            post.data.venue.address
          )}
        </span>
      </div>
    )
  }
  {
    post.data.events.length > 0 && (
      <div class="le-row">
        <span class="le-label">{t.gp.program_label}</span>
        <div class="le-value">
          {post.data.events.map((ev) => (
            <div class="le-event">
              <strong>{ev.name}</strong>
              <br />
              {ev.period ? (
                ev.period
              ) : (
                <>
                  {formatLocalDate(new Date(ev.date), locale, { weekday: 'long', day: 'numeric', month: 'long' })} —{' '}
                  {`${t.gp.time_prefix} ${ev.time}`}
                </>
              )}
              <br />
              <span class="le-muted">{composeFormat(ev.format, ev.proxies, ev.rounds, locale)}</span>
            </div>
          ))}
        </div>
      </div>
    )
  }
  {
    post.data.schedule.length > 0 && (
      <div class="le-row">
        <span class="le-label">{t.gp.schedule_label}</span>
        <div class="le-value">
          {post.data.schedule.map((s) => (
            <div>
              {s.label}: <strong>{s.time}</strong>
            </div>
          ))}
        </div>
      </div>
    )
  }
  {
    post.data.pricing.length > 0 && (
      <div class="le-row">
        <span class="le-label">{t.gp.pricing_label}</span>
        <div class="le-value">
          {post.data.pricing.map((p) => (
            <div>
              {p.label}: <strong>{p.regular}</strong>
            </div>
          ))}
        </div>
      </div>
    )
  }
  {
    post.data.payment && (
      <div class="le-row">
        <span class="le-label">{t.gp.payment_label}</span>
        <span class="le-value">{post.data.payment}</span>
      </div>
    )
  }
  {
    (post.data.registration || post.data.events.some((ev) => ev.archonUrl)) && (
      <div class="le-row">
        <span class="le-label">{t.gp.registration_label}</span>
        <div class="le-value">
          {post.data.registration}
          {post.data.events.some((ev) => ev.archonUrl) && (
            <div class="le-archon-links">
              {post.data.events
                .filter((ev) => ev.archonUrl)
                .map((ev) => {
                  const platform = resolvePlatformLabel(ev.archonUrl!);
                  return (
                    <a href={ev.archonUrl} target="_blank" rel="noopener noreferrer" class="le-link-btn">
                      <svg
                        viewBox="0 0 24 24"
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                      {`${ev.name} — ${platform}`}
                    </a>
                  );
                })}
            </div>
          )}
        </div>
      </div>
    )
  }
  {
    post.data.prizes && (
      <div class="le-row">
        <span class="le-label">{t.gp.prizes_label}</span>
        <div class="le-value">
          {Array.isArray(post.data.prizes) ? (
            <ul class="le-prizes-list">
              {post.data.prizes.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          ) : (
            post.data.prizes
          )}
        </div>
      </div>
    )
  }
  {
    post.data.contact && (
      <div class="le-row">
        <span class="le-label">{t.gp.contact_label}</span>
        <span class="le-value">
          {post.data.contact?.includes('@') ? (
            <a href={`mailto:${post.data.contact}`}>{post.data.contact}</a>
          ) : (
            post.data.contact
          )}
        </span>
      </div>
    )
  }
</div>

{/* Links */}
{
  links.length > 0 && (
    <div class="le-links">
      {links.map((link) => {
        const isPdf = /\.pdf(?:[?#]|$)/i.test(link.url);
        const isWeb = /^https?:\/\//i.test(link.url) && !isPdf;
        return (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`le-link-btn${isWeb ? ' le-link-btn--web' : ''}`}
          >
            {isWeb ? (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
                <polyline points="10 9 9 9 8 9" />
              </svg>
            )}
            {link.label}
          </a>
        );
      })}
    </div>
  )
}

{/* Rules */}
{
  post.data.leagueRules && post.data.leagueRules.length > 0 && (
    <section class="le-rules">
      <h2 class="le-section-title">{t.league.rules_title}</h2>
      <div class="le-rules-list">
        {post.data.leagueRules.map((rule) => (
          <div class="le-rule">
            <span class="le-rule-acronym">{rule.acronym}</span>
            <span class="le-rule-label">({rule.label})</span>
            <span class="le-rule-desc">{rule.description}</span>
          </div>
        ))}
      </div>
    </section>
  )
}

{/* Bonus Points */}
{
  post.data.leagueBonusPoints && post.data.leagueBonusPoints.length > 0 && (
    <section class="le-bonus">
      <h2 class="le-section-title">{t.league.bonus_title}</h2>
      <div class="le-bonus-list">
        {post.data.leagueBonusPoints.map((bp) => (
          <div class="le-bonus-item">
            <strong class="le-bonus-name">{bp.name}</strong>
            <span class="le-bonus-desc">{bp.description}</span>
          </div>
        ))}
      </div>
    </section>
  )
}

{/* League Standings */}
{
  standings.length > 0 && (
    <section id="classifica" class="le-standings">
      <h2 class="le-section-title">{post.data.standingsLabel ?? t.league.standings_label}</h2>
      <div class="le-standings-wrap">
        <table class="le-standings-table">
          <caption class="sr-only">{post.data.standingsLabel ?? t.league.standings_label}</caption>
          {isTournamentShape ? (
            <>
              <thead>
                <tr>
                  <th class="tc">#</th>
                  <th>{t.league.standings_player}</th>
                  <th class="tc">GW</th>
                  <th class="tc">VP</th>
                  {hasFvp && <th class="tc">FVP</th>}
                  <th class="tc">TP</th>
                </tr>
              </thead>
              <tbody>
                {standings.map((s) => (
                  <tr
                    class:list={[
                      s.rank === 1 && 'le-standings-winner',
                      s.rank >= 2 && s.rank <= 5 && 'le-standings-finalist',
                    ]}
                  >
                    <td class="tc">{s.rank}</td>
                    <td>{anonymizeName(s.name)}</td>
                    <td class="tc">{s.gw}</td>
                    <td class="tc">{fmt(s.vp)}</td>
                    {hasFvp && <td class="tc">{s.fvp != null ? fmt(s.fvp) : ''}</td>}
                    <td class="tc">{s.tp ?? 0}</td>
                  </tr>
                ))}
              </tbody>
            </>
          ) : (
            <>
              <thead>
                <tr>
                  <th class="tc">#</th>
                  <th>{t.league.standings_player}</th>
                  <th class="tc">GW</th>
                  <th class="tc">VP</th>
                  {hasFp && <th class="tc">FVP</th>}
                  <th class="tc">LP</th>
                  {hasPp && <th class="tc">PP</th>}
                  <th class="tc">BP</th>
                  <th class="tc">G</th>
                </tr>
              </thead>
              <tbody>
                {standings.map((s) => (
                  <tr
                    class:list={[
                      s.rank === 1 && 'le-standings-winner',
                      s.rank >= 2 && s.rank <= 5 && 'le-standings-finalist',
                    ]}
                  >
                    <td class="tc">{s.rank}</td>
                    <td>{anonymizeName(s.name)}</td>
                    <td class="tc">{s.gw}</td>
                    <td class="tc">{fmt(s.vp)}</td>
                    {hasFp && <td class="tc">{s.fp != null ? fmt(s.fp) : ''}</td>}
                    <td class="tc">{fmt(s.lp ?? 0)}</td>
                    {hasPp && <td class="tc">{fmt(s.pp ?? 0)}</td>}
                    <td class="tc">{s.bp ?? 0}</td>
                    <td class="tc">{s.games ?? 0}</td>
                  </tr>
                ))}
              </tbody>
            </>
          )}
        </table>
      </div>
    </section>
  )
}

{/* Gallery */}
{
  post.data.gallerySections.length > 0 && (
    <section class="le-gallery">
      <h2 class="le-section-title">{t.post.gallery}</h2>
      {post.data.gallerySections.map((section) => (
        <div class="le-gallery-section">
          <h3 class="le-gallery-section-title">{section.title}</h3>
          <div class="le-gallery-grid">
            {section.images.map((img, i) => (
              <a
                href={img}
                class={`le-gallery-item${(section.wideImages || []).includes(img) ? ' wide' : ''}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img src={img} alt={`${section.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  )
}
{
  post.data.gallerySections.length === 0 && galleryImages.length > 0 && (
    <section class="le-gallery">
      <h2 class="le-section-title">{t.post.gallery}</h2>
      <div class="le-gallery-grid">
        {galleryImages.map((img, i) => (
          <a href={img} class="le-gallery-item" target="_blank" rel="noopener noreferrer">
            <img src={img} alt={`${post.data.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </section>
  )
}
