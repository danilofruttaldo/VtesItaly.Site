---
import '../../../styles/community-page.css';
import type { GetStaticPaths } from 'astro';
import Base from '../../../layouts/Base.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../../../data/pages';
import { filterByLocale, useTranslations, formatLocalDate } from '../../../utils/i18n';
import { typeTagLabels } from '../../../data/categories';

const t = useTranslations('en');

export const getStaticPaths = (async ({ paginate }) => {
  const posts = filterByLocale(await getCollection('blog'), 'en')
    .filter(p => p.data.category === 'comunita')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  return paginate(posts, { pageSize: 8 });
}) satisfies GetStaticPaths;

const pageMeta = mainPages.find(p => p.slug.it === 'comunita')!;
const { page } = Astro.props;

const typeTags = Object.fromEntries(Object.entries(typeTagLabels).map(([k, v]) => [k, v.en]));

function getEnPostUrl(post: any): string {
  let cleanSlug = post.slug.replace(/-en$/, '');
  let catSlug = post.data.category;
  if (catSlug === 'nazionale') { catSlug = 'national-championship'; cleanSlug = cleanSlug.replace('nazionale-', 'nc-'); }
  else if (catSlug === 'comunita') { catSlug = 'community'; }
  return `/en/${catSlug}/${cleanSlug}/`;
}
---
<Base title={pageMeta.title.en} description={pageMeta.description.en} noindex={page.currentPage > 1}>
  <img src={pageMeta.headerImage} alt={pageMeta.title.en} class="hero-banner" decoding="async" fetchpriority="high" />
  <section class="hero-text">
    <div class="container container--narrow">
      <h1>{pageMeta.title.en}</h1>
      <p class="hero-text__subtitle">{t.community.subtitle}</p>
    </div>
  </section>
  <section class="section"><div class="container container--narrow">

    <div class="post-list">
      {page.data.map(post => (
        <a href={getEnPostUrl(post)} class="post-card">
          <h2 class="post-card__title">{post.data.title}</h2>
          <div class="post-card__body">
            {(post.data.featuredImage || post.data.poster) && (
              <img src={post.data.featuredImage || post.data.poster} alt={post.data.title} class:list={['post-card__image', !post.data.featuredImage && post.data.poster && 'post-card__image--poster']} loading="lazy" decoding="async" />
            )}
            <div class="post-card__content">
              <div class="post-card__date-row">
                <time class="post-card__date" datetime={post.data.date.toISOString()}>
                  {formatLocalDate(post.data.date, 'en')}
                </time>
                {(() => {
                  const typeTag = post.data.tags?.find((t: string) => typeTags[t]);
                  return typeTag ? <span class="post-card__type">{typeTags[typeTag]}</span> : null;
                })()}
              </div>
              {post.data.excerpt && <p class="post-card__excerpt">{post.data.excerpt}</p>}
              <span class="post-card__cta">{t.post.read_cta} &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label={t.community.pagination}>
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination__link">&larr; {t.community.previous}</a>
        ) : (
          <span class="pagination__link pagination__link--disabled">&larr; {t.community.previous}</span>
        )}
        <span class="pagination__info">{t.community.page_info.replace('%current%', String(page.currentPage)).replace('%last%', String(page.lastPage))}</span>
        {page.url.next ? (
          <a href={page.url.next} class="pagination__link">{t.community.next} &rarr;</a>
        ) : (
          <span class="pagination__link pagination__link--disabled">{t.community.next} &rarr;</span>
        )}
      </nav>
    )}
    <ShareButtons />
  </div></section>
</Base>

