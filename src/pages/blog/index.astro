---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'comunita')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(date: Date): string {
  return date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Base title="Comunità" description="Articoli, report e novità dalla comunità VTES Italia.">
  <PageHero title="Comunità" />
  <section class="section"><div class="container container--narrow">
    <p class="section-subtitle">Articoli, report e novità dalla comunità.</p>

    <div class="post-list">
      {posts.map(post => (
        <a href={`/${post.data.category}/${post.slug}/`} class="post-card">
          {post.data.featuredImage && (
            <img src={post.data.featuredImage} alt={post.data.title} class="post-card__image" loading="lazy" />
          )}
          <div class="post-card__content">

            <h2 class="post-card__title">{post.data.title}</h2>
            <time class="post-card__date" datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
          </div>
        </a>
      ))}
    </div>
  </div></section>
</Base>

<style>
  .section { padding: 40px clamp(20px, 5vw, 80px) 48px; }
  .section-subtitle { color: var(--color-muted); margin-bottom: 32px; text-align: center; }
  .post-list { display: flex; flex-direction: column; gap: 16px; }
  .post-card {
    display: flex; gap: 16px; align-items: center;
    padding: 16px; border-radius: var(--radius);
    border: 1px solid var(--color-border);
    text-decoration: none; color: var(--color-contrast);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }
  .post-card:hover {
    background-color: rgba(255,255,255,0.04);
    transform: translateX(2px);
    color: var(--color-contrast);
  }
  .post-card__image {
    width: 80px; height: 80px; border-radius: var(--radius);
    object-fit: cover; flex-shrink: 0;
  }
  .post-card__content { flex: 1; min-width: 0; }
  .post-card__category {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.5px; color: var(--color-gold);
  }
  .post-card__title {
    font-size: 1rem; font-weight: 600; margin: 4px 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .post-card__date { font-size: 0.78rem; color: var(--color-muted); }

  @media (max-width: 544px) {
    .post-card__image { width: 60px; height: 60px; }
  }
</style>
