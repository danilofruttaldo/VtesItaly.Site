---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';
import { filterByLocale, useTranslations, formatLocalDate } from '../../utils/i18n';

const t = useTranslations('it');

export const getStaticPaths = (async ({ paginate }) => {
  const posts = filterByLocale(await getCollection('blog'), 'it')
    .filter(p => p.data.category === 'comunita')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  return paginate(posts, { pageSize: 8 });
}) satisfies GetStaticPaths;

const pageMeta = mainPages.find(p => p.slug.it === 'comunita')!;
const { page } = Astro.props;

const typeTags: Record<string, string> = {
  contest: 'Contest',
  torneo: 'Torneo',
  lega: 'Lega',
  prerelease: 'Prerelease',
};
---
<Base title={pageMeta.title.it} description={pageMeta.description.it}>
  <img src={pageMeta.headerImage} alt={pageMeta.title.it} class="hero-banner" decoding="async" fetchpriority="high" />
  <section class="hero-text">
    <div class="container container--narrow">
      <h1>{pageMeta.title.it}</h1>
      <p class="hero-text__subtitle">{t.community.subtitle}</p>
    </div>
  </section>
  <section class="section"><div class="container container--narrow">

    <div class="post-list">
      {page.data.map(post => (
        <a href={`/${post.data.category}/${post.slug}/`} class="post-card">
          <h2 class="post-card__title">{post.data.title}</h2>
          <div class="post-card__body">
            {(post.data.featuredImage || post.data.poster) && (
              <img src={post.data.featuredImage || post.data.poster} alt={post.data.title} class:list={['post-card__image', !post.data.featuredImage && post.data.poster && 'post-card__image--poster']} loading="lazy" decoding="async" />
            )}
            <div class="post-card__content">
              <div class="post-card__date-row">
                <time class="post-card__date" datetime={post.data.date.toISOString()}>
                  {formatLocalDate(post.data.date, 'it')}
                </time>
                {(() => {
                  const typeTag = post.data.tags?.find((t: string) => typeTags[t]);
                  return typeTag ? <span class="post-card__type">{typeTags[typeTag]}</span> : null;
                })()}
              </div>
              {post.data.excerpt && <p class="post-card__excerpt">{post.data.excerpt}</p>}
              <span class="post-card__cta">{t.post.read_cta} &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label={t.community.pagination}>
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination__link">&larr; {t.community.previous}</a>
        ) : (
          <span class="pagination__link pagination__link--disabled">&larr; {t.community.previous}</span>
        )}
        <span class="pagination__info">{t.community.page_info.replace('%current%', String(page.currentPage)).replace('%last%', String(page.lastPage))}</span>
        {page.url.next ? (
          <a href={page.url.next} class="pagination__link">{t.community.next} &rarr;</a>
        ) : (
          <span class="pagination__link pagination__link--disabled">{t.community.next} &rarr;</span>
        )}
      </nav>
    )}
    <ShareButtons />
  </div></section>
</Base>

<style>
  .hero-banner { width: 100%; display: block; object-fit: cover; max-height: 340px; }
  .hero-text { padding: 24px clamp(20px, 5vw, 80px) 40px; text-align: center; }
  .hero-text h1 { font-size: clamp(1.5rem, 5vw, 2.25rem); font-weight: 700; text-transform: uppercase; margin-bottom: 12px; }
  .hero-text__subtitle { color: var(--color-muted); font-size: clamp(0.9rem, 3vw, 1.05rem); line-height: 1.6; margin: 0; }
  .post-card__date-row { display: flex; align-items: center; gap: 8px; }
  .post-card__type {
    flex-shrink: 0;
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--color-gold); background: rgba(201,168,76,0.1);
    padding: 2px 8px; border-radius: var(--radius);
  }
  .post-card__cta {
    font-size: var(--font-size-small); font-weight: 600; color: var(--color-accent-1);
    margin-top: auto; padding-top: 8px; align-self: flex-end;
  }
  .post-card:hover .post-card__cta { color: var(--color-accent-2); }
  .post-card__excerpt {
    font-size: var(--font-size-small); color: var(--color-muted);
    line-height: 1.5; margin: 6px 0 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
</style>
