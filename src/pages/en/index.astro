---
import Base from '../../layouts/Base.astro';
import Calendar from '../../components/Calendar.astro';
import { cities } from '../../data/cities';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';
import { categoryLabels } from '../../data/categories';
import { filterByLocale, useTranslations, formatLocalDate } from '../../utils/i18n';

const page = mainPages.find(p => p.slug.it === '')!;
const t = useTranslations('en');
const latestPosts = filterByLocale(await getCollection('blog'), 'en')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);
---

<Base title={page.title.en} description={page.description.en}>
  <img src={page.headerImage} alt="VTES Italy" class="hero-banner" decoding="async" fetchpriority="high" />

  <section class="hero-text">
    <div class="container container--narrow">
      <h1>{t.home.hero_title}</h1>
      <p class="hero-text__subtitle">{t.home.hero_subtitle}</p>
    </div>
  </section>

  <hr class="divider" />

  <section class="section" id="eventi">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.events_title}</h2>
      <p class="section-subtitle">{t.home.events_subtitle}</p>
      <Calendar />
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.latest_title}</h2>
      <p class="section-subtitle">{t.home.latest_subtitle}</p>
      <div class="latest-posts">
        {latestPosts.map(post => (
          <a href={`/en/${post.data.category}/${post.slug}/`} class="latest-post">
            {post.data.featuredImage && (
              <img src={post.data.featuredImage} alt={post.data.title} class="latest-post__image" loading="lazy" decoding="async" />
            )}
            <div class="latest-post__body">
              <span class="latest-post__category">{categoryLabels[post.data.category]?.en || post.data.category}</span>
              <h3 class="latest-post__title">{post.data.title}</h3>
              <time class="latest-post__date" datetime={post.data.date.toISOString()}>{formatLocalDate(post.data.date, 'en')}</time>
            </div>
          </a>
        ))}
      </div>
      <div class="section-cta">
        <a href="/en/community/" class="btn">{t.home.all_articles} &rarr;</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.domains_title}</h2>
      <p class="section-subtitle">{t.home.domains_subtitle}</p>
      <div class="cities-quicklinks">
        {cities.map(city => (
          <a href={`/en/domains/${city.slug.en}/`}>{city.name.en}</a>
        ))}
      </div>
      <div class="section-cta">
        <a href="/en/domains/" class="btn">{t.home.all_domains} &rarr;</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-banner { width: 100%; display: block; object-fit: cover; max-height: 340px; }
  .hero-text { padding: 48px clamp(20px, 5vw, 80px) 40px; text-align: center; }
  .hero-text h1 { font-size: clamp(1.5rem, 5vw, 2.25rem); margin-bottom: 16px; }
  .hero-text__subtitle {
    color: var(--color-muted); font-size: clamp(0.9rem, 3vw, 1.05rem);
    line-height: 1.6; margin-bottom: 24px;
  }

  .latest-posts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .latest-post {
    display: flex; flex-direction: column;
    border: 1px solid var(--color-border); border-radius: var(--radius);
    overflow: hidden; text-decoration: none; color: var(--color-contrast);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }
  .latest-post:hover { background-color: rgba(255,255,255,0.04); transform: translateY(-2px); color: var(--color-contrast); }
  .latest-post__image { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
  .latest-post:not(:has(.latest-post__image)) .latest-post__body { min-height: 120px; display: flex; flex-direction: column; justify-content: center; }
  .latest-post__body { padding: 12px 16px; }
  .latest-post__category {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.5px; color: var(--color-gold);
  }
  .latest-post__title { font-size: 0.95rem; font-weight: 600; margin: 4px 0; line-height: 1.3; }
  .latest-post__date { font-size: 0.78rem; color: var(--color-muted); }

  .cities-quicklinks { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
  .cities-quicklinks a {
    font-size: 0.85rem; padding: 6px 12px;
    border: 1px solid var(--color-border); border-radius: var(--radius);
    color: var(--color-accent-1); transition: all 0.2s ease;
  }
  .cities-quicklinks a:hover { background-color: var(--color-accent-1); color: #fff; border-color: var(--color-accent-1); }

  @media (max-width: 599px) {
    .hero-text { padding-inline: 16px; }
    .latest-posts { grid-template-columns: 1fr; gap: 10px; }
    .latest-post { border-radius: 0; border-left: none; border-right: none; }
  }
</style>
