{
  "ci": {
    "collect": {
      "staticDistDir": "dist",
      "url": [
        "/",
        "/en/",
        "/principati/",
        "/cartoline/",
        "/comunita/",
        "/tour/tour-2026/",
        "/nazionale/nazionale-2026/",
        "/comunita/symposium-italicum-mmxxv/"
      ]
    },
    "assert": {
      "assertions": {
        "//performance": "Lighthouse runs once per URL, so single-run variance is ~±0.05; 0.75 keeps a hard gate without flapping on borderline pages like /principati/.",
        "categories:performance": ["error", { "minScore": 0.75 }],
        "categories:accessibility": ["error", { "minScore": 0.89 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
