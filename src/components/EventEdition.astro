---
import '../styles/prose.css';
import '../styles/event-edition.css';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../utils/i18n';
import { useTranslations, formatLocalDate } from '../utils/i18n';
import { resolveLinkLabel, resolvePlatformLabel } from '../utils/status';
import { anonymizeName } from '../utils/anonymize';
import { composeFormat } from '../utils/calendar';
import { todayLocalMidnight } from '../utils/today';

interface Props {
  post: CollectionEntry<'blog'>;
  locale?: Locale;
}

const { post, locale = 'it' } = Astro.props;
if (post.data.category !== 'grand-prix' && post.data.category !== 'nazionale' && post.data.category !== 'comunita') {
  throw new Error(`EventEdition: unsupported category "${post.data.category}"`);
}
const t = useTranslations(locale);

const { Content } = await render(post);
const links = (post.data.links ?? [])
  .filter((l) => !l.locale || l.locale === locale)
  .map((l) => ({ ...l, label: resolveLinkLabel(l) }));

// Build gallery (exclude poster)
let galleryImages: string[] = post.data.gallery || [];
if (post.data.galleryFolder && galleryImages.length === 0) {
  const folder = post.data.galleryFolder.replace(/^\//, '').replace(/\/$/, '');
  const allImages = import.meta.glob('/public/{gp,nc,tour,ev}/**/*.{webp,jpg,jpeg,png}');
  galleryImages = Object.keys(allImages)
    .filter((p) => p.includes(`/${folder}/`))
    .map((p) => p.replace('/public', ''))
    .sort();
}
if (post.data.poster) {
  galleryImages = galleryImages.filter((img) => img !== post.data.poster);
}

// Load standings if available
interface Standing {
  rank: number;
  name: string;
  gw: number;
  vp: number;
  fvp: number | null;
  tp: number;
}
let standings: Standing[] = [];
if (post.data.standingsUrl) {
  const allData = import.meta.glob('/src/data/standings/**/*.json', { eager: true }) as Record<
    string,
    { default: unknown }
  >;
  const key = Object.keys(allData).find((k) => k.includes(post.data.standingsUrl!.replace(/^.*\//, '')));
  if (key && Array.isArray(allData[key].default)) standings = allData[key].default as Standing[];
}
const hasFvp = standings.some((s) => s.fvp != null);
const postEvents = post.data.events;
const today = todayLocalMidnight();
const lastEventDay = postEvents.reduce<Date | null>((max, e) => {
  const d = new Date(e.date);
  d.setHours(0, 0, 0, 0);
  return !max || d > max ? d : max;
}, null);
const eventFinished = lastEventDay !== null && today >= lastEventDay;
const earlyActive = !eventFinished && (!post.data.earlyDeadlineDate || today < post.data.earlyDeadlineDate);
const regularActive = !eventFinished && !earlyActive;
// Local-anchored ISO so the runtime script in Base.astro can compare dates as
// strings against today (also local-anchored). The toISOString() approach
// would silently shift dates near midnight in positive-offset timezones.
const toIsoLocal = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
const lastEventDayIso = lastEventDay ? toIsoLocal(lastEventDay) : undefined;
const earlyDeadlineDateIso = post.data.earlyDeadlineDate ? toIsoLocal(post.data.earlyDeadlineDate) : undefined;
---

{/* Poster / locandina */}
{
  post.data.poster && (
    <figure class="gp-poster">
      <img src={post.data.poster} alt={post.data.title} loading="eager" decoding="async" />
      {post.data.posterCaption && <figcaption class="gp-poster-caption">{post.data.posterCaption}</figcaption>}
    </figure>
  )
}

{/* Quick nav */}
{
  (standings.length > 0 || post.data.highlight) && (
    <nav class="gp-quicknav">
      {standings.length > 0 && (
        <a href="#classifica" class="gp-quicknav-link">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9" />
          </svg>
          {t.post.jump_standings}
        </a>
      )}
      {post.data.highlight && (
        <a href={`#${post.data.highlight.id}`} class="gp-quicknav-link">
          <svg
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linejoin="round"
          >
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
          {post.data.highlight.label}
        </a>
      )}
    </nav>
  )
}

{/* Contenuto */}
<div class="gp-content prose">
  <Content />
</div>

{/* Info di servizio */}
<div class="gp-info">
  {
    post.data.venue && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.venue_label}</span>
        <span class="gp-value">
          <>
            <strong>
              {post.data.venue.siteUrl ? (
                <a href={post.data.venue.siteUrl} target="_blank" rel="noopener noreferrer">
                  {post.data.venue.name}
                </a>
              ) : (
                post.data.venue.name
              )}
            </strong>
            {post.data.venue.address !== post.data.venue.name && <br />}
          </>
          {post.data.venue.address !== post.data.venue.name &&
            (post.data.venue.mapUrl ? (
              <a href={post.data.venue.mapUrl} target="_blank" rel="noopener noreferrer">
                {post.data.venue.address}
              </a>
            ) : (
              post.data.venue.address
            ))}
        </span>
      </div>
    )
  }
  {
    post.data.events.length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.program_label}</span>
        <div class="gp-value">
          {post.data.events.map((ev) => {
            const isAltro = ev.type === 'altro';
            const hasTime = ev.time && ev.time !== '—';
            const showFormat = !isAltro && ev.format;
            // Hide the event name when it just repeats the page title (single-event tournaments).
            const showName = ev.name && ev.name !== post.data.title;
            const startDate = new Date(ev.date);
            const crossesYear = !!ev.endDate && startDate.getFullYear() !== ev.endDate.getFullYear();
            const startOpts = crossesYear
              ? { weekday: 'long' as const, day: 'numeric' as const, month: 'long' as const, year: 'numeric' as const }
              : { weekday: 'long' as const, day: 'numeric' as const, month: 'long' as const };
            const endOpts = ev.endDate
              ? { weekday: 'long' as const, day: 'numeric' as const, month: 'long' as const, year: 'numeric' as const }
              : startOpts;
            return (
              <div class="gp-event">
                {showName && (
                  <>
                    <strong>{ev.name}</strong>
                    <br />
                  </>
                )}
                {formatLocalDate(startDate, locale, startOpts)}
                {ev.endDate && <> → {formatLocalDate(ev.endDate, locale, endOpts)}</>}
                {hasTime && <> — {`${t.gp.time_prefix} ${ev.time}`}</>}
                {showFormat && (
                  <>
                    <br />
                    <span class="gp-muted">{composeFormat(ev.format, ev.proxies, ev.rounds, locale)}</span>
                  </>
                )}
              </div>
            );
          })}
        </div>
      </div>
    )
  }
  {
    post.data.schedule.length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.schedule_label}</span>
        <div class="gp-value">
          {post.data.schedule.map((s) => (
            <div class="gp-schedule-item">
              <span class="gp-muted">{s.time}</span> — {s.label}
            </div>
          ))}
        </div>
      </div>
    )
  }
  {
    post.data.pricing.length > 0 && post.data.pricing.some((p) => p.regular || p.early) && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.pricing_label}</span>
        <div class="gp-value">
          <table
            class="gp-table"
            data-temporal-pricing
            data-event-last-date={lastEventDayIso}
            data-early-deadline-date={earlyDeadlineDateIso}
          >
            {post.data.earlyDeadline && (
              <thead>
                <tr>
                  <th />
                  <th class={`gp-price-cell--early ${earlyActive ? 'gp-price-active' : 'gp-price-inactive'}`}>
                    {t.gp.early_col} {post.data.earlyDeadline}
                  </th>
                  <th class={`gp-price-cell--regular ${regularActive ? 'gp-price-active' : 'gp-price-inactive'}`}>
                    {t.gp.regular_col} {post.data.earlyDeadline}
                  </th>
                </tr>
              </thead>
            )}
            <tbody>
              {post.data.pricing.map((p) => (
                <tr>
                  <td>{p.label}</td>
                  {p.early && (
                    <td class={`gp-price-cell--early ${earlyActive ? 'gp-price-active' : 'gp-price-inactive'}`}>
                      {p.early}
                    </td>
                  )}
                  <td class={`gp-price-cell--regular ${regularActive ? 'gp-price-active' : 'gp-price-inactive'}`}>
                    {p.regular}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )
  }
  {
    post.data.payment && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.payment_label}</span>
        <span class="gp-value">{post.data.payment}</span>
      </div>
    )
  }
  {
    post.data.hotel.length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.hotel_label}</span>
        <div class="gp-value">
          {post.data.hotel.map((h) => (
            <div>
              {h.room}: <strong>{h.price}</strong>
            </div>
          ))}
          {post.data.hotelNote && <div class="gp-muted gp-hotel-note">{post.data.hotelNote}</div>}
        </div>
      </div>
    )
  }
  {
    post.data.prizes && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.prizes_label}</span>
        <div class="gp-value">
          {Array.isArray(post.data.prizes) ? (
            <ul class="gp-prizes-list">
              {post.data.prizes.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          ) : (
            post.data.prizes
          )}
        </div>
      </div>
    )
  }
  {
    (post.data.registration || post.data.events.some((ev) => ev.archonUrl)) && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.registration_label}</span>
        <div class="gp-value">
          {post.data.registration && post.data.registration.includes(' · ') ? (
            <ol class="gp-steps-list">
              {post.data.registration.split(' · ').map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          ) : (
            post.data.registration
          )}
          {post.data.events.some((ev) => ev.archonUrl) && (
            <div class="gp-archon-links">
              {post.data.events
                .filter((ev) => ev.archonUrl)
                .map((ev) => {
                  const platform = resolvePlatformLabel(ev.archonUrl!);
                  const hasMultiple = postEvents.filter((e) => e.archonUrl).length > 1;
                  return (
                    <a href={ev.archonUrl} target="_blank" rel="noopener noreferrer" class="gp-link-btn">
                      <svg
                        viewBox="0 0 24 24"
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                      {hasMultiple ? `${ev.name} — ${platform}` : platform}
                    </a>
                  );
                })}
            </div>
          )}
        </div>
      </div>
    )
  }
  {
    post.data.contact && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.contact_label}</span>
        <span class="gp-value">
          {post.data.contact?.includes('@') ? (
            <a href={`mailto:${post.data.contact}`}>{post.data.contact}</a>
          ) : (
            post.data.contact
          )}
        </span>
      </div>
    )
  }
  {
    post.data.notes
      .filter((n) => /^[A-Za-zÀ-ú\s]{2,25}:/.test(n))
      .map((n) => {
        const idx = n.indexOf(':');
        return (
          <div class="gp-row">
            <span class="gp-label">{n.slice(0, idx).trim()}</span>
            <span class="gp-value">{n.slice(idx + 1).trim()}</span>
          </div>
        );
      })
  }
  {
    post.data.notes.filter((n) => !/^[A-Za-zÀ-ú\s]{2,25}:/.test(n)).length > 0 && (
      <div class="gp-row">
        <span class="gp-label">{t.gp.notes_label}</span>
        <div class="gp-value">
          {post.data.notes
            .filter((n) => !/^[A-Za-zÀ-ú\s]{2,25}:/.test(n))
            .map((n) => (
              <div class="gp-muted">{n}</div>
            ))}
        </div>
      </div>
    )
  }
</div>

{/* Link utili */}
{
  links.length > 0 && (
    <div class="gp-links">
      {links.map((link) => {
        const isPdf = /\.pdf(?:[?#]|$)/i.test(link.url);
        const isWeb = /^https?:\/\//i.test(link.url) && !isPdf;
        return (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`gp-link-btn${isWeb ? ' gp-link-btn--web' : ''}`}
          >
            {isWeb ? (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
                <polyline points="10 9 9 9 8 9" />
              </svg>
            )}
            {link.label}
          </a>
        );
      })}
    </div>
  )
}

{/* Streaming finale + extra video links */}
{
  (post.data.streamingUrl || post.data.streamingLinks.length > 0) && (
    <div class="gp-links">
      {post.data.streamingLinks.map((v) => (
        <a href={v.url} target="_blank" rel="noopener noreferrer" class="gp-link-btn gp-link-btn--streaming">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0C.488 3.45.029 5.804 0 12c.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0C23.512 20.55 23.971 18.196 24 12c-.029-6.185-.484-8.549-4.385-8.816zM9 16V8l8 4-8 4z" />
          </svg>
          {v.label}
        </a>
      ))}
      {post.data.streamingUrl && (
        <a
          href={post.data.streamingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="gp-link-btn gp-link-btn--streaming"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0C.488 3.45.029 5.804 0 12c.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0C23.512 20.55 23.971 18.196 24 12c-.029-6.185-.484-8.549-4.385-8.816zM9 16V8l8 4-8 4z" />
          </svg>
          {post.data.streamingLabel ?? t.gp.streaming_label}
        </a>
      )}
    </div>
  )
}

{/* Highlight callout (rendered after streaming) */}
{post.data.highlightHtml && <div class="gp-content prose" set:html={post.data.highlightHtml} />}

{/* Galleria a sezioni */}
{
  post.data.gallerySections.length > 0 && (
    <section class="gp-gallery">
      <h2 class="gp-gallery-title">{t.post.gallery}</h2>
      {post.data.gallerySections.map((section) => (
        <div class="gp-gallery-section">
          <h3 class="gp-gallery-section-title">{section.title}</h3>
          <div class="gp-collage">
            {section.images.map((img, i) => (
              <a
                href={img}
                class={`gp-collage-item${(section.wideImages || []).includes(img) ? ' wide' : ''}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img src={img} alt={`${section.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  )
}

{/* Galleria griglia (fallback se no sezioni) */}
{
  post.data.gallerySections.length === 0 && galleryImages.length > 0 && (
    <section class="gp-gallery">
      <h2 class="gp-gallery-title">{t.post.gallery}</h2>
      <div class="gp-gallery-grid">
        {galleryImages.map((img, i) => (
          <a href={img} class="gp-gallery-item" target="_blank" rel="noopener noreferrer">
            <img src={img} alt={`${post.data.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </section>
  )
}

{/* Classifica */}
{
  standings.length > 0 && (
    <section id="classifica" class="gp-standings">
      <h2 class="gp-standings-title">{t.gp.standings_label}</h2>
      <div class="gp-standings-wrap">
        <table class="gp-standings-table">
          <caption class="sr-only">{t.gp.standings_label}</caption>
          <thead>
            <tr>
              <th class="tc">#</th>
              <th>{t.gp.standings_player}</th>
              <th class="tc">GW</th>
              <th class="tc">VP</th>
              {hasFvp && <th class="tc">FVP</th>}
              <th class="tc">TP</th>
            </tr>
          </thead>
          <tbody>
            {standings.map((s) => (
              <tr
                class:list={[
                  s.rank <= 1 && 'gp-standings-winner',
                  s.rank >= 2 && s.rank <= 5 && 'gp-standings-finalist',
                ]}
              >
                <td class="tc">{s.rank}</td>
                <td>{anonymizeName(s.name)}</td>
                <td class="tc">{s.gw}</td>
                <td class="tc">{s.vp}</td>
                {hasFvp && <td class="tc">{s.fvp ?? ''}</td>}
                <td class="tc">{s.tp}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )
}
