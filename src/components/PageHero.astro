---
interface Props {
  title: string;
  image?: string;
  breadcrumb?: { label: string; href: string };
}

const { title, image, breadcrumb } = Astro.props;
---

<section class="page-hero" style={image ? `background-image: url(${image})` : undefined}>
  <div class="page-hero__overlay"></div>
  <div class="page-hero__content">
    {title && <h1>{title}</h1>}
  </div>
</section>

{breadcrumb && (
  <div class="container breadcrumb">
    <a href={breadcrumb.href}>&larr; {breadcrumb.label}</a>
  </div>
)}

<style>
  .page-hero {
    position: relative;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    background-color: var(--color-surface);
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(18, 20, 22, 0.65);
  }

  .page-hero__content {
    position: relative;
    text-align: center;
    padding: 40px clamp(16px, 4vw, 60px);
  }

  .page-hero__content h1 {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-contrast);
  }

  .breadcrumb {
    padding-top: 12px;
    font-size: 0.8rem;
  }

  .breadcrumb a {
    color: var(--color-muted);
  }
</style>
