---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import StagesGrid from '../components/StagesGrid.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../data/pages';

const page = mainPages.find(p => p.slug === 'tour')!;
const posts = (await getCollection('blog'))
  .filter(p => p.data.category === page.category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Current edition = most recent post with stages
const current = posts.find(p => p.data.stages && p.data.stages.length > 0);
const { Content: CurrentContent } = current ? await current.render() : { Content: null };
const pastEditions = posts.filter(p => p !== current);
---
<Base title={page.titleIt} description={page.descriptionIt}>
  <PageHero title={page.titleIt} image={page.headerImage} />

  <section class="page-section">
    <div class="container container--narrow">
      {/* Intro */}
      <Fragment set:html={page.leadHtmlIt!} />

      {/* Current edition */}
      {current && (
        <>
          <hr class="page-divider" />

          <h2 class="page-section-title">{current.data.title}</h2>

          {/* Stages grid */}
          {current.data.stages && current.data.stages.length > 0 && (
            <StagesGrid stages={current.data.stages} locale="it" />
          )}

          {/* Article content */}
          {CurrentContent && (
            <div class="edition-content prose">
              <CurrentContent />
            </div>
          )}

          {/* Standings embed */}
          {current.data.standingsUrl && (
            <div class="standings">
              <h3 class="standings-title">Classifica</h3>
              <div class="standings-frame">
                <iframe src={current.data.standingsUrl} title="Classifica Tour" loading="lazy"></iframe>
              </div>
            </div>
          )}
        </>
      )}

      {/* Past editions */}
      {pastEditions.length > 0 && (
        <>
          <hr class="page-divider" />
          <h2 class="page-section-title">{page.editionsTitleIt || 'Edizioni precedenti'}</h2>
          <div class="editions-list">
            {pastEditions.map(post => (
              <a href={`/tour/${post.slug}/`} class="edition-card">
                <span class="edition-year">{new Date(post.data.date).getFullYear()}</span>
                <span class="edition-label">{post.data.title}</span>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</Base>

<style>
  .edition-content {
    margin-top: 28px;
  }

  /* Prose styles */
  .prose :global(h1) { font-size: clamp(1.4rem, 4vw, 2rem); margin: 32px 0 16px; }
  .prose :global(h2) { font-size: clamp(1.2rem, 3.5vw, 1.5rem); margin: 28px 0 12px; }
  .prose :global(h3) { font-size: clamp(1rem, 3vw, 1.2rem); margin: 24px 0 8px; }
  .prose :global(p) { line-height: 1.7; margin-bottom: 16px; }
  .prose :global(ul), .prose :global(ol) { padding-left: 20px; margin-bottom: 16px; }
  .prose :global(li) { margin-bottom: 6px; line-height: 1.6; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-gold); padding-left: 16px;
    color: var(--color-muted); font-style: italic; margin: 16px 0;
  }
  .prose :global(hr) { border: none; border-top: 1px solid rgba(139,26,43,0.15); margin: 24px 0; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(a) { color: var(--color-accent-1); }
  .prose :global(a:hover) { color: var(--color-accent-2); }

  /* Standings */
  .standings {
    margin-top: 32px;
  }
  .standings-title {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }
  .standings-frame {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .standings-frame iframe {
    width: 100%;
    min-height: 500px;
    border: none;
    background: var(--color-surface);
  }
</style>
