---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import TournamentPage from '../components/TournamentPage.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../data/pages';

const page = mainPages.find(p => p.slug === 'grand-prix')!;
const posts = (await getCollection('blog'))
  .filter(p => p.data.category === page.category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title={page.titleIt} description={page.descriptionIt}>
  <PageHero title={page.titleIt} image={page.headerImage} />
  <TournamentPage posts={posts} leadHtml={page.leadHtmlIt!} editionsTitle={page.editionsTitleIt!} baseUrl={page.baseUrlIt!} />
</Base>
