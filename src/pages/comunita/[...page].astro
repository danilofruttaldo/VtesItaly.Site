---
import '../../styles/community-page.css';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';
import { filterByLocale, useTranslations } from '../../utils/i18n';

const t = useTranslations('it');

export const getStaticPaths = (async ({ paginate }) => {
  const posts = filterByLocale(await getCollection('blog'), 'it')
    .filter(p => p.data.category === 'comunita')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  return paginate(posts, { pageSize: 8 });
}) satisfies GetStaticPaths;

const pageMeta = mainPages.find(p => p.slug.it === 'comunita')!;
const { page } = Astro.props;

---
<Base title={pageMeta.title.it} description={pageMeta.description.it} noindex={page.currentPage > 1}>
  <img src={pageMeta.headerImage} alt={pageMeta.title.it} class="hero-banner" decoding="async" fetchpriority="high" />
  <section class="hero-text">
    <div class="container container--narrow">
      <h1>{pageMeta.title.it}</h1>
      <p class="hero-text__subtitle">{t.community.subtitle}</p>
    </div>
  </section>
  <section class="section"><div class="container container--narrow">

    <div class="post-list">
      {page.data.map(post => (
        <PostCard
          href={`/${post.data.category}/${post.slug}/`}
          title={post.data.title}
          image={post.data.featuredImage || post.data.poster}
          isPoster={!post.data.featuredImage && !!post.data.poster}
          date={post.data.date}
          tags={post.data.tags}
          excerpt={post.data.excerpt}
          locale="it"
        />
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label={t.community.pagination}>
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination__link">&larr; {t.community.previous}</a>
        ) : (
          <span class="pagination__link pagination__link--disabled">&larr; {t.community.previous}</span>
        )}
        <span class="pagination__info">{t.community.page_info.replace('%current%', String(page.currentPage)).replace('%last%', String(page.lastPage))}</span>
        {page.url.next ? (
          <a href={page.url.next} class="pagination__link">{t.community.next} &rarr;</a>
        ) : (
          <span class="pagination__link pagination__link--disabled">{t.community.next} &rarr;</span>
        )}
      </nav>
    )}
    <ShareButtons />
  </div></section>
</Base>

