---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'grand-prix')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title="Grand Prix" description="The Italian Grand Prix of Vampire: The Eternal Struggle, the most anticipated tournament of the season.">
  <PageHero title="Grand Prix" image="/images/headers/header-grand-prix.webp" />
  <section class="section"><div class="container container--narrow">
    <p class="lead">The <strong>Italian Grand Prix</strong> of Vampire: The Eternal Struggle is the <strong>most anticipated tournament event</strong> of the Italian season. A key fixture in the European circuit, open to all Methuselahs ready to test themselves through <strong>intrigue</strong>, <strong>fragile alliances</strong> and <strong>plot twists</strong>.</p>
    <p>Bring your deck, sharpen your strategies… and prepare to claim power in the <strong>eternal struggle for domination</strong>.</p>

    <hr class="divider" />

    <h2 class="section-title">Grand Prix Editions</h2>
    <div class="editions-list">
      {posts.map(post => (
        <a href={`/en/grand-prix/${post.slug}/`} class="edition-card">
          <span class="edition-year">{new Date(post.data.date).getFullYear()}</span>
          <span class="edition-label">{post.data.title}</span>
        </a>
      ))}
    </div>
  </div></section>
</Base>

<style>
  .section { padding: 40px clamp(20px, 5vw, 80px) 48px; }
  .section-title { font-size: clamp(1.2rem, 3.5vw, 1.5rem); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 0.5px; }
  .lead { font-size: clamp(0.95rem, 3vw, 1.05rem); line-height: 1.7; }
  .divider { border: none; border-top: 1px solid var(--color-accent-light); margin: 32px 0; }
  .editions-list { display: flex; flex-direction: column; gap: 12px; }
  .edition-card {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 20px; border-radius: var(--radius);
    border: 1px solid var(--color-border);
    text-decoration: none; color: var(--color-contrast);
    transition: background-color 0.2s ease, transform 0.15s ease;
  }
  .edition-card:hover { background-color: rgba(255,255,255,0.04); transform: translateX(2px); color: var(--color-contrast); }
  .edition-year { font-size: 1.5rem; font-weight: 700; color: var(--color-gold); min-width: 60px; }
  .edition-label { font-size: 1rem; font-weight: 600; }
</style>
