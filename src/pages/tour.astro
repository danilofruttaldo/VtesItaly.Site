---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TourEdition from '../components/TourEdition.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../data/pages';
import { filterByLocale, useTranslations, formatLocalDate } from '../utils/i18n';

const t = useTranslations('it');

const page = mainPages.find(p => p.slug.it === 'tour')!;
const posts = filterByLocale(await getCollection('blog'), 'it')
  .filter(p => p.data.category === page.category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const current = posts.find(p => p.data.stages && p.data.stages.length > 0 && !p.data.stages.every(s => s.status === 'completed'));
const pastEditions = posts.filter(p => p !== current);
---
<Base title={page.title.it} description={page.description.it}>
  <PageHero title={page.title.it} image={page.headerImage} />

  <section class="page-section">
    <div class="container container--narrow">
      <div class="intro-lead">
        <Fragment set:html={page.leadHtml.it!} />
      </div>
    </div>
  </section>

  {current && (
    <section class="page-section">
      <div class="container container--narrow">
        <div class="edition-header">
          <h2 class="edition-title">{current.data.title}</h2>
          <span class="edition-label-tag">{t.tour.ongoing_label}</span>
        </div>
        <TourEdition post={current} />
      </div>
    </section>
  )}

  {pastEditions.length > 0 && (
    <section class="page-section">
      <div class="container container--narrow">
        <h2 class="page-section-title">{t.tour.archive}</h2>
        <div class="editions-list">
          {pastEditions.map(post => (
            <a href={`/tour/${post.slug}/`} class="edition-card">
              <span class="edition-year">{new Date(post.data.date).getFullYear()}</span>
              {post.data.stages && post.data.stages.length > 0 && (() => {
                const stg = post.data.stages!;
                const citiesCount = new Set(stg.flatMap(s => s.cities)).size;
                const first = formatLocalDate(stg[0].date, 'it', { day: 'numeric', month: 'short' });
                const last = formatLocalDate(stg[stg.length - 1].date, 'it', { day: 'numeric', month: 'short' });
                return (
                  <span class="edition-info">{stg.length} {t.tour.stages_unit} &middot; {citiesCount} {t.tour.cities_unit} &middot; {first} — {last}</span>
                );
              })()}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  <section class="page-section"><div class="container container--narrow"><ShareButtons /></div></section>
</Base>

<style>
  .intro-lead :global(p) {
    color: var(--color-muted);
    text-align: justify;
  }
  .edition-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .edition-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.25);
    border-color: rgba(255,255,255,0.12);
  }
  .edition-year {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-gold);
  }
  .edition-info {
    font-size: 0.75rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }
  .edition-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 24px;
  }
  .edition-label-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-gold);
    background: rgba(201,168,76,0.12);
    padding: 4px 12px;
    border-radius: var(--radius);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .edition-title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    letter-spacing: 0.5px;
  }
</style>
