---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import CityCard from '../../components/CityCard.astro';
import { cities } from '../../data/cities';
---

<Base title="Principati" description="Le citta dove si gioca a VTES in Italia.">
  <PageHero title="Principati" image="/images/headers/header-principati.webp" />

  <section class="section">
    <div class="container">
      <h1 class="section-title">Principati</h1>
      <p class="section-subtitle">Le citta dove si gioca a VTES in Italia. Ogni principato ha il suo Principe, un punto di riferimento per la community locale.</p>
      <div class="principati-grid">
        {cities.map(city => (
          <CityCard
            name={city.name}
            href={`/principati/${city.slug}/`}
            princeName={city.prince.name}
            princeAlias={city.prince.alias}
            princeImage={city.prince.image}
          />
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .section { padding: 40px clamp(16px, 4vw, 60px) 48px; }
  .section-title { text-align: center; font-size: clamp(1.4rem, 4vw, 2rem); text-transform: uppercase; margin-bottom: 12px; }
  .section-subtitle { text-align: center; color: var(--color-muted); font-size: clamp(0.875rem, 3vw, 1rem); line-height: 1.6; margin-bottom: 32px; }
  .principati-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  @media (min-width: 600px) { .principati-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .principati-grid { grid-template-columns: repeat(4, 1fr); } }
</style>
