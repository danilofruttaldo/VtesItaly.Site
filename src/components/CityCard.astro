---
interface Props {
  name: string;
  href: string;
  princeName: string;
  princeAlias: string;
  princeImage: string;
}

const { name, href, princeName, princeAlias, princeImage } = Astro.props;
---

<a href={href} class="city-card">
  <img src={princeImage} alt={princeName} class="city-card__avatar" loading="lazy" decoding="async" />
  <h3 class="city-card__title">{name}</h3>
  <p class="city-card__prince">{princeName}<br /><em>{princeAlias}</em></p>
</a>

<style>
  .city-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 16px 12px;
    background-color: var(--color-card);
    border: 1px solid var(--color-accent-light);
    border-radius: 12px;
    text-align: center;
    text-decoration: none;
    color: var(--color-contrast);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .city-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent-hover);
    color: var(--color-contrast);
  }

  .city-card__avatar {
    width: 90px;
    height: 90px;
    border-radius: 16px;
    object-fit: cover;
  }

  .city-card__title {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .city-card__prince {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }

  @media (max-width: 399px) {
    .city-card { padding: 12px 8px; gap: 8px; }
    .city-card__avatar { width: 64px; height: 64px; }
    .city-card__title { font-size: 0.9rem; }
    .city-card__prince { font-size: 0.72rem; }
  }
</style>
