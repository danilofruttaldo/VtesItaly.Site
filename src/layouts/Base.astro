---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import Lightbox from '../components/Lightbox.astro';
import JsonLd from '../components/JsonLd.astro';
import LangChooser from '../components/LangChooser.astro';
import { getLocaleFromUrl, getAlternateUrl, useTranslations, getOtherLocales } from '../utils/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const {
  title,
  description = t.default_description,
  ogImage = '/images/og/og-default.webp',
  noindex = false,
} = Astro.props;
const otherLocales = getOtherLocales(locale);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const altUrlForRedirect = getAlternateUrl(Astro.url, otherLocales[0]);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | VTES Italy</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl.href} />
    {
      otherLocales.map((alt) => (
        <link rel="alternate" hreflang={alt} href={new URL(getAlternateUrl(Astro.url, alt), Astro.site).href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={canonicalUrl.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | VTES Italy`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={t.og_locale} />
    <meta property="og:site_name" content="VTES Italy" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:alt" content={`${title} | VTES Italy`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | VTES Italy`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:image:alt" content={`${title} | VTES Italy`} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#121416" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Font preload (eliminates discovery delay) -->
    <link rel="preload" href="/fonts/manrope-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/logo-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <JsonLd
      data={{
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'VTES Italy',
        url: Astro.site?.href,
        logo: new URL('/images/logo.webp', Astro.site).href,
        description: t.default_description,
        sameAs: [
          'https://www.facebook.com/groups/115874240013',
          'https://www.instagram.com/vtes.italy',
          'https://www.youtube.com/@VtesItaly',
          'https://t.me/+i_YymbZgFS84YzRk',
        ],
      }}
    />
    <slot name="head" />
    <!-- Early lang redirect (before body renders to avoid flash) -->
    <script is:inline define:vars={{ currentLocale: locale, altUrl: altUrlForRedirect }}>
      (function () {
        try {
          var saved = localStorage.getItem('vtesitaly-lang');
          if (saved && (saved === 'it' || saved === 'en') && saved !== currentLocale) {
            location.replace(altUrl);
          }
        } catch {
          /* storage unavailable */
        }
      })();
    </script>
  </head>
  <body>
    <noscript><p style="text-align:center;padding:1em;color:#9b9b9b;">{t.noscript}</p></noscript>
    <a href="#main-content" class="sr-only">{t.skip_to_content}</a>
    <Header />
    <main id="main-content" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <SearchOverlay />
    <LangChooser />
    <Lightbox />
    <button
      type="button"
      id="back-to-top"
      class="back-to-top"
      aria-label={t.post.back_to_top}
      title={t.post.back_to_top}
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
    <script is:inline define:vars={{ swUpdate: t.sw_update }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', async () => {
          function showUpdateBanner() {
            if (document.getElementById('sw-update')) return;
            const bar = document.createElement('div');
            bar.id = 'sw-update';
            bar.className = 'sw-update';
            bar.setAttribute('role', 'status');
            bar.setAttribute('aria-live', 'polite');
            const msg = document.createElement('span');
            msg.textContent = swUpdate.title;
            const reload = document.createElement('button');
            reload.type = 'button';
            reload.className = 'sw-update-btn';
            reload.textContent = swUpdate.reload;
            reload.addEventListener('click', () => window.location.reload());
            const dismiss = document.createElement('button');
            dismiss.type = 'button';
            dismiss.className = 'sw-update-dismiss';
            dismiss.setAttribute('aria-label', swUpdate.dismiss);
            dismiss.textContent = '×';
            dismiss.addEventListener('click', () => bar.remove());
            bar.append(msg, reload, dismiss);
            document.body.appendChild(bar);
          }
          try {
            const reg = await navigator.serviceWorker.register('/sw.js');
            reg.addEventListener('updatefound', () => {
              const worker = reg.installing;
              if (!worker) return;
              worker.addEventListener('statechange', () => {
                if (worker.state === 'installed' && navigator.serviceWorker.controller) {
                  showUpdateBanner();
                }
              });
            });
            navigator.serviceWorker.addEventListener('controllerchange', () => {
              if (!document.getElementById('sw-update')) showUpdateBanner();
            });
          } catch {
            /* SW registration is best-effort */
          }
        });
      }
    </script>
    <script is:inline>
      (function () {
        var btn = document.getElementById('back-to-top');
        if (!btn) return;
        var visible = false;
        function toggle() {
          var show = window.scrollY > 400;
          if (show !== visible) {
            visible = show;
            btn.classList.toggle('back-to-top--visible', show);
          }
        }
        window.addEventListener('scroll', toggle, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        toggle();
      })();
    </script>
    <script is:inline>
      // Client-side mirrors of computeEventStatus/computeTourStatus from
      // src/utils/status.ts. Required because this script runs after page
      // hydration to recompute statuses against the user's local "today"
      // (the server-rendered status uses build-time today and would go
      // stale on cached HTML). Keep the logic in sync with status.ts;
      // stages here arrive already serialized as { date, cancelled } from
      // src/pages/[...slug].astro:tourStagesJson.
      (function () {
        var now = new Date();
        var todayISO =
          now.getFullYear() +
          '-' +
          String(now.getMonth() + 1).padStart(2, '0') +
          '-' +
          String(now.getDate()).padStart(2, '0');

        function computeEvent(dateStr) {
          if (dateStr === todayISO) return 'live';
          return dateStr > todayISO ? 'upcoming' : 'past';
        }

        function computeTour(stages) {
          var active = stages.filter(function (s) {
            return !s.cancelled;
          });
          if (active.length === 0) return null;
          var statuses = active.map(function (s) {
            return s.date < todayISO ? 'completed' : 'future';
          });
          if (
            statuses.every(function (s) {
              return s === 'completed';
            })
          )
            return 'past';
          if (
            statuses.every(function (s) {
              return s === 'future';
            })
          )
            return 'upcoming';
          return 'live';
        }

        function applyStatus(el, status) {
          if (!status) {
            el.style.display = 'none';
            return;
          }
          el.textContent = el.getAttribute('data-label-' + status) || status;
          if (el.classList.contains('post__status')) {
            el.classList.remove('post__status--active', 'post__status--finished');
            el.classList.add(status === 'past' ? 'post__status--finished' : 'post__status--active');
          }
        }

        // Single-date events
        document.querySelectorAll('[data-event-date]').forEach(function (el) {
          applyStatus(el, computeEvent(el.getAttribute('data-event-date')));
        });

        // Tour (multi-stage)
        document.querySelectorAll('[data-tour-stages]').forEach(function (el) {
          try {
            var stages = JSON.parse(el.getAttribute('data-tour-stages') || '[]');
            applyStatus(el, computeTour(stages));
          } catch {
            /* malformed data */
          }
        });

        // Timeline window: pick 5 cards centered on real-today pivot, shipping
        // the rest of the timeline inside a <template data-timeline-overflow>
        // so they're parsed but inert (don't count toward Lighthouse DOM size
        // and don't trigger <img> loads). Cards move between container and
        // template as the pivot shifts away from the build-time window.
        document.querySelectorAll('[data-temporal-window]').forEach(function (container) {
          var template = container.querySelector('template[data-timeline-overflow]');
          var visible = Array.prototype.slice.call(container.querySelectorAll(':scope > .post-card[data-date]'));
          var overflow = template
            ? Array.prototype.slice.call(template.content.querySelectorAll('.post-card[data-date]'))
            : [];
          var all = visible.concat(overflow);
          if (all.length === 0) return;
          all.sort(function (a, b) {
            var da = a.getAttribute('data-date') || '';
            var db = b.getAttribute('data-date') || '';
            return da < db ? -1 : da > db ? 1 : 0;
          });

          // Reset highlight markers on every card (visible + overflow)
          all.forEach(function (c) {
            c.classList.remove('post-card--highlight');
            var b = c.querySelector('.post-card__highlight-badge');
            if (b) b.hidden = true;
          });

          var pivot = -1;
          for (var i = 0; i < all.length; i++) {
            if ((all[i].getAttribute('data-date') || '') >= todayISO) {
              pivot = i;
              break;
            }
          }
          var chosen;
          if (pivot === -1) {
            chosen = all.slice(-5).reverse();
          } else {
            var idealAbove = 2;
            var idealBelow = 2;
            var above = all.slice(pivot + 1, pivot + 1 + idealAbove);
            var below = all.slice(Math.max(0, pivot - idealBelow), pivot);
            var aboveShort = idealAbove - above.length;
            var belowShort = idealBelow - below.length;
            if (aboveShort > 0) below = all.slice(Math.max(0, pivot - idealBelow - aboveShort), pivot);
            if (belowShort > 0) above = all.slice(pivot + 1, pivot + 1 + idealAbove + belowShort);
            chosen = above.slice().reverse().concat([all[pivot]], below.slice().reverse());
            all[pivot].classList.add('post-card--highlight');
            var pivotBadge = all[pivot].querySelector('.post-card__highlight-badge');
            if (pivotBadge) pivotBadge.hidden = false;
          }

          // Move visible cards not in `chosen` into the template (parks them).
          var chosenSet = chosen.reduce(function (m, c) {
            m.set(c, true);
            return m;
          }, new Map());
          if (template) {
            visible.forEach(function (c) {
              if (!chosenSet.get(c)) template.content.appendChild(c);
            });
          }
          // Append chosen cards to the container in visual order; this moves
          // them out of the template if needed and reorders existing ones.
          chosen.forEach(function (c) {
            container.appendChild(c);
          });
          // Keep the template as the last child so its position is stable.
          if (template && container.lastChild !== template) container.appendChild(template);
        });

        // Past divider: in [data-temporal-divider] containers, position the
        // .post-list__divider between future (top) and past (bottom) cards.
        // Cards are sorted descending (newest first).
        document.querySelectorAll('[data-temporal-divider]').forEach(function (container) {
          var divider = container.querySelector('.post-list__divider');
          if (!divider) return;
          var cards = Array.prototype.slice.call(container.querySelectorAll('.post-card[data-date]'));
          if (cards.length === 0) {
            divider.hidden = true;
            return;
          }
          var firstPast = -1;
          for (var j = 0; j < cards.length; j++) {
            if ((cards[j].getAttribute('data-date') || '') < todayISO) {
              firstPast = j;
              break;
            }
          }
          if (firstPast <= 0) {
            // No past on this page, OR all cards are past (no future above) → no divider.
            divider.hidden = true;
          } else {
            divider.hidden = false;
            var target = cards[firstPast];
            if (divider.nextSibling !== target) container.insertBefore(divider, target);
          }
        });

        // Next-event highlight: cards in [data-temporal-next-event] are sorted
        // future-first then past. Highlight the last future card (just before the
        // first past). If all future, highlight the very last; if all past, none.
        document.querySelectorAll('[data-temporal-next-event]').forEach(function (container) {
          var cards = Array.prototype.slice.call(container.querySelectorAll('.post-card[data-date]'));
          cards.forEach(function (c) {
            c.classList.remove('post-card--highlight');
            var b = c.querySelector('.post-card__highlight-badge');
            if (b) b.hidden = true;
          });
          if (cards.length === 0) return;
          var firstPast = -1;
          for (var k = 0; k < cards.length; k++) {
            if ((cards[k].getAttribute('data-date') || '') < todayISO) {
              firstPast = k;
              break;
            }
          }
          var idx;
          if (firstPast === -1) idx = cards.length - 1;
          else if (firstPast === 0) idx = -1;
          else idx = firstPast - 1;
          if (idx >= 0) {
            cards[idx].classList.add('post-card--highlight');
            var b2 = cards[idx].querySelector('.post-card__highlight-badge');
            if (b2) b2.hidden = false;
          }
        });

        // Pricing column highlight in [data-temporal-pricing]. Toggles
        // gp-price-active / gp-price-inactive on .gp-price-cell--early and
        // .gp-price-cell--regular based on today vs deadline + last-event date.
        document.querySelectorAll('[data-temporal-pricing]').forEach(function (table) {
          var lastEventDate = table.getAttribute('data-event-last-date') || '';
          var earlyDeadlineDate = table.getAttribute('data-early-deadline-date') || '';
          if (!lastEventDate) return;
          var eventFinished = todayISO >= lastEventDate;
          var earlyActive = !eventFinished && (!earlyDeadlineDate || todayISO < earlyDeadlineDate);
          var regularActive = !eventFinished && !earlyActive;
          function applyPrice(selector, active) {
            table.querySelectorAll(selector).forEach(function (el) {
              el.classList.remove('gp-price-active', 'gp-price-inactive');
              el.classList.add(active ? 'gp-price-active' : 'gp-price-inactive');
            });
          }
          applyPrice('.gp-price-cell--early', earlyActive);
          applyPrice('.gp-price-cell--regular', regularActive);
        });

        // Footer copyright year
        var copy = document.querySelector('.footer-bottom p');
        if (copy) copy.textContent = copy.textContent.replace(/–\d{4}/, '–' + now.getFullYear());
      })();
    </script>
  </body>
</html>
