---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../utils/i18n';
import { useTranslations } from '../utils/i18n';

interface Props {
  posts: CollectionEntry<'blog'>[];
  leadHtml: string;
  editionsTitle: string;
  baseUrl: string;
  locale?: Locale;
}

const { posts, leadHtml, editionsTitle, baseUrl, locale = 'it' } = Astro.props;
const t = useTranslations(locale);

// Current edition = most recent post
const current = posts[0];
const { Content: CurrentContent } = current ? await current.render() : { Content: null };
const pastEditions = posts.slice(1);

// Build gallery for current edition
let galleryImages: string[] = [];
if (current) {
  galleryImages = current.data.gallery || [];
  if (current.data.galleryFolder && galleryImages.length === 0) {
    const folder = current.data.galleryFolder.replace(/^\//, '').replace(/\/$/, '');
    const allImages = import.meta.glob('/public/images/gallery/**/*.{webp,jpg,jpeg,png}');
    galleryImages = Object.keys(allImages)
      .filter(p => p.includes(`/${folder}/`))
      .map(p => p.replace('/public', ''))
      .sort();
  }
}
---

<section class="page-section">
  <div class="container container--narrow">
    <Fragment set:html={leadHtml} />

    {/* Current edition */}
    {current && (
      <>
        <hr class="page-divider" />

        <h2 class="page-section-title">{current.data.title}</h2>

        {CurrentContent && (
          <div class="edition-content prose">
            <CurrentContent />
          </div>
        )}

        {galleryImages.length > 0 && (
          <section class="edition-gallery">
            <h3 class="edition-gallery-title">{t.post.gallery}</h3>
            <div class="edition-gallery-grid">
              {galleryImages.map((img, i) => (
                <a href={img} class="edition-gallery-item" target="_blank" rel="noopener noreferrer">
                  <img src={img} alt={`${current.data.title} — ${t.post.photo} ${i + 1}`} loading="lazy" decoding="async" />
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    )}

    {/* Past editions */}
    {pastEditions.length > 0 && (
      <>
        <hr class="page-divider" />
        <h2 class="page-section-title">{editionsTitle}</h2>
        <div class="editions-list">
          {pastEditions.map(post => (
            <a href={`${baseUrl}${post.slug}/`} class="edition-card">
              <span class="edition-year">{new Date(post.data.date).getFullYear()}</span>
              <span class="edition-label">{post.data.title}</span>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</section>

<style>
  .edition-content {
    margin-top: 28px;
  }

  /* Prose styles */
  .prose :global(h1) { font-size: clamp(1.4rem, 4vw, 2rem); margin: 32px 0 16px; }
  .prose :global(h2) { font-size: clamp(1.2rem, 3.5vw, 1.5rem); margin: 28px 0 12px; }
  .prose :global(h3) { font-size: clamp(1rem, 3vw, 1.2rem); margin: 24px 0 8px; }
  .prose :global(p) { line-height: 1.7; margin-bottom: 16px; }
  .prose :global(ul), .prose :global(ol) { padding-left: 20px; margin-bottom: 16px; }
  .prose :global(li) { margin-bottom: 6px; line-height: 1.6; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-gold); padding-left: 16px;
    color: var(--color-muted); font-style: italic; margin: 16px 0;
  }
  .prose :global(hr) { border: none; border-top: 1px solid rgba(139,26,43,0.15); margin: 24px 0; }
  .prose :global(img) { max-width: 100%; border-radius: var(--radius); margin: 16px 0; }
  .prose :global(a) { color: var(--color-accent-1); }
  .prose :global(a:hover) { color: var(--color-accent-2); }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 16px 0; }
  .prose :global(th), .prose :global(td) {
    padding: 8px 12px; border: 1px solid var(--color-border); text-align: left;
  }
  .prose :global(th) { font-weight: 600; background-color: var(--color-surface); }

  /* Gallery */
  .edition-gallery { margin-top: 32px; }
  .edition-gallery-title {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }
  .edition-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 8px;
  }
  .edition-gallery-item {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .edition-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .edition-gallery-item:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 544px) {
    .edition-gallery-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  }
</style>
