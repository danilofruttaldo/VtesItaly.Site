---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getCollection } from 'astro:content';
import { categoryLabels, categoryUrls } from '../../data/categories';
import { cities } from '../../data/cities';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: `${post.data.category}/${post.slug}` },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Build gallery: explicit list or auto-glob from folder
let galleryImages: string[] = post.data.gallery || [];
if (post.data.galleryFolder && galleryImages.length === 0) {
  const folder = post.data.galleryFolder.replace(/^\//, '').replace(/\/$/, '');
  const allImages = import.meta.glob('/public/images/gallery/**/*.{webp,jpg,jpeg,png}');
  galleryImages = Object.keys(allImages)
    .filter(p => p.includes(`/${folder}/`))
    .map(p => p.replace('/public', ''))
    .sort();
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

const label = categoryLabels[post.data.category]?.en || post.data.category;
const backUrl = categoryUrls[post.data.category]?.en || '/en/community/';
const backLabel = categoryLabels[post.data.category]?.en || 'Community';

// Map city slugs to their domain page
const cityMap = new Map(cities.map(c => [c.slug, { name: c.nameEn, url: `/en/domains/${c.slugEn}/` }]));

// Build share URLs
const pageUrl = new URL(`en/${post.data.category}/${post.slug}/`, Astro.site).href;
const shareTitle = post.data.title;
---
<Base title={post.data.title} description={post.data.excerpt || post.data.title} ogImage={post.data.featuredImage}>
  <JsonLd slot="head" data={{
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    datePublished: post.data.date.toISOString(),
    description: post.data.excerpt || post.data.title,
    ...(post.data.featuredImage ? { image: new URL(post.data.featuredImage, Astro.site).href } : {}),
    publisher: { '@type': 'Organization', name: 'VTES Italy', logo: { '@type': 'ImageObject', url: new URL('/images/logo.jpeg', Astro.site).href } }
  }} />

  <article class="post">
    {/* Hero image — full width */}
    {post.data.featuredImage && (
      <div class="post__hero-wrap">
        <img src={post.data.featuredImage} alt={post.data.title} class="post__hero" loading="eager" decoding="async" />
        <div class="post__hero-overlay"></div>
      </div>
    )}

    <div class="container container--narrow">
      {/* Back link */}
      <a href={backUrl} class="post__back">&larr; {backLabel}</a>

      {/* Title & description */}
      <header class="post__header">
        <h1 class="post__title">{post.data.title}</h1>
        {post.data.excerpt && (
          <p class="post__excerpt">{post.data.excerpt}</p>
        )}
      </header>

      {/* Metadata: category, date, tags */}
      <div class="post__meta">
        <span class="post__category">{label}</span>
        <time class="post__date" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post__tags">
            {post.data.tags.map(tag => {
              const city = cityMap.get(tag);
              return city ? (
                <a href={city.url} class="post__tag post__tag--city">{city.name}</a>
              ) : (
                <span class="post__tag">{tag}</span>
              );
            })}
          </div>
        )}
      </div>

      <hr class="post__divider" />

      {/* Article content */}
      <div class="post__content prose">
        <Content />
      </div>

      {/* Image gallery */}
      {galleryImages.length > 0 && (
        <section class="post__gallery">
          <h2 class="post__gallery-title">Gallery</h2>
          <div class="post__gallery-grid">
            {galleryImages.map((img, i) => (
              <a href={img} class="post__gallery-item" data-gallery target="_blank" rel="noopener noreferrer">
                <img src={img} alt={`${post.data.title} — photo ${i + 1}`} loading="lazy" decoding="async" />
              </a>
            ))}
          </div>
        </section>
      )}

      <hr class="post__divider" />

      {/* Social sharing */}
      <div class="post__share">
        <span class="post__share-label">Share</span>
        <div class="post__share-buttons">
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener noreferrer" class="post__share-btn post__share-btn--fb" title="Share on Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(shareTitle)}`} target="_blank" rel="noopener noreferrer" class="post__share-btn post__share-btn--x" title="Share on X">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(shareTitle + ' ' + pageUrl)}`} target="_blank" rel="noopener noreferrer" class="post__share-btn post__share-btn--wa" title="Share on WhatsApp">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <button class="post__share-btn post__share-btn--copy" title="Copy link" data-url={pageUrl}>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          </button>
        </div>
      </div>

      {/* Footer */}
      <div class="post__footer">
        <a href={backUrl} class="btn">&larr; {backLabel}</a>
      </div>
    </div>
  </article>
</Base>

<script>
  document.querySelectorAll('.post__share-btn--copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = (btn as HTMLElement).dataset.url;
      if (url) {
        await navigator.clipboard.writeText(url);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 2000);
      }
    });
  });
</script>

<style>
  /* Hero */
  .post__hero-wrap {
    position: relative;
    width: 100%;
    max-height: 420px;
    overflow: hidden;
  }
  .post__hero {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }
  .post__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, var(--color-base) 100%);
  }

  /* Layout */
  .post { padding-bottom: 48px; }

  /* Back link */
  .post__back {
    display: inline-block;
    margin-top: 24px;
    margin-bottom: 16px;
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
  }
  .post__back:hover { color: var(--color-accent-1); }

  /* Header: title + excerpt */
  .post__header { margin-bottom: 16px; }
  .post__title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .post__excerpt {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Meta: category, date, tags */
  .post__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .post__category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-gold);
    background: rgba(201,168,76,0.1);
    padding: 2px 8px;
    border-radius: var(--radius);
  }
  .post__date { font-size: 0.8rem; color: var(--color-muted); }
  .post__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-left: auto;
  }
  .post__tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: var(--radius);
    background: var(--color-accent-light);
    color: var(--color-accent-1);
  }
  .post__tag--city {
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  .post__tag--city:hover {
    background: rgba(139,26,43,0.25);
    color: var(--color-accent-2);
  }

  /* Divider */
  .post__divider {
    border: none;
    border-top: 1px solid rgba(139,26,43,0.15);
    margin: 24px 0;
  }

  /* Prose styles for markdown content */
  .prose :global(h1) { font-size: clamp(1.4rem, 4vw, 2rem); margin: 32px 0 16px; }
  .prose :global(h2) { font-size: clamp(1.2rem, 3.5vw, 1.5rem); margin: 28px 0 12px; }
  .prose :global(h3) { font-size: clamp(1rem, 3vw, 1.2rem); margin: 24px 0 8px; }
  .prose :global(p) { line-height: 1.7; margin-bottom: 16px; }
  .prose :global(ul), .prose :global(ol) { padding-left: 20px; margin-bottom: 16px; }
  .prose :global(li) { margin-bottom: 6px; line-height: 1.6; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-gold); padding-left: 16px;
    color: var(--color-muted); font-style: italic; margin: 16px 0;
  }
  .prose :global(hr) { border: none; border-top: 1px solid rgba(139,26,43,0.15); margin: 24px 0; }
  .prose :global(img) { max-width: 100%; border-radius: var(--radius); margin: 16px 0; }
  .prose :global(a) { color: var(--color-accent-1); }
  .prose :global(a:hover) { color: var(--color-accent-2); }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 16px 0; }
  .prose :global(th), .prose :global(td) {
    padding: 8px 12px; border: 1px solid var(--color-border); text-align: left;
  }
  .prose :global(th) { font-weight: 600; background-color: var(--color-surface); }

  /* Gallery */
  .post__gallery { margin-top: 32px; }
  .post__gallery-title {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }
  .post__gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 8px;
  }
  .post__gallery-item {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .post__gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .post__gallery-item:hover img {
    transform: scale(1.05);
  }

  /* Social sharing */
  .post__share {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .post__share-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-muted);
  }
  .post__share-buttons {
    display: flex;
    gap: 8px;
  }
  .post__share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    background: none;
    padding: 0;
  }
  .post__share-btn:hover { border-color: var(--color-accent-1); color: var(--color-accent-1); }
  .post__share-btn--fb:hover { color: #1877F2; border-color: #1877F2; }
  .post__share-btn--x:hover { color: var(--color-contrast); border-color: var(--color-contrast); }
  .post__share-btn--wa:hover { color: #25D366; border-color: #25D366; }
  .post__share-btn--copy.copied { color: var(--color-gold); border-color: var(--color-gold); }

  /* Footer */
  .post__footer { text-align: center; }

  @media (max-width: 544px) {
    .post__hero { height: 260px; }
    .post__hero-wrap { max-height: 260px; }
    .post__tags { margin-left: 0; width: 100%; }
    .post__gallery-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  }
</style>
