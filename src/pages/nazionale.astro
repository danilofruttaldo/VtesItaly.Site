---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import ShareButtons from '../components/ShareButtons.astro';
import GpEdition from '../components/GpEdition.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../data/pages';
import { filterByLocale, useTranslations } from '../utils/i18n';
import { computeEventStatus } from '../utils/status';
import { getCardMeta, type Standing } from '../utils/standings';
import '../styles/edition-archive.css';

const t = useTranslations('it');

const page = mainPages.find(p => p.slug.it === 'nazionale')!;
const posts = filterByLocale(await getCollection('blog'), 'it')
  .filter(p => p.data.category === page.category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const now = new Date();
const current = posts.find(p => new Date(p.data.date) >= now) || posts[0];
const pastEditions = posts.filter(p => p !== current);

const ncStatus = current ? computeEventStatus(new Date(current.data.date)) : null;

const allStandings = import.meta.glob('/src/data/standings/nc/standings-nc-*.json', { eager: true }) as Record<string, { default: Standing[] }>;
---
<Base title={page.title.it} description={page.description.it}>
  <PageHero title={page.title.it} image={page.headerImage} />

  {/* Parte fissa: intro */}
  <section class="page-section">
    <div class="container container--narrow">
      <div class="intro-lead">
        <Fragment set:html={page.leadHtml?.it ?? ''} />
      </div>
    </div>
  </section>

  {/* Parte variabile: edizione corrente */}
  {current && (
    <section class="page-section">
      <div class="container container--narrow">
        <div class="edition-header">
          <h2 class="edition-title">{current.data.title}</h2>
          <span class="edition-label-tag">{ncStatus === 'live' ? t.status.live : ncStatus === 'upcoming' ? t.status.upcoming : t.status.past}</span>
        </div>
        <GpEdition post={current} locale="it" />
      </div>
    </section>
  )}

  {/* Parte fissa: archivio + condivisione */}
  {pastEditions.length > 0 && (
    <section class="page-section">
      <div class="container container--narrow">
        <h2 class="page-section-title">{t.gp.archive}</h2>
        <div class="editions-list">
          {pastEditions.map(post => {
            const meta = getCardMeta(post, allStandings);
            return (
            <a href={`/nazionale/${post.id}/`} class="edition-card">
              {(post.data.poster || post.data.featuredImage) && (
                <img src={post.data.poster || post.data.featuredImage} alt={post.data.title} class:list={['edition-thumb', post.data.poster && 'edition-thumb--poster']} loading="lazy" decoding="async" width="64" height="64" />
              )}
              <div class="edition-card-body">
                <div class="edition-card-header">
                  <span class="edition-year">{post.id.match(/\d{4}/)?.[0] ?? new Date(post.data.date).getFullYear()}</span>
                  {meta.winner && (
                    <span class="edition-winner">&#127942; {meta.winner}</span>
                  )}
                </div>
                <span class="edition-info">
                  {post.data.tags && post.data.tags.filter(tag => tag !== 'italia').length > 0 && (
                    <>{post.data.tags.filter(tag => tag !== 'italia').join(', ')}</>
                  )}
                  {meta.eventDate && <> &middot; {meta.eventDate}</>}
                  {meta.players > 0 && <> &middot; {meta.players} {t.gp.players_label}</>}
                </span>
              </div>
            </a>
            );
          })}
        </div>
      </div>
    </section>
  )}
  <section class="page-section"><div class="container container--narrow"><ShareButtons /></div></section>
</Base>
