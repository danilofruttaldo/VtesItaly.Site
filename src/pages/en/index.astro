---
import Base from '../../layouts/Base.astro';
import Calendar from '../../components/Calendar.astro';
import PageHero from '../../components/PageHero.astro';
import PostCard from '../../components/PostCard.astro';
import { cities } from '../../data/cities';
import { getCollection } from 'astro:content';
import { mainPages } from '../../data/pages';
import { filterByLocale, useTranslations } from '../../utils/i18n';
import { getCommunityTimeline, pickTimelineWindow } from '../../utils/calendar';
import { todayLocalIso } from '../../utils/today';

const page = mainPages.find((p) => p.slug.it === '')!;
const t = useTranslations('en');

const posts = filterByLocale(await getCollection('blog'), 'en');
const today = todayLocalIso();
// The visible 5-card window is computed at build time; the rest of the
// timeline ships inside a <template data-timeline-overflow> below so it stays
// parsed but doesn't render and doesn't count toward Lighthouse's DOM budget.
// The runtime in Base.astro swaps cards between the visible window and the
// template when the user's real "today" moves the pivot past the build date.
const fullTimeline = getCommunityTimeline(posts, 'en');
const buildWindow = pickTimelineWindow(fullTimeline, today);
const buildWindowSet = new Set(buildWindow.entries);
---

<Base title={page.title.en} description={page.description.en} ogImage={page.ogImage}>
  <PageHero image={page.headerImage} />

  <section class="hero-text">
    <div class="container container--narrow">
      <h1>{t.home.hero_title}</h1>
      <p class="hero-text__subtitle">{t.home.hero_subtitle}</p>
    </div>
  </section>

  <hr class="divider" />

  <section class="section" id="eventi">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.events_title}</h2>
      <p class="section-subtitle">{t.home.events_subtitle}</p>
      <Calendar />
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.latest_title}</h2>
      <p class="section-subtitle">{t.home.latest_subtitle}</p>
      <div class="post-list" data-temporal-window>
        {
          /* Visible: only the build-time window in visual order. The runtime in
            Base.astro will swap these out (against the inert overflow below) if
            the user's real "today" has moved the pivot since the last deploy. */
          buildWindow.entries.map((entry, i) => (
            <PostCard
              href={entry.url || '#'}
              title={entry.title}
              image={entry.image}
              imageAnchor={entry.imageAnchor}
              date={new Date(entry.date)}
              category={entry.category}
              tags={entry.tags}
              excerpt={entry.excerpt}
              locale="en"
              highlight={i === buildWindow.highlightIndex}
              highlightLabel={t.home.next_event_label}
              eager={i === 0}
            />
          ))
        }
        {
          /* Overflow inside a <template> stays parsed but doesn't render and
            doesn't count toward Lighthouse's DOM size budget. Holds the rest
            of the timeline in chronological order; the runtime hydrates from
            here when the real-today pivot falls outside the visible window. */
        }
        <template data-timeline-overflow>
          {
            fullTimeline
              .filter((entry) => !buildWindowSet.has(entry))
              .map((entry) => (
                <PostCard
                  href={entry.url || '#'}
                  title={entry.title}
                  image={entry.image}
                  imageAnchor={entry.imageAnchor}
                  date={new Date(entry.date)}
                  category={entry.category}
                  tags={entry.tags}
                  excerpt={entry.excerpt}
                  locale="en"
                  highlight={false}
                  highlightLabel={t.home.next_event_label}
                />
              ))
          }
        </template>
      </div>
      <div class="section-cta">
        <a href="/en/community/" class="btn">{t.home.all_articles} &rarr;</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <section class="section">
    <div class="container container--narrow">
      <h2 class="section-title">{t.home.domains_title}</h2>
      <p class="section-subtitle">{t.home.domains_subtitle}</p>
      <div class="cities-quicklinks">
        {cities.map((city) => <a href={`/en/domains/${city.slug.en}/`}>{city.name.en}</a>)}
      </div>
      <div class="section-cta">
        <a href="/en/domains/" class="btn">{t.home.all_domains} &rarr;</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-text {
    padding: 32px 0 8px;
    text-align: center;
  }
  .hero-text h1 {
    font-size: clamp(1.5rem, 5vw, 2.25rem);
    margin-bottom: 16px;
  }
  .hero-text__subtitle {
    color: var(--color-muted);
    font-size: clamp(0.9rem, 3vw, 1.05rem);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .cities-quicklinks {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .cities-quicklinks a {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-small);
    font-weight: 500;
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-accent-1);
    text-decoration: none;
    transition: all 0.2s ease;
    text-align: center;
  }
  .cities-quicklinks a:hover {
    background-color: var(--color-accent-1);
    color: #fff;
    border-color: var(--color-accent-1);
  }

  @media (max-width: 599px) {
    .hero-text {
      padding-inline: 0;
    }
  }
</style>
