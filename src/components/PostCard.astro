---
import type { Locale } from '../utils/i18n';
import { useTranslations, formatLocalDate } from '../utils/i18n';
import { categoryLabels, typeTagLabels } from '../data/categories';
import { thumbFor } from '../utils/image';

interface Props {
  href: string;
  title: string;
  image?: string;
  imageAnchor?: string;
  date?: Date;
  /** Last day of a multi-day event. Emitted as `data-end-date` so the temporal
      runtime keeps the card highlighted for the event's whole run. */
  endDate?: Date;
  category?: string;
  tags?: string[];
  excerpt?: string;
  locale?: Locale;
  highlight?: boolean;
  /** Badge text for an upcoming event ("Prossimo"). */
  highlightLabel?: string;
  /** Badge text for an event in progress ("Oggi"). When set, the runtime
      swaps the badge wording to it once the card's start day arrives. */
  ongoingLabel?: string;
  /** Build-time initial state: the highlighted card is currently in progress. */
  ongoing?: boolean;
  /** Prioritise the image as LCP candidate (above-the-fold cards). */
  eager?: boolean;
  /** Server-side hidden state. The runtime script in Base.astro clears this
      when it re-picks the timeline window against the user's real "today". */
  hidden?: boolean;
}

const {
  href,
  title,
  image,
  imageAnchor,
  date,
  endDate,
  category,
  tags = [],
  excerpt,
  locale = 'it',
  highlight = false,
  highlightLabel,
  ongoingLabel,
  ongoing = false,
  eager = false,
  hidden = false,
} = Astro.props;

const RELEVANT_CATEGORIES = new Set(['tour', 'grand-prix', 'nazionale']);
const categoryAccent = category && RELEVANT_CATEGORIES.has(category) ? `post-card--${category}` : null;
const t = useTranslations(locale);

const typeTags = Object.fromEntries(Object.entries(typeTagLabels).map(([k, v]) => [k, v[locale]]));
const typeTag = tags.find((t) => typeTags[t]);

const badges: { label: string }[] = [];
if (category) {
  const catLabel = categoryLabels[category]?.[locale];
  if (catLabel) badges.push({ label: catLabel });
}
if (typeTag) badges.push({ label: typeTags[typeTag] });

// Local-anchored ISO (YYYY-MM-DD) so the runtime script in Base.astro can compare
// it as a string against today (also local-anchored). Using toISOString() here
// would silently shift dates near midnight in positive-offset timezones.
const isoDate = date
  ? `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`
  : undefined;
const isoEndDate = endDate
  ? `${endDate.getFullYear()}-${String(endDate.getMonth() + 1).padStart(2, '0')}-${String(endDate.getDate()).padStart(2, '0')}`
  : undefined;

// PostCard renders at 120 px (desktop) / 80 px (mobile). `thumbFor` swaps
// the full poster for the 240² `-thumb.webp` emitted by
// scripts/build-thumbnails.mjs, saving ~280 KB per card.
const cardImage = thumbFor(image);
---

<a
  href={href}
  class:list={['post-card', categoryAccent, highlight && 'post-card--highlight']}
  data-date={isoDate}
  data-end-date={isoEndDate}
  hidden={hidden}
>
  {
    /* Badge is always emitted (hidden by default) so the client-side temporal
      runtime can toggle it — and swap between the "next" and "today" label —
      without rebuilding HTML. Same gold styling for both states; only the
      wording changes. */
  }
  {
    highlightLabel && (
      <span
        class="post-card__highlight-badge"
        data-label-next={highlightLabel}
        data-label-ongoing={ongoingLabel}
        hidden={!highlight}
      >
        {highlight && ongoing && ongoingLabel ? ongoingLabel : highlightLabel}
      </span>
    )
  }
  {
    cardImage && (
      <img
        src={cardImage}
        alt={title}
        class="post-card__image"
        loading={eager ? 'eager' : 'lazy'}
        fetchpriority={eager ? 'high' : 'auto'}
        decoding="async"
        width="120"
        height="120"
        style={imageAnchor ? `object-position: ${imageAnchor};` : undefined}
      />
    )
  }
  <div class="post-card__body">
    {
      date && (
        <time class="post-card__date" datetime={date.toISOString()}>
          {formatLocalDate(date, locale)}
        </time>
      )
    }
    {
      badges.length > 0 && (
        <div class="post-card__tags">
          {badges.map((b) => (
            <span class="post-card__tag">{b.label}</span>
          ))}
        </div>
      )
    }
    <span class="post-card__title">{title}</span>
    {excerpt && <p class="post-card__excerpt">{excerpt}</p>}
    <span class="post-card__cta">{t.post.read_cta} &rarr;</span>
  </div>
</a>
