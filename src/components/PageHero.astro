---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

interface Props {
  title: string;
  image?: string;
  breadcrumb?: { label: string; href: string };
}

const { title, image, breadcrumb } = Astro.props;

// Build-time detection of `-2x.webp` retina variants and `.avif` siblings so
// the picture sources only appear when the files actually exist; missing
// variants would otherwise trigger 404s for the browser's source selection.
const has = (relative: string) => existsSync(resolve('public', relative.replace(/^\//, '')));
const webp2x = image?.replace(/\.webp$/, '-2x.webp');
const avif1x = image?.replace(/\.webp$/, '.avif');
const avif2x = image?.replace(/\.webp$/, '-2x.avif');
const webpSrcset = image && webp2x && has(webp2x) ? `${image} 1x, ${webp2x} 2x` : undefined;
const avifSrcset =
  image && avif1x && has(avif1x) ? (avif2x && has(avif2x) ? `${avif1x} 1x, ${avif2x} 2x` : avif1x) : undefined;
---

<section class="page-hero">
  {
    image && (
      <picture>
        {avifSrcset && <source type="image/avif" srcset={avifSrcset} />}
        {webpSrcset && <source type="image/webp" srcset={webpSrcset} />}
        <img src={image} alt={title} class="page-hero__img" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
    )
  }
  <div class="page-hero__overlay"></div>
  <div class="page-hero__content">
    {title && <h1>{title}</h1>}
  </div>
</section>

{
  breadcrumb && (
    <div class="container breadcrumb">
      <a href={breadcrumb.href}>&larr; {breadcrumb.label}</a>
    </div>
  )
}

<style>
  .page-hero {
    position: relative;
    width: 100%;
    /* Match the 1920×420 header source aspect so object-fit:cover has
       nothing to crop — the full image is visible at every viewport
       width. A fixed height would instead crop the sides on any screen
       narrower than 1920px. */
    aspect-ratio: 32 / 7;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface);
  }

  .page-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    /* Darker through the vertical middle where the centered H1 sits —
       several header sources are bright enough there to wash out white
       text. Still fades to --color-base at the bottom to blend into the
       page. The H1 also carries a text-shadow as a second safety net. */
    background: linear-gradient(
      to bottom,
      rgba(18, 20, 22, 0.5) 0%,
      rgba(18, 20, 22, 0.58) 50%,
      var(--color-base) 100%
    );
  }

  .page-hero__content {
    position: relative;
    text-align: center;
    padding: 40px 0;
  }

  .page-hero__content h1 {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-contrast);
    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.85),
      0 0 24px rgba(0, 0, 0, 0.6);
  }

  .breadcrumb {
    padding-top: 12px;
    font-size: var(--font-size-sm);
  }

  .breadcrumb a {
    color: var(--color-muted);
  }

  @media (max-width: 544px) {
    /* On phones the 32:7 ratio would be too short for the title, so
       fall back to a fixed height — this does crop the sides, but the
       image's focal point sits centred. */
    .page-hero {
      aspect-ratio: auto;
      height: 220px;
    }
  }
</style>
