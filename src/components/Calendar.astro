---
import '../styles/calendar.css';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, useTranslations, filterByLocale } from '../utils/i18n';
import { extractCalendarEvents } from '../utils/calendar';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const allPosts = await getCollection('blog');
const posts = filterByLocale(allPosts, locale);
const allEvents = extractCalendarEvents(posts, locale);
---

<div
  class="cal"
  data-locale={locale}
  data-months-json={JSON.stringify(t.months_array)}
  data-no-events={t.calendar.no_events_month}
  data-add-google={t.calendar.add_google}
  data-read-cta={t.post.read_cta}
  data-close-label={t.search.close_label}
  data-cat-labels={JSON.stringify({
    'grand-prix': t.calendar.cat_gp,
    tour: t.calendar.cat_tour,
    nazionale: t.calendar.cat_nc,
    comunita: t.calendar.cat_community,
    local: t.calendar.cat_local,
    altro: t.calendar.legend_other,
  })}
  data-prev-year={t.calendar.prev_year}
  data-next-year={t.calendar.next_year}
  data-tbd={t.calendar.tbd}
  data-server-events={JSON.stringify(allEvents)}
>
  {/* Navigation */}
  <div class="cal__nav">
    <button type="button" class="cal__nav-btn cal__prev" aria-label={t.calendar.prev_month}>&#8249;</button>
    <button
      type="button"
      class="cal__month-title"
      aria-label={t.calendar.select_month}
      aria-haspopup="dialog"
      aria-expanded="false"></button>
    <button type="button" class="cal__nav-btn cal__next" aria-label={t.calendar.next_month}>&#8250;</button>
    <button type="button" class="cal__today-btn">{t.calendar.today}</button>
  </div>

  {/* Day headers */}
  <div class="cal__grid cal__header" role="row">
    {
      [1, 2, 3, 4, 5, 6, 0].map((i) => (
        <span class="cal__dh" role="columnheader">
          {t.days_short_array[i]}
        </span>
      ))
    }
  </div>

  {/* Calendar body — filled by JS */}
  <div class="cal__grid cal__body" id="cal-body" role="grid" aria-label={t.calendar.aria_calendar ?? 'Calendar'}></div>

  {/* Event detail popup */}
  <div class="cal__popup" id="cal-popup" hidden>
    <div
      class="cal__popup-inner"
      id="cal-popup-inner"
      role="dialog"
      aria-modal="true"
      aria-label={t.calendar.event_details ?? 'Event details'}
    >
    </div>
  </div>

  {/* Month/Year picker modal */}
  <div class="cal__picker" id="cal-picker" hidden>
    <div class="cal__picker-inner" role="dialog" aria-modal="true">
      <button
        type="button"
        class="cal__popup-close cal__picker-close"
        id="cal-picker-close"
        aria-label={t.search.close_label}>&times;</button
      >
      <div class="cal__picker-year-nav">
        <button type="button" class="cal__picker-year-btn" id="cal-picker-prev-year" aria-label={t.calendar.prev_year}
          >&#8249;</button
        >
        <span class="cal__picker-year" id="cal-picker-year"></span>
        <button type="button" class="cal__picker-year-btn" id="cal-picker-next-year" aria-label={t.calendar.next_year}
          >&#8250;</button
        >
      </div>
      <div class="cal__picker-months" id="cal-picker-months"></div>
    </div>
  </div>

  {/* Legend */}
  <div class="cal__legend">
    <span class="cal__legend-item"><span class="cal__legend-dot" style="background:#CE2B37"></span>GP</span>
    <span class="cal__legend-item"><span class="cal__legend-dot" style="background:#F0E6D3"></span>NC</span>
    <span class="cal__legend-item"><span class="cal__legend-dot" style="background:#009246"></span>Tour</span>
    <span class="cal__legend-item"
      ><span class="cal__legend-dot" style="background:#4A90D9"></span>{t.calendar.legend_events}</span
    >
    <span class="cal__legend-item"
      ><span class="cal__legend-dot" style="background:#9B59B6"></span>{t.calendar.legend_other}</span
    >
  </div>
</div>

<script>
  // Bundled module (Astro processes <script> without is:inline) so the calendar
  // hydration code is served as a cacheable external file instead of inlining
  // ~270 lines into every page that uses <Calendar />. The HTML payload drops
  // by the same amount without changing visual behavior (the calendar body is
  // still built from JS on load, never SSG'd).
  type CalEvent = {
    date: string;
    endDate?: string;
    time?: string;
    title: string;
    category: string;
    location?: string;
    venue?: string;
    image?: string;
    description?: string;
    format?: string;
    archonUrl?: string;
    url?: string;
    tags?: string[];
  };

  (function () {
    var cal = document.querySelector('.cal');
    if (!cal) return;

    var monthNames: string[] = JSON.parse(cal.getAttribute('data-months-json') || '[]');
    var addGoogle = cal.getAttribute('data-add-google') || '';
    var readCta = cal.getAttribute('data-read-cta') || '';
    var closeLabel = cal.getAttribute('data-close-label') || 'Close';
    var catLabels: Record<string, string> = JSON.parse(cal.getAttribute('data-cat-labels') || '{}');
    var tbdLabel = cal.getAttribute('data-tbd') || 'TBD';

    var events: CalEvent[] = JSON.parse(cal.getAttribute('data-server-events') || '[]');
    var now = new Date();
    var displayYear = now.getFullYear();
    var displayMonth = now.getMonth();

    var body = document.getElementById('cal-body')!;
    var titleEl = cal.querySelector('.cal__month-title')!;
    var popup = document.getElementById('cal-popup')!;
    var popupInner = document.getElementById('cal-popup-inner')!;
    var focusTrapHandler: ((e: KeyboardEvent) => void) | null = null;

    function esc(s: string | null | undefined): string {
      var d = document.createElement('div');
      d.appendChild(document.createTextNode(s || ''));
      return d.innerHTML;
    }

    function eventsForDay(y: number, m: number, d: number): CalEvent[] {
      var k = y + '-' + String(m + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
      return events.filter(function (e) {
        return e.date === k;
      });
    }

    function googleUrl(ev: CalEvent) {
      var d = ev.date.replace(/-/g, '');
      var endStr = ev.endDate || ev.date;
      var parts = endStr.split('-');
      var nd = new Date(Date.UTC(+parts[0], +parts[1] - 1, +parts[2] + 1));
      var dates = d + '/' + nd.toISOString().slice(0, 10).replace(/-/g, '');
      var p = 'action=TEMPLATE&text=' + encodeURIComponent(ev.title) + '&dates=' + dates + '&ctz=Europe/Rome';
      if (ev.location) p += '&location=' + encodeURIComponent(ev.location);
      else if (ev.venue) p += '&location=' + encodeURIComponent(ev.venue);
      return 'https://calendar.google.com/calendar/render?' + p;
    }

    function closePopup() {
      popup.hidden = true;
      if (focusTrapHandler) {
        popupInner.removeEventListener('keydown', focusTrapHandler);
        focusTrapHandler = null;
      }
      popupInner.innerHTML = '';
    }

    function showPopup(ev: CalEvent) {
      var ts = ev.time || '';

      var h = '';
      h += '<button type="button" class="cal__popup-close" aria-label="' + esc(closeLabel) + '">&times;</button>';

      if (ev.image) {
        h += '<img class="cal__popup-img" src="' + esc(ev.image) + '" alt="' + esc(ev.title) + '" loading="lazy" />';
      }

      h += '<div class="cal__popup-body">';
      h +=
        '<span class="cal__popup-cat" style="color:' +
        eventColor(ev) +
        '">' +
        esc(catLabels[ev.category] || ev.category) +
        '</span>';
      h += '<span class="cal__popup-title">' + esc(ev.title) + '</span>';

      // Info rows
      h += '<div class="cal__popup-info">';
      if (ts) {
        h +=
          '<div class="cal__popup-row"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ' +
          esc(ts) +
          '</div>';
      }
      var venueName = ev.venue && ev.venue !== 'TBD' ? ev.venue : null;
      if (venueName) {
        h +=
          '<div class="cal__popup-row"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> ' +
          esc(venueName) +
          '</div>';
        if (ev.location && ev.location !== venueName) {
          h += '<div class="cal__popup-row cal__popup-row--sub">' + esc(ev.location) + '</div>';
        }
      } else {
        h +=
          '<div class="cal__popup-row"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> ' +
          esc(tbdLabel) +
          '</div>';
      }
      if (ev.description) {
        h += '<div class="cal__popup-row cal__popup-row--desc">' + esc(ev.description) + '</div>';
      } else if (ev.format) {
        h +=
          '<div class="cal__popup-row"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a4 4 0 00-8 0v2"/></svg> ' +
          esc(ev.format) +
          '</div>';
      }
      h += '</div>';

      // Actions row
      var hasTBD = ts === 'TBD' || !ts;
      h += '<div class="cal__popup-actions">';
      if (!hasTBD) {
        h += '<a href="' + googleUrl(ev) + '" target="_blank" rel="noopener noreferrer" class="cal__popup-btn">';
        h +=
          '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>';
        h += ' ' + esc(addGoogle) + '</a>';
      }
      if (ev.archonUrl) {
        var platform = ev.archonUrl.indexOf('bcncrisis') !== -1 ? 'BCN Crisis' : 'Archon';
        h +=
          '<a href="' +
          esc(ev.archonUrl) +
          '" target="_blank" rel="noopener noreferrer" class="cal__popup-btn">' +
          platform +
          '</a>';
      }
      if (ev.url) {
        h += '<a href="' + esc(ev.url) + '" class="cal__popup-cta">' + esc(readCta) + ' &rarr;</a>';
      }
      h += '</div>';

      h += '</div>';

      popupInner.innerHTML = h;
      popup.hidden = false;

      var closeBtn = popupInner.querySelector('.cal__popup-close') as HTMLElement;
      closeBtn.addEventListener('click', closePopup);
      closeBtn.focus();

      // Focus trap inside popup
      focusTrapHandler = function (e: KeyboardEvent) {
        if (e.key !== 'Tab') return;
        var focusable = popupInner.querySelectorAll<HTMLElement>('a, button, [tabindex]');
        if (focusable.length === 0) return;
        var first = focusable[0],
          last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      };
      popupInner.addEventListener('keydown', focusTrapHandler);
    }

    // Close popup on outside click or Escape
    popup.addEventListener('click', function (e) {
      if (e.target === popup) closePopup();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !popup.hidden) closePopup();
    });

    function eventColor(ev: CalEvent) {
      if (ev.category === 'grand-prix') return '#CE2B37';
      if (ev.category === 'tour') return '#009246';
      if (ev.category === 'nazionale') return '#F0E6D3';
      if (ev.category === 'local') return '#4A90D9';
      if (ev.category === 'comunita') {
        var t = ev.tags || [];
        if (t.indexOf('contest') !== -1 || t.indexOf('prerelease') !== -1) return '#9B59B6';
        return '#4A90D9';
      }
      return '#9B59B6';
    }

    function render() {
      closePopup();
      titleEl.textContent = monthNames[displayMonth] + ' ' + displayYear;
      var firstDay = new Date(displayYear, displayMonth, 1).getDay();
      var startOffset = (firstDay + 6) % 7;
      var daysInMonth = new Date(displayYear, displayMonth + 1, 0).getDate();
      var today = new Date();
      var isCurrentMonth = today.getFullYear() === displayYear && today.getMonth() === displayMonth;
      var todayDate = today.getDate();

      var html = '';

      // Empty cells before first day
      for (var i = 0; i < startOffset; i++) {
        html += '<div class="cal__cell cal__cell--empty" role="gridcell"></div>';
      }

      // Day cells
      for (var d = 1; d <= daysInMonth; d++) {
        var dayEvts = eventsForDay(displayYear, displayMonth, d);
        var isToday = isCurrentMonth && d === todayDate;
        var ev: CalEvent | null = dayEvts.length > 0 ? dayEvts[0] : null;

        var cls = 'cal__cell';
        if (isToday) cls += ' cal__cell--today';
        if (ev) cls += ' cal__cell--event';

        html +=
          '<div class="' +
          cls +
          '" role="gridcell"' +
          (ev
            ? ' data-day="' +
              d +
              '" data-cat="' +
              esc(ev.category) +
              '" tabindex="0" aria-label="' +
              esc(ev.title) +
              '"'
            : '') +
          '>';

        // Background image (desktop only via CSS)
        if (ev && ev.image) {
          html += '<div class="cal__cell-bg" role="presentation" style="background-image:url(' + esc(ev.image) + ')">';
          html += '<div class="cal__cell-overlay"></div>';
          html += '</div>';
        }

        html += '<span class="cal__cell-day">' + d + '</span>';

        if (ev) {
          // Dot indicator (visible on mobile)
          html += '<span class="cal__cell-dot" style="background:' + eventColor(ev) + '"></span>';
          // Text label (hidden on mobile)
          html += '<span class="cal__cell-label" style="color:' + eventColor(ev) + '">' + esc(ev.title) + '</span>';
        }

        html += '</div>';
      }

      // Trailing empty cells
      var total = startOffset + daysInMonth;
      var rem = total % 7;
      if (rem > 0) {
        for (var j = 0; j < 7 - rem; j++) {
          html += '<div class="cal__cell cal__cell--empty" role="gridcell"></div>';
        }
      }

      body.innerHTML = html;
    }

    cal.querySelector('.cal__prev')!.addEventListener('click', function () {
      displayMonth--;
      if (displayMonth < 0) {
        displayMonth = 11;
        displayYear--;
      }
      render();
    });
    cal.querySelector('.cal__next')!.addEventListener('click', function () {
      displayMonth++;
      if (displayMonth > 11) {
        displayMonth = 0;
        displayYear++;
      }
      render();
    });
    cal.querySelector('.cal__today-btn')!.addEventListener('click', function () {
      var n = new Date();
      displayYear = n.getFullYear();
      displayMonth = n.getMonth();
      render();
    });

    // Month/Year picker
    var picker = document.getElementById('cal-picker')!;
    var pickerYear = document.getElementById('cal-picker-year')!;
    var pickerMonths = document.getElementById('cal-picker-months')!;
    var pickerYearVal = displayYear;

    function renderPicker() {
      pickerYear.textContent = String(pickerYearVal);
      var html = '';
      for (var m = 0; m < 12; m++) {
        var active = m === displayMonth && pickerYearVal === displayYear;
        html +=
          '<button type="button" class="cal__picker-month' +
          (active ? ' cal__picker-month--active' : '') +
          '" data-month="' +
          m +
          '">' +
          esc(monthNames[m] || '') +
          '</button>';
      }
      pickerMonths.innerHTML = html;
      var btns = pickerMonths.querySelectorAll<HTMLElement>('.cal__picker-month');
      for (var i = 0; i < btns.length; i++) {
        btns[i].addEventListener('click', function (this: HTMLElement) {
          displayMonth = parseInt(this.getAttribute('data-month') || '0');
          displayYear = pickerYearVal;
          closePicker();
          render();
        });
      }
    }

    function openPicker() {
      pickerYearVal = displayYear;
      renderPicker();
      picker.hidden = false;
      titleEl.setAttribute('aria-expanded', 'true');
    }

    function closePicker() {
      picker.hidden = true;
      titleEl.setAttribute('aria-expanded', 'false');
    }

    titleEl.addEventListener('click', function () {
      if (picker.hidden) openPicker();
      else closePicker();
    });

    document.getElementById('cal-picker-close')!.addEventListener('click', closePicker);

    document.getElementById('cal-picker-prev-year')!.addEventListener('click', function () {
      pickerYearVal--;
      renderPicker();
    });
    document.getElementById('cal-picker-next-year')!.addEventListener('click', function () {
      pickerYearVal++;
      renderPicker();
    });

    // Close picker on backdrop click
    picker.addEventListener('click', function (e) {
      if (e.target === picker) closePicker();
    });

    // Close picker on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !picker.hidden) closePicker();
    });

    function openCell(cell: Element) {
      var day = parseInt(cell.getAttribute('data-day') || '0');
      var dayEvts = eventsForDay(displayYear, displayMonth, day);
      if (dayEvts.length > 0) showPopup(dayEvts[0]);
    }
    body.addEventListener('click', function (e) {
      var target = e.target as HTMLElement | null;
      var cell = target?.closest('.cal__cell--event');
      if (cell) openCell(cell);
    });
    body.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        var target = e.target as HTMLElement | null;
        var cell = target?.closest('.cal__cell--event');
        if (cell) {
          e.preventDefault();
          openCell(cell);
        }
      }
    });

    render();
  })();
</script>
