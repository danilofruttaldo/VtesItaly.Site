---
import Base from '../layouts/Base.astro';
---

<Base title="404" noindex>
  <section class="not-found">
    <div class="container">
      <h1>404</h1>
      <p class="subtitle" id="nf-subtitle">Pagina non trovata.</p>
      <p class="hint" id="nf-hint">Il vampiro che cercavi si è nascosto nell'ombra...</p>
      <nav class="not-found__links" id="nf-links">
        <a href="/" class="btn">Home</a>
        <a href="/comunita/" class="btn btn--outline" id="nf-community">Comunità</a>
        <a href="/principati/" class="btn btn--outline" id="nf-domains">Principati</a>
      </nav>
    </div>
  </section>
</Base>
<script is:inline>
  (function () {
    var isEn = window.location.pathname.startsWith('/en/') || window.location.pathname === '/en';
    if (!isEn) {
      try {
        isEn = localStorage.getItem('vtesitaly-lang') === 'en';
      } catch {
        /* storage unavailable */
      }
    }
    if (isEn) {
      document.getElementById('nf-subtitle').textContent = 'Page not found.';
      document.getElementById('nf-hint').textContent = 'The vampire you were looking for has hidden in the shadows...';
      var home = document.querySelector('#nf-links .btn');
      if (home) home.href = '/en/';
      var comm = document.getElementById('nf-community');
      if (comm) {
        comm.href = '/en/community/';
        comm.textContent = 'Community';
      }
      var dom = document.getElementById('nf-domains');
      if (dom) {
        dom.href = '/en/domains/';
        dom.textContent = 'Domains';
      }
    }
  })();
</script>
<style>
  .not-found {
    text-align: center;
    padding: 100px 20px;
  }
  .not-found h1 {
    font-size: 5rem;
    color: var(--color-accent-1);
    margin-bottom: 8px;
    line-height: var(--leading-none);
  }
  .subtitle {
    color: var(--color-muted);
    margin-bottom: 8px;
    font-size: var(--font-size-md);
  }
  .hint {
    color: var(--color-gold);
    font-style: italic;
    margin-bottom: 32px;
    font-size: var(--font-size-small);
  }
  .not-found__links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn--outline {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent-1);
  }
  .btn--outline:hover {
    background-color: var(--color-accent);
    color: #fff;
  }
</style>
