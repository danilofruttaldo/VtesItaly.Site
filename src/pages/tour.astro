---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import TournamentPage from '../components/TournamentPage.astro';
import { getCollection } from 'astro:content';
import { mainPages } from '../data/pages';

const page = mainPages.find(p => p.slug === 'tour')!;
const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'tour')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title={page.titleIt} description={page.descriptionIt}>
  <PageHero title={page.titleIt} image={page.headerImage} />
  <TournamentPage
    posts={posts}
    leadHtml={`<p class="page-lead">Il <strong>VTES Italian Tour</strong> è un'entusiasmante <strong>serie di tornei</strong> che si svolgono durante tutto l'anno nei <strong>principali Principati italiani</strong>. Ogni <strong>tappa</strong> offre l'opportunità di <strong>guadagnare punti preziosi</strong> per la <strong>classifica annuale</strong>, con i <strong>migliori giocatori</strong> pronti a contendersi <strong>tutto il territorio</strong>.</p><p>Preparati a vivere una <strong>competizione avvincente e strategica</strong>, dove <strong>ogni partita può fare la differenza</strong> nel <strong>cammino verso la vittoria finale</strong>.</p>`}
    editionsTitle="Edizioni del Tour"
    baseUrl="/tour/"
  />
</Base>
